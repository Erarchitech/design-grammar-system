{
  "id": "string_unique",
  "layer": "DesignGrammar.Communication | DesignGrammar.Validation",
  "task": "nl_to_swrl_and_metagraph",
  "rule_kind": "violation | compliance",
  "domain": "string",
  "input_nl": {
    "text": "natural language rule",
    "controlled_terms": [
      {
        "surface": "term as written in NL",
        "iri": "curie_or_iri",
        "owl_type": "owl:Class | owl:DatatypeProperty | owl:ObjectProperty | owl:NamedIndividual | rdfs:Datatype",
        "range": "xsd:decimal | ex:SomeClass | null",
        "notes": "optional"
      }
    ]
  },
  "output_formal": {
    "language": "SWRL",
    "expression": "single-line SWRL"
  },
  "metagraph": {
    "rule_node": {
      "label": "Rule",
      "key": {
        "Rule_Id": "same_as_dataset_id"
      },
      "props": {
        "SWRL": "SWRL expression string",
        "kind": "violation | compliance",
        "RuleName": "optional human-readable name",
        "RuleDescription": "optional human-readable description",
        "project": "default-project",
        "graph": "Metagraph"
      }
    },
    "nodes": [
      {
        "label": "Class",
        "key": {
          "iri": "ex:<ClassName>"
        },
        "props": {
          "label": "<ClassName>",
          "project": "default-project",
          "graph": "OntoGraph"
        }
      },
      {
        "label": "DatatypeProperty",
        "key": {
          "iri": "ex:<propertyName>"
        },
        "props": {
          "SWRL_label": "<propertyName>",
          "range": "xsd:decimal | xsd:integer | xsd:boolean | xsd:string",
          "project": "default-project",
          "graph": "OntoGraph"
        }
      },
      {
        "label": "Builtin",
        "key": {
          "iri": "swrlb:<builtinName>"
        },
        "props": {
          "label": "<builtinName>",
          "project": "default-project",
          "graph": "Metagraph"
        }
      },
      {
        "label": "Atom",
        "key": {
          "Atom_Id": "{Rule_Id}_A{n} | {Rule_Id}_H{n}"
        },
        "props": {
          "Atom_Id": "{Rule_Id}_A{n} | {Rule_Id}_H{n}",
          "type": "ClassAtom | DataPropertyAtom | ObjectPropertyAtom | BuiltinAtom",
          "iri": "ex:<ClassName> | ex:<propertyName> | swrlb:<builtinName>",
          "SWRL_label": "<ClassName> | <propertyName> | <builtinName>",
          "project": "default-project",
          "graph": "Metagraph"
        }
      },
      {
        "label": "Var",
        "key": {
          "name": "?<varName>",
          "project": "default-project"
        },
        "props": {
          "project": "default-project",
          "graph": "Metagraph"
        }
      },
      {
        "label": "Literal",
        "key": {
          "lex": "<value>",
          "datatype": "xsd:decimal | xsd:integer | xsd:boolean | xsd:string"
        },
        "props": {
          "project": "default-project",
          "graph": "Metagraph"
        }
      }
    ],
    "schema_reference": {
      "note": "DesignState & Run are document-only — NOT emitted by LLM ingest. Written only by VALIDATOR-on-publish. The ingest emits OntoGraph + Metagraph nodes only. This reference documents the full schema for reader context.",
      "DesignState": {
        "label": "DesignState",
        "key": {
          "StateId": "DS_<hash> | OS_<hash> | PS_<hash>",
          "project": "default-project"
        },
        "props": {
          "kind": "ObjState | ParamState | PropState",
          "project": "default-project",
          "graph": "ValidGraph"
        }
      },
      "Run": {
        "label": "ValidationRun",
        "key": {
          "ValidationRunId": "<uuid>",
          "project": "default-project"
        },
        "props": {
          "ValidStatus": "per-ObjState Boolean list, index-matched",
          "SendStatus": "single Boolean",
          "project": "default-project",
          "graph": "ValidGraph"
        },
        "note": "No stored Status text field. Overall pass = AND(ValidStatus), derived at read time."
      },
      "RunDesignStateRelationship": {
        "type": "VALIDATES",
        "from": "Run",
        "to": "DesignState",
        "cardinality": "many Runs to one DesignState"
      },
      "note_identity_registry": "Representation & SharedProperty are document-only — NOT emitted by LLM ingest. Written only by the data-service identity API (/identity/ routes). The ingest emits OntoGraph + Metagraph nodes only. These entries document the registry node shapes for reader context.",
      "Representation": {
        "label": "Representation",
        "key": {
          "nativeId": "<platform-native identifier>",
          "platform": "Grasshopper | Revit | IFC | Speckle",
          "project": "default-project"
        },
        "props": {
          "nativeId": "string",
          "platform": "Grasshopper | Revit | IFC | Speckle",
          "nativeIdKind": "InstanceGuid | UniqueId | GlobalId | ApplicationId",
          "connector": "string",
          "boundAt": "datetime",
          "graph": "Computgraph",
          "project": "default-project"
        }
      },
      "SharedProperty": {
        "label": "SharedProperty",
        "key": {
          "dgId": "dg:<16 uppercase hex>",
          "propertyName": "string",
          "project": "default-project"
        },
        "props": {
          "dgId": "string (dg:<16 uppercase hex>)",
          "propertyName": "string",
          "value": "any",
          "platform": "string",
          "connector": "string",
          "writtenAt": "datetime",
          "graph": "Computgraph",
          "project": "default-project"
        }
      },
      "IdentityRelationships": {
        "HAS_REPRESENTATION": {
          "type": "HAS_REPRESENTATION",
          "from": "Computgraph entity",
          "to": "Representation"
        },
        "HAS_SHARED_PROPERTY": {
          "type": "HAS_SHARED_PROPERTY",
          "from": "Computgraph entity",
          "to": "SharedProperty"
        }
      },
      "note_computgraph_runtime": "Computgraph runtime nodes are document-only — NOT emitted by LLM ingest. Written ONLY by data-service POST /computgraph/publish. These entries document the runtime node shapes for reader context.",
      "Object": {
        "label": "Object",
        "key": {
          "cgId": "<cg:<alg>:<kind>:<conventionName>>",
          "definitionId": "string",
          "project": "default-project"
        },
        "props": {
          "objectName": "string",
          "classIri": "string (optional, ex:<ClassName>)",
          "dgId": "string (dg:<16 uppercase hex>)",
          "source": "string (tagged | recognized)",
          "provider": "string (recognized only, optional)",
          "model": "string (recognized only, optional)",
          "confidence": "number (recognized only, optional)",
          "definitionId": "string",
          "fileName": "string (optional)",
          "publishedAt": "datetime",
          "graph": "Computgraph",
          "project": "default-project"
        }
      },
      "Behavior": {
        "label": "Behavior",
        "key": {
          "definitionId": "string",
          "project": "default-project"
        },
        "props": {
          "definitionId": "string",
          "graph": "Computgraph",
          "project": "default-project"
        },
        "note": "Structural node — no cgId/dgId"
      },
      "Algorithm": {
        "label": "Algorithm",
        "key": {
          "algIndex": "integer",
          "definitionId": "string",
          "project": "default-project"
        },
        "props": {
          "algorithmName": "string",
          "algIndex": "integer",
          "contextJson": "string (JSON)",
          "graph": "Computgraph",
          "project": "default-project"
        }
      },
      "Procedure": {
        "label": "Procedure",
        "key": {
          "cgId": "<cg:<alg>:<kind>:<conventionName>>",
          "definitionId": "string",
          "project": "default-project"
        },
        "props": {
          "procedureName": "string",
          "procIndex": "integer",
          "cgId": "string (cg:<alg>:<kind>:<conventionName>)",
          "dgId": "string (dg:<16 uppercase hex>)",
          "graph": "Computgraph",
          "project": "default-project"
        }
      },
      "Pattern": {
        "label": "Pattern",
        "key": {
          "cgId": "<cg:<alg>:<kind>:<conventionName>>",
          "definitionId": "string",
          "project": "default-project"
        },
        "props": {
          "patternName": "string",
          "cgId": "string (cg:<alg>:<kind>:<conventionName>)",
          "dgId": "string (dg:<16 uppercase hex>)",
          "graph": "Computgraph",
          "project": "default-project"
        }
      },
      "Parameter": {
        "label": "Parameter",
        "key": {
          "cgId": "<cg:<alg>:<kind>:<conventionName>>",
          "definitionId": "string",
          "project": "default-project"
        },
        "props": {
          "parameterName": "string",
          "paramKind": "Variable | Constant | Emergent",
          "dataType": "Float | Integer | Text | Boolean | Geometry",
          "domainMin": "number (optional)",
          "domainMax": "number (optional)",
          "domainStep": "number (optional)",
          "cgId": "string (cg:<alg>:<kind>:<conventionName>)",
          "dgId": "string (dg:<16 uppercase hex>)",
          "graph": "Computgraph",
          "project": "default-project"
        }
      },
      "Interface": {
        "label": "Interface",
        "key": {
          "cgId": "<cg:<alg>:<kind>:<conventionName>>",
          "definitionId": "string",
          "project": "default-project"
        },
        "props": {
          "interfaceName": "string",
          "ifaceType": "Input | Output",
          "cgId": "string (cg:<alg>:<kind>:<conventionName>)",
          "dgId": "string (dg:<16 uppercase hex>)",
          "graph": "Computgraph",
          "project": "default-project"
        }
      },
      "ComputgraphRelationships": {
        "HAS_BEHAVIOR": {
          "type": "HAS_BEHAVIOR",
          "from": "Object",
          "to": "Behavior"
        },
        "HAS_ALGORITHM": {
          "type": "HAS_ALGORITHM",
          "from": "Behavior",
          "to": "Algorithm"
        },
        "HAS_PROCEDURE": {
          "type": "HAS_PROCEDURE",
          "from": "Algorithm",
          "to": "Procedure"
        },
        "HAS_PATTERN": {
          "type": "HAS_PATTERN",
          "from": "Procedure",
          "to": "Pattern"
        },
        "PATTERN_HOST_TO": {
          "type": "PATTERN_HOST_TO",
          "from": "Pattern",
          "to": "Pattern"
        },
        "HAS_PARAMETER": {
          "type": "HAS_PARAMETER",
          "from": "Procedure",
          "to": "Parameter"
        },
        "HAS_INTERFACE": {
          "type": "HAS_INTERFACE",
          "from": "Procedure",
          "to": "Interface"
        },
        "PARAM_LINK": {
          "type": "PARAM_LINK",
          "from": "Parameter",
          "to": "Interface"
        },
        "REFERS_TO": {
          "type": "REFERS_TO",
          "from": "Object",
          "to": "Class",
          "note": "Cross-layer bridge to OntoGraph"
        }
      }
    },
    "atoms": [
      {
        "Atom_Id": "{Rule_Id}_A{n} | {Rule_Id}_H{n}",
        "atom_type": "ClassAtom | DataPropertyAtom | ObjectPropertyAtom | BuiltinAtom",
        "predicate_ref": {
          "iri": "ex:<ClassName> | ex:<propertyName> | swrlb:<builtinName>",
          "SWRL_label": "<ClassName> | <propertyName> | <builtinName>",
          "owl_type": "owl:Class | owl:DatatypeProperty | owl:ObjectProperty | swrl:Builtin"
        },
        "args": [
          {
            "pos": 1,
            "type": "Var",
            "value": "?<varName>"
          },
          {
            "pos": 2,
            "type": "Var | Literal",
            "value": "?<varName> | <literalValue>",
            "datatype": "null | xsd:decimal | xsd:integer | xsd:boolean | xsd:string"
          }
        ]
      }
    ],
    "connections": [
      {
        "type": "HAS_BODY",
        "from": "{Rule_Id}",
        "to": "{Rule_Id}_A{n}",
        "order": 1
      },
      {
        "type": "HAS_HEAD",
        "from": "{Rule_Id}",
        "to": "{Rule_Id}_H{n}",
        "order": 1
      },
      {
        "type": "REFERS_TO",
        "from": "{Atom_Id}",
        "to_onto_iri": "<iri of Class | DatatypeProperty | Builtin>"
      },
      {
        "type": "ARG",
        "from": "{Atom_Id}",
        "to": {
          "type": "Var | Literal",
          "value": "?<varName> | <literalValue>"
        },
        "pos": 1
      }
    ]
  },
  "metadata": {
    "entity_scope": "ex:<ClassName>",
    "constraint_semantics": "minimum | maximum | range | implication | equality | cardinality",
    "unit": "m | hours_per_day | null",
    "numeric_type": "xsd:decimal | xsd:integer | xsd:boolean | null",
    "thresholds": {
      "min": 0,
      "max": 0
    },
    "assumptions": [
      "..."
    ],
    "version": "v4.0"
  }
}