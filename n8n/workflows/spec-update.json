        -460,
        0
      ]
    },
    {
      "parameters": {
        "functionCode": "return [{ json: { status: 'accepted', executionId: String($execution.id) } }];"
      },
      "id": "ku-format-ack",
      "name": "Format Ack",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        -460,
        -160
      ]
    },
    {
      "parameters": {
        "responseCode": 200
      },
      "id": "ku-respond-ack",
      "name": "Respond Ack",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        -220,
        -160
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.all()[0].json;\nconst currentContent = input.current_content || '';\nconst updatePrompt = input.prompt_text || '';\n\nconst prompt = [\n  'You are an architectural knowledge editor.',\n  'Revise the note content according to the update instruction.',\n  'Return ONLY the revised note text — no explanation, no JSON, no markdown fences.',\n  'Preserve the original structure and tone. Only change what the instruction requests.',\n  '',\n  'Update instruction:',\n  updatePrompt,\n  '',\n  'Current note content:',\n  currentContent,\n  '',\n  'Revised note content:'\n].join('\\n');\n\nreturn [{ json: { ...input, update_prompt: prompt } }];"
      },
      "id": "ku-build-prompt",
      "name": "Build Update Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -220,
        0
      ]
    },
    {
      "parameters": {
        "url": "http://ollama:11434/api/generate",
        "jsonParameters": true,
        "options": {
          "timeout": 900000
        },
        "bodyParametersJson": "={{ { \"model\": \"llama3.1\", \"prompt\": $json.update_prompt, \"stream\": false, \"options\": { \"temperature\": 0.3 } } }}",
        "requestMethod": "POST"
      },
      "id": "ku-ollama",
      "name": "Ollama Generate",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        20,
        0
      ]
    },
    {
      "parameters": {
        "keepOnlySet": true,
        "values": {
          "string": [
            {
              "name": "proposed_text",
              "value": "={{$json.response || ''}}"
            },
            {
              "name": "execution_id",
              "value": "={{$items('Build Update Prompt')[0].json.execution_id || ''}}"
            },
            {
              "name": "note_id",
              "value": "={{$items('Build Update Prompt')[0].json.note_id || ''}}"
            },
            {
              "name": "project_name",
              "value": "={{$items('Build Update Prompt')[0].json.project_name || ''}}"
            }
          ]
        }
      },
      "id": "ku-parse-text",
      "name": "Parse LLM Text",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        260,
        0
      ]
    },
    {
