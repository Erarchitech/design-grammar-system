        "jsonParameters": true,
        "bodyParametersJson": "={{ { \"executionId\": $json.execution_id, \"status\": \"completed\", \"workflow\": \"knowledge-update\", \"payload\": { \"proposedText\": $json.proposed_text } } }}",
        "requestMethod": "POST"
      },
      "id": "ku-post-result",
      "name": "Post Execution Result",
      "type": "n8n-nodes-base.httpRequest",
