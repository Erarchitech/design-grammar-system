          <mxGeometry x="420" y="370" width="117" height="117" as="geometry" />
        </mxCell>
        <mxCell id="B0CF9BZpH_4emkg-0tWx-5" value="Material Ontology" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#f8cecc;strokeColor=#b85450;opacity=50;" parent="1" vertex="1">
