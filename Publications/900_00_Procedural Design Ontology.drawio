        <object label="Product Modelling Ontology" Description="This ontology structures the lifecycle of a product, detailing components, features, and configurations from design to manufacturing. It captures relationships among different product elements, focusing on specifications, material properties, and functional requirements." Id="302" References="" placeholders="1" Role="Unlike abstract design ontologies, this is practical and component-focused, emphasizing usability in engineering and manufacturing for real-world production." id="s6fc3c9Xg-LPU3BYoQBv-1">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#F08705;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=1;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
            <mxGeometry x="610" y="1369" width="150" height="60" as="geometry" />
          </mxCell>
        </object>
        <object label="Parametric Design Ontology" Description="Parametric design ontology organizes knowledge around parameters and constraints that guide the generation of designs. It includes the definition of variables, dependencies, and rules that dynamically control design outputs, enabling the creation of adaptable and responsive forms." Id="303" References="" placeholders="1" Role="It focuses on the interplay between variables, setting it apart from other ontologies by emphasizing flexibility through parameters rather than static shapes or structures." id="s6fc3c9Xg-LPU3BYoQBv-2">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#F08705;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=1;arcSize=7;perimeterSpacing=2;" parent="1" vertex="1">
