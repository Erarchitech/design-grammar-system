          </mxCell>
        </object>
        <object label="&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Agents&lt;/b&gt;&lt;/span&gt;" Description="Independent entities with specific attributes, behaviors, and objectives, such as individuals in a crowd, autonomous robots, or vehicles." Role="Serve as the fundamental components in the system, each with unique characteristics and the ability to perceive and interact with their environment and other agents, leading to complex, emergent patterns." id="Z8ZMG5t9qmk1xCjCsyjZ-1984">
          <mxCell style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=33;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;strokeColor=#1A1A1A;perimeterSpacing=1;" parent="baEqDthC3gyB-VP1ChTG-1819" vertex="1">
