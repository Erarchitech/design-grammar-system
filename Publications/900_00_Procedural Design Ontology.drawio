        <object label="&lt;font&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Functional Requirements&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;" Description="Outlines the intended function and performance expectations of the product." Role="Guides design and manufacturing by specifying objectives that the product must meet, ensuring it is fit for purpose and compliant." id="7iJxjdkOMapWwhl0Z6aH-1814">
          <mxCell style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;perimeterSpacing=1;strokeColor=#1A1A1A;fontColor=#001933;" parent="1" vertex="1">
