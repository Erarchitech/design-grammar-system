        </mxCell>
        <mxCell id="B0CF9BZpH_4emkg-0tWx-6" value="Human-Centered Design Ontology" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#fff2cc;strokeColor=#d6b656;opacity=50;" parent="1" vertex="1">
          <mxGeometry x="340" y="344" width="83" height="83" as="geometry" />
        </mxCell>
        <mxCell id="B0CF9BZpH_4emkg-0tWx-8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="B0CF9BZpH_4emkg-0tWx-7" target="B0CF9BZpH_4emkg-0tWx-2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="B0CF9BZpH_4emkg-0tWx-7" value="&lt;h1 style=&quot;margin-top: 0px; line-height: 0%;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Closely related&lt;/font&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; line-height: 20%;&quot;&gt;&lt;span style=&quot;font-size: 8px; background-color: initial; font-weight: normal;&quot;&gt;IFC&#39;s hierarchical structure of building components (e.g., walls, slabs, doors) mirrors product modeling ontologies&#39; representation of product parts.&lt;/span&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="83" y="442" width="125" height="90" as="geometry" />
        </mxCell>
        <mxCell id="B0CF9BZpH_4emkg-0tWx-10" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="B0CF9BZpH_4emkg-0tWx-9" target="B0CF9BZpH_4emkg-0tWx-3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="B0CF9BZpH_4emkg-0tWx-9" value="&lt;h1 style=&quot;margin-top: 0px; line-height: 0%;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Related&lt;/font&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; line-height: 20%;&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;IFC defines processes such as scheduling, resource allocation, and construction sequencing, which align with process design ontologies.&lt;/span&gt;&lt;br&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="568" y="485" width="125" height="90" as="geometry" />
        </mxCell>
        <mxCell id="11-uI4Rqhqnwz-yZQAW2-2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="11-uI4Rqhqnwz-yZQAW2-1" target="B0CF9BZpH_4emkg-0tWx-6" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="11-uI4Rqhqnwz-yZQAW2-1" value="&lt;h1 style=&quot;margin-top: 0px; line-height: 0%;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Partially related&lt;/font&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; line-height: 20%;&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;IFC includes parameters for accessibility, usability, and occupant comfort, which align with user-centric aspects of human-centered design.&lt;/span&gt;&lt;br&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="319" y="233" width="125" height="90" as="geometry" />
        </mxCell>
        <mxCell id="11-uI4Rqhqnwz-yZQAW2-4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="11-uI4Rqhqnwz-yZQAW2-3" target="B0CF9BZpH_4emkg-0tWx-4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="11-uI4Rqhqnwz-yZQAW2-3" value="&lt;h1 style=&quot;margin-top: 0px; line-height: 0%;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Related&lt;/font&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; line-height: 20%;&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;IFC handles spatial relationships and connectivity (e.g., adjacency of rooms, pathways) akin to the concepts in topological ontologies.&lt;/span&gt;&lt;br&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="568" y="383.5" width="125" height="90" as="geometry" />
        </mxCell>
        <mxCell id="11-uI4Rqhqnwz-yZQAW2-6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="11-uI4Rqhqnwz-yZQAW2-5" target="B0CF9BZpH_4emkg-0tWx-5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="11-uI4Rqhqnwz-yZQAW2-5" value="&lt;h1 style=&quot;margin-top: 0px; line-height: 0%;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Partially related&lt;/font&gt;&lt;/h1&gt;&lt;h1 style=&quot;margin-top: 0px; line-height: 20%;&quot;&gt;&lt;span style=&quot;font-size: 8px; font-weight: 400;&quot;&gt;IFC includes material properties (e.g., thermal conductivity, durability), which overlap with material ontologies.&lt;/span&gt;&lt;br&gt;&lt;/h1&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="324" y="613" width="125" height="90" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
