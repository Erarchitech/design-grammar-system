        <object label="&lt;font&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Environment&lt;/b&gt;&lt;/span&gt;&lt;/font&gt;" Description="The spatial or virtual context in which agents operate, which can include physical boundaries, obstacles, or resources." Role="Provides the framework within which agents interact, move, and respond. The environment often influences agents’ behavior and decision-making and can evolve based on agents’ actions, thus creating dynamic feedback loops." id="Z8ZMG5t9qmk1xCjCsyjZ-1972">
          <mxCell style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;strokeColor=#1A1A1A;perimeterSpacing=1;fontColor=#001933;" parent="baEqDthC3gyB-VP1ChTG-1819" vertex="1">
            <mxGeometry x="-1" y="280" width="168" height="90" as="geometry">
              <mxRectangle x="1455" y="581" width="163" height="30" as="alternateBounds" />
            </mxGeometry>
          </mxCell>
        </object>
        <object label="Spatial Structure" Description="The layout or organization of the environment, such as grids, nodes, or open fields." id="Z8ZMG5t9qmk1xCjCsyjZ-1973">
          <mxCell style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontColor=#1A1A1A;" parent="Z8ZMG5t9qmk1xCjCsyjZ-1972" vertex="1">
