        <object label="Agent-based Ontology" Description="Shape grammar ontology is a system of rules defining how shapes and forms can be generated and manipulated. It uses a rule-based approach where shapes are combined, transformed, and adapted according to specific grammar rules, fostering flexibility and creativity in design." Id="306" References="" placeholders="1" Role="Uniquely grounded in behavior and interaction, this ontology enables emergent, self-organizing systems, contrasting with more static frameworks in design." id="Z8ZMG5t9qmk1xCjCsyjZ-1963">
          <mxCell style="rounded=1;whiteSpace=wrap;html=1;shadow=0;labelBackgroundColor=none;strokeColor=none;strokeWidth=3;fillColor=#F08705;fontFamily=Helvetica;fontSize=14;fontColor=#FFFFFF;align=center;spacing=5;fontStyle=1;arcSize=7;perimeterSpacing=2;" parent="baEqDthC3gyB-VP1ChTG-1819" vertex="1">
