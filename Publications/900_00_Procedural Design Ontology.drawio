        </mxCell>
        <object label="&lt;b style=&quot;font-size: 14px;&quot;&gt;Behavior Rules&lt;/b&gt;" Description="Set of rules or algorithms defining how agents behave under specific conditions. This includes movement, decision-making processes, and responses to other agents or environmental stimuli." Role="Dictates agent actions, facilitating interactions that contribute to the emergence of collective patterns. Behaviors may include attraction, repulsion, alignment, or task-specific functions like searching or resource-gathering." id="Z8ZMG5t9qmk1xCjCsyjZ-1968">
          <mxCell style="swimlane;fontStyle=0;childLayout=stackLayout;horizontal=1;startSize=30;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;whiteSpace=wrap;html=1;strokeColor=#1A1A1A;perimeterSpacing=1;fontColor=#001933;" parent="baEqDthC3gyB-VP1ChTG-1819" vertex="1">
            <mxGeometry y="168" width="167" height="90" as="geometry">
              <mxRectangle x="1452" y="684" width="175" height="31" as="alternateBounds" />
            </mxGeometry>
          </mxCell>
        </object>
        <object label="Interaction Rules" Description="Rules that define how agents interact, such as cooperation, competition, or communication." id="Z8ZMG5t9qmk1xCjCsyjZ-1969">
          <mxCell style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontColor=#1A1A1A;" parent="Z8ZMG5t9qmk1xCjCsyjZ-1968" vertex="1">
            <mxGeometry y="30" width="167" height="30" as="geometry" />
          </mxCell>
        </object>
        <object label="Response Rules" placeholders="1" Description="Reaction mechanisms to environmental stimuli (e.g., obstacles or resource availability)." id="Z8ZMG5t9qmk1xCjCsyjZ-1970">
          <mxCell style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontColor=#1A1A1A;" parent="Z8ZMG5t9qmk1xCjCsyjZ-1968" vertex="1">
