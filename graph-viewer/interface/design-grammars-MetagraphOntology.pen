{
  "version": "2.9",
  "children": [
    {
      "type": "frame",
      "id": "ont000",
      "x": 0,
      "y": 0,
      "name": "Metagraph Ontology Schema",
      "width": 2400,
      "height": 3600,
      "fill": "#0f1117",
      "layout": "vertical",
      "padding": 40,
      "children": [
        {
          "type": "text",
          "id": "ontTitle",
          "name": "Schema Title",
          "fill": "#f4f7fb",
          "content": "Metagraph Ontology Schema",
          "fontFamily": "Space Grotesk",
          "fontSize": 32,
          "fontWeight": "700"
        },
        {
          "type": "text",
          "id": "ontSub",
          "name": "Schema Subtitle",
          "fill": "#7a8799",
          "content": "Complete class, property, relationship, and enum definitions for the Design Grammar rule system",
          "fontFamily": "Inter",
          "fontSize": 14,
          "fontWeight": "normal"
        },
        {
          "type": "text",
          "id": "secGraph",
          "name": "Section: Graph Node Classes",
          "fill": "#5fd0ff",
          "content": "1  Graph Node Classes (Neo4j Labels)",
          "fontFamily": "Space Grotesk",
          "fontSize": 22,
          "fontWeight": "700"
        },
        {
          "type": "frame",
          "id": "clsRule",
          "name": "Class: Rule",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#5f8fd3"
          },
          "layout": "vertical",
          "gap": 6,
          "padding": [
            20,
            24
          ],
          "children": [
            {
              "type": "frame",
              "id": "clsRuleHdr",
              "name": "Rule Header",
              "width": "fill_container",
              "gap": 12,
              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "clsRuleBdg",
                  "name": "Rule Badge",
                  "width": 36,
                  "height": 36,
                  "fill": "#5f8fd3",
                  "cornerRadius": 18,
                  "justifyContent": "center",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "clsRuleIco",
                      "fill": "#ffffff",
                      "content": "R",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 16,
                      "fontWeight": "700"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "clsRuleNm",
                  "fill": "#f4f7fb",
                  "content": "Rule",
                  "fontFamily": "Space Grotesk",
                  "fontSize": 20,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "clsRuleLbl",
                  "fill": "#7a8799",
                  "content": "Neo4j label: Rule  |  graph: Metagraph",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "clsRuleDesc",
              "fill": "#b8c2d0",
              "content": "Represents a semantic design rule expressed in SWRL. Central node of the Metagraph.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRulePH",
              "fill": "#5fd0ff",
              "content": "Properties",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "clsRuleP1",
              "fill": "#d8e0eb",
              "content": "  Rule_Id        string        (key) Unique identifier, e.g. \"R_height_max\"",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRuleP2",
              "fill": "#d8e0eb",
              "content": "  title          string?       Human-readable title (fallback: name, Rule_Id)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRuleP3",
              "fill": "#d8e0eb",
              "content": "  name           string        Rule name",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRuleP4",
              "fill": "#d8e0eb",
              "content": "  description    string        Natural-language description of the rule",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRuleP5",
              "fill": "#d8e0eb",
              "content": "  kind           RuleKind      \"violation\" | \"compliance\"",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRuleP6",
              "fill": "#d8e0eb",
              "content": "  text           string        SWRL expression string",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRuleP7",
              "fill": "#d8e0eb",
              "content": "  swrl           string        Canonical SWRL expression (fallback to text)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRuleP8",
              "fill": "#d8e0eb",
              "content": "  project        string        Project scope, e.g. \"default-project\"",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsRuleP9",
              "fill": "#d8e0eb",
              "content": "  graph          string        Always \"Metagraph\"",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "clsAtom",
          "name": "Class: Atom",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#d3845f"
          },
          "layout": "vertical",
          "gap": 6,
          "padding": [
            20,
            24
          ],
          "children": [
            {
              "type": "frame",
              "id": "clsAtomHdr",
              "name": "Atom Header",
              "width": "fill_container",
              "gap": 12,
              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "clsAtomBdg",
                  "name": "Atom Badge",
                  "width": 30,
                  "height": 30,
                  "fill": "#d3845f",
                  "cornerRadius": 15,
                  "justifyContent": "center",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "clsAtomIco",
                      "fill": "#ffffff",
                      "content": "A",
                      "fontFamily": "Space Grotesk",
                      "fontSize": 14,
                      "fontWeight": "700"
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "clsAtomNm",
                  "fill": "#f4f7fb",
                  "content": "Atom",
                  "fontFamily": "Space Grotesk",
                  "fontSize": 20,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "clsAtomLbl",
                  "fill": "#7a8799",
                  "content": "Neo4j label: Atom  |  graph: Metagraph",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "clsAtomDesc",
              "fill": "#b8c2d0",
              "content": "Represents a single predicate (condition or conclusion) within a SWRL rule.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsAtomPH",
              "fill": "#5fd0ff",
              "content": "Properties",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "clsAtomP1",
              "fill": "#d8e0eb",
              "content": "  Atom_Id        string        (key) Format: \"{Rule_Id}_A{n}\" (body) | \"{Rule_Id}_H{n}\" (head)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsAtomP2",
              "fill": "#d8e0eb",
              "content": "  type           AtomType      \"ClassAtom\" | \"DataPropertyAtom\" | \"ObjectPropertyAtom\" | \"BuiltinAtom\"",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsAtomP3",
              "fill": "#d8e0eb",
              "content": "  iri            string        IRI of the predicate, e.g. \"ex:Building\" or \"swrlb:greaterThan\"",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsAtomP4",
              "fill": "#d8e0eb",
              "content": "  SWRL_label     string?       Human-readable predicate label",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsAtomP5",
              "fill": "#d8e0eb",
              "content": "  project        string        Project scope",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsAtomP6",
              "fill": "#d8e0eb",
              "content": "  graph          string        Always \"Metagraph\"",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
