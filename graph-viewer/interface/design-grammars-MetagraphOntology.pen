          "gap": 6,
          "padding": [
            16,
            24
          ],
          "children": [
            {
              "type": "frame",
              "id": "relRTHdr",
              "name": "REFERS_TO Header",
              "width": "fill_container",
              "gap": 16,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "relRTNm",
                  "fill": "#f4f7fb",
                  "content": "REFERS_TO",
                  "fontFamily": "Space Grotesk",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "relRTDir",
                  "fill": "#9fb6c9",
                  "content": "Atom  ---->>  Class | DatatypeProperty | ObjectProperty | Builtin",
                  "fontFamily": "Courier New",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "relRTDesc",
              "fill": "#b8c2d0",
              "content": "Links an Atom to the ontology predicate it references. Every atom refers to exactly one predicate.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "relRTNote",
              "fill": "#7a8799",
              "content": "No edge properties. Target resolved by atom type: ClassAtom->Class, DataPropertyAtom->DatatypeProperty, ObjectPropertyAtom->ObjectProperty, BuiltinAtom->Builtin",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "relArg",
          "name": "Relationship: ARG",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#9fb6c9"
          },
