                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "relHBDesc",
              "fill": "#b8c2d0",
              "content": "Links a Rule to its body (antecedent/condition) atoms. A rule has 1..n body atoms.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "relHBPH",
              "fill": "#5fd0ff",
              "content": "Edge Properties",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "relHBP1",
              "fill": "#d8e0eb",
              "content": "  order          int           Execution order within the body (1-indexed)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "relHasHead",
          "name": "Relationship: HAS_HEAD",
          "width": "fill_container",
