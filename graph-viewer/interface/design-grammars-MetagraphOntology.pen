        {
          "type": "text",
          "id": "secSwrl",
          "name": "Section: SWRL Expression Syntax",
          "fill": "#5fd0ff",
          "content": "5  SWRL Expression Syntax",
          "fontFamily": "Space Grotesk",
          "fontSize": 22,
          "fontWeight": "700"
        },
        {
          "type": "frame",
          "id": "swrlSyntax",
          "name": "SWRL Syntax Reference",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#fff8d8"
          },
          "layout": "vertical",
          "gap": 8,
          "padding": [
            20,
            24
          ],
          "children": [
            {
              "type": "text",
              "id": "swrlNm",
              "fill": "#f4f7fb",
              "content": "SWRL Expression Format",
              "fontFamily": "Space Grotesk",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "swrlFmt",
              "fill": "#fff8d8",
              "content": "  Body -> Head",
              "fontFamily": "Courier New",
              "fontSize": 14,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "swrlD1",
              "fill": "#b8c2d0",
              "content": "Atoms within each side separated by '^' (caret). Variables prefixed with '?'. Arguments in parentheses, comma-separated.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlEx1L",
              "fill": "#5fd0ff",
              "content": "Example: Maximum height violation",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "swrlEx1",
              "fill": "#fff8d8",
              "content": "  Building(?b) ^ hasHeightM(?b,?h) ^ swrlb:greaterThan(?h,75) -> violatesMaxHeight(?b,true)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlEx1N",
              "fill": "#7a8799",
              "content": "  Reads: For any Building ?b with height ?h, if ?h > 75, then ?b violates max height.",
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlParsL",
              "fill": "#5fd0ff",
              "content": "Atom Parsing Rules",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "swrlPars1",
              "fill": "#d8e0eb",
              "content": "  predicate starts with \"swrlb:\"     -> BuiltinAtom",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlPars2",
              "fill": "#d8e0eb",
              "content": "  1 argument                         -> ClassAtom",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlPars3",
              "fill": "#d8e0eb",
              "content": "  2+ arguments                       -> DataPropertyAtom (default)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlLitL",
              "fill": "#5fd0ff",
              "content": "Literal Type Inference",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "swrlLit1",
              "fill": "#d8e0eb",
              "content": "  \"true\" | \"false\"                   -> xsd:boolean",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlLit2",
              "fill": "#d8e0eb",
              "content": "  number with '.'                    -> xsd:decimal",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlLit3",
              "fill": "#d8e0eb",
              "content": "  number without '.'                 -> xsd:integer",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "swrlLit4",
              "fill": "#d8e0eb",
              "content": "  anything else                      -> xsd:string",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "text",
          "id": "secPipe",
          "name": "Section: Processing Pipeline",
          "fill": "#5fd0ff",
          "content": "6  Processing Pipeline",
          "fontFamily": "Space Grotesk",
          "fontSize": 22,
          "fontWeight": "700"
        },
        {
          "type": "frame",
          "id": "pipeline",
          "name": "Pipeline Overview",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#283143"
          },
          "layout": "vertical",
          "gap": 10,
          "padding": [
            20,
            24
          ],
          "children": [
            {
              "type": "text",
              "id": "pipeNm",
              "fill": "#f4f7fb",
              "content": "Rule Lifecycle: NL Text -> Graph -> Validation -> Publish",
              "fontFamily": "Space Grotesk",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "pipe1",
              "fill": "#5fd0ff",
              "content": "  1. NL Input           User enters natural-language design rule",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "pipe2",
              "fill": "#5fd0ff",
              "content": "  2. LLM Parse          NL -> SWRL expression + Metagraph nodes/edges",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "pipe3",
              "fill": "#5fd0ff",
              "content": "  3. Write Graph        Metagraph written to Neo4j (Rule, Atom, Class, Var, Literal nodes + edges)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "pipe4",
              "fill": "#5fd0ff",
              "content": "  4. Load Rules         Neo4jRuleRepository.GetRulesAsync() -> List<Rule> with atoms & variables",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "pipe5",
              "fill": "#5fd0ff",
              "content": "  5. Classify           VariableBinder binds SWRL variables to design entity data -> ClassificationResult",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "pipe6",
              "fill": "#5fd0ff",
              "content": "  6. Evaluate           RuleEvaluator checks BuiltinAtom predicates -> RuleEvaluationResult",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "pipe7",
              "fill": "#5fd0ff",
              "content": "  7. Package            ValidationPublishPackageBuilder aggregates -> ValidationPublishPackage",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "pipe8",
              "fill": "#5fd0ff",
              "content": "  8. Publish            Package sent to host application for visualization",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "text",
          "id": "secGraphs",
          "name": "Section: Graph Partitions",
          "fill": "#5fd0ff",
          "content": "7  Graph Partitions",
          "fontFamily": "Space Grotesk",
          "fontSize": 22,
          "fontWeight": "700"
        },
        {
          "type": "frame",
          "id": "graphParts",
          "name": "Graph Partitions",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#283143"
          },
          "layout": "vertical",
          "gap": 8,
          "padding": [
            20,
            24
          ],
          "children": [
            {
              "type": "text",
              "id": "gpMeta",
              "fill": "#5f8fd3",
              "content": "Metagraph",
              "fontFamily": "Space Grotesk",
              "fontSize": 16,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "gpMetaD",
              "fill": "#b8c2d0",
              "content": "Contains: Rule, Atom, Var, Literal, Builtin nodes and all HAS_BODY, HAS_HEAD, ARG edges.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "gpMetaN",
              "fill": "#7a8799",
              "content": "The rule-structure graph. Scoped by project property. This is the primary graph for rule authoring.",
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "gpOnto",
              "fill": "#c75fd0",
              "content": "OntoGraph",
              "fontFamily": "Space Grotesk",
              "fontSize": 16,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "gpOntoD",
              "fill": "#b8c2d0",
              "content": "Contains: Class, DatatypeProperty, ObjectProperty nodes.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "gpOntoN",
              "fill": "#7a8799",
              "content": "The domain ontology graph. Atoms in Metagraph link to OntoGraph via REFERS_TO edges.",
              "fontFamily": "Inter",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        }
      ]
    }
  ]
}