              "gap": 16,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "relHHNm",
                  "fill": "#f4f7fb",
                  "content": "HAS_HEAD",
                  "fontFamily": "Space Grotesk",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "relHHDir",
                  "fill": "#9fb6c9",
                  "content": "Rule  ---->>  Atom",
                  "fontFamily": "Courier New",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "text",
              "id": "relHHDesc",
              "fill": "#b8c2d0",
              "content": "Links a Rule to its head (consequent/conclusion) atoms. A rule has 1..n head atoms.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "relHHPH",
              "fill": "#5fd0ff",
              "content": "Edge Properties",
