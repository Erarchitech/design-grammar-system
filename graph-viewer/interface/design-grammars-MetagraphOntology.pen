              "width": "fill_container",
              "gap": 16,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "relHBNm",
                  "fill": "#f4f7fb",
                  "content": "HAS_BODY",
                  "fontFamily": "Space Grotesk",
                  "fontSize": 18,
                  "fontWeight": "700"
                },
                {
                  "type": "text",
                  "id": "relHBDir",
                  "fill": "#9fb6c9",
