              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "relHHP1",
              "fill": "#d8e0eb",
              "content": "  order          int           Execution order within the head (1-indexed)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "relRefersTo",
          "name": "Relationship: REFERS_TO",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#9fb6c9"
          },
