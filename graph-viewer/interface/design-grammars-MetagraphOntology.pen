              "type": "text",
              "id": "clsDtPropP2",
              "fill": "#d8e0eb",
              "content": "  SWRL_label     string        SWRL predicate name, e.g. \"hasHeightM\"",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "clsDtPropP3",
              "fill": "#d8e0eb",
              "content": "  range          XsdDatatype   \"xsd:decimal\" | \"xsd:integer\" | \"xsd:boolean\" | \"xsd:string\"",
