            24
          ],
          "children": [
            {
              "type": "text",
              "id": "enumXsdNm",
              "fill": "#f4f7fb",
              "content": "XsdDatatype",
              "fontFamily": "Space Grotesk",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
