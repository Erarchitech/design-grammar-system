              "type": "text",
              "id": "relArgDesc",
              "fill": "#b8c2d0",
              "content": "Links an Atom to one of its arguments (variable or literal). An atom has 1..n arguments.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "relArgPH",
              "fill": "#5fd0ff",
              "content": "Edge Properties",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "relArgP1",
              "fill": "#d8e0eb",
              "content": "  pos            int           Argument position (1-indexed). pos=1 is typically the subject variable.",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "text",
          "id": "secEnum",
          "name": "Section: Enumerations",
          "fill": "#5fd0ff",
          "content": "3  Enumerations & Value Types",
          "fontFamily": "Space Grotesk",
          "fontSize": 22,
          "fontWeight": "700"
        },
        {
          "type": "frame",
          "id": "enumAtomType",
          "name": "Enum: AtomType",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#d3845f"
          },
          "layout": "vertical",
          "gap": 6,
          "padding": [
            16,
            24
          ],
          "children": [
            {
              "type": "text",
              "id": "enumATNm",
              "fill": "#f4f7fb",
              "content": "AtomType",
              "fontFamily": "Space Grotesk",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "enumATDesc",
              "fill": "#b8c2d0",
              "content": "Discriminator for the type of SWRL atom predicate.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumAT1",
              "fill": "#d8e0eb",
              "content": "  ClassAtom              Class membership test. 1 arg (the individual). REFERS_TO -> Class",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumAT2",
              "fill": "#d8e0eb",
              "content": "  DataPropertyAtom       Data property assertion. 2 args (subject, value). REFERS_TO -> DatatypeProperty",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumAT3",
              "fill": "#d8e0eb",
              "content": "  ObjectPropertyAtom     Object property assertion. 2 args (subject, object). REFERS_TO -> ObjectProperty",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumAT4",
              "fill": "#d8e0eb",
              "content": "  BuiltinAtom            SWRL built-in comparison. 2+ args. REFERS_TO -> Builtin",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "enumAtomSide",
          "name": "Enum: AtomSide",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#9fb6c9"
          },
          "layout": "vertical",
          "gap": 6,
          "padding": [
            16,
            24
          ],
          "children": [
            {
              "type": "text",
              "id": "enumASNm",
              "fill": "#f4f7fb",
              "content": "AtomSide",
              "fontFamily": "Space Grotesk",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "enumASDesc",
              "fill": "#b8c2d0",
              "content": "Which part of the SWRL implication an atom belongs to.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumAS1",
              "fill": "#d8e0eb",
              "content": "  Body = 0               Antecedent: conditions that must be satisfied",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumAS2",
              "fill": "#d8e0eb",
              "content": "  Head = 1               Consequent: conclusions derived when body is satisfied",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "enumArgKind",
          "name": "Enum: ArgKind",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#9fb6c9"
          },
          "layout": "vertical",
          "gap": 6,
          "padding": [
            16,
            24
          ],
          "children": [
            {
              "type": "text",
              "id": "enumAKNm",
              "fill": "#f4f7fb",
              "content": "ArgKind",
              "fontFamily": "Space Grotesk",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "enumAKDesc",
              "fill": "#b8c2d0",
              "content": "Discriminator for atom argument types.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumAK1",
              "fill": "#d8e0eb",
              "content": "  Variable = 0           A ?-prefixed SWRL variable bound at evaluation time",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumAK2",
              "fill": "#d8e0eb",
              "content": "  Literal  = 1           A constant value (number, boolean, or string)",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "enumRuleKind",
          "name": "Enum: RuleKind",
          "width": "fill_container",
          "fill": "#151926",
          "cornerRadius": 12,
          "stroke": {
            "align": "inside",
            "thickness": 1,
            "fill": "#9fb6c9"
          },
          "layout": "vertical",
          "gap": 6,
          "padding": [
