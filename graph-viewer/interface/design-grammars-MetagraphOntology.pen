            24
          ],
          "children": [
            {
              "type": "text",
              "id": "enumRKNm",
              "fill": "#f4f7fb",
              "content": "RuleKind",
              "fontFamily": "Space Grotesk",
              "fontSize": 18,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "enumRKDesc",
              "fill": "#b8c2d0",
              "content": "Semantic intent of the rule.",
              "fontFamily": "Inter",
              "fontSize": 13,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumRK1",
              "fill": "#d8e0eb",
              "content": "  violation               Rule defines a constraint that should NOT be violated",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            },
            {
              "type": "text",
              "id": "enumRK2",
              "fill": "#d8e0eb",
              "content": "  compliance              Rule defines a condition that SHOULD be satisfied",
              "fontFamily": "Courier New",
              "fontSize": 12,
              "fontWeight": "normal"
            }
          ]
        },
