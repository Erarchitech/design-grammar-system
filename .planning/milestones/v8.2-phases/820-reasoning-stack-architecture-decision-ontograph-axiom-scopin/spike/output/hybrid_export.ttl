<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_BUILDING_MAX_STOREY_9_V_A2> a swrl:DatavaluedPropertyAtom ;
    swrl:argument1 <http://example.org/design-grammar/project/v8-ui-smoke/var/b> ;
    swrl:argument2 <http://example.org/design-grammar/project/v8-ui-smoke/var/s> ;
