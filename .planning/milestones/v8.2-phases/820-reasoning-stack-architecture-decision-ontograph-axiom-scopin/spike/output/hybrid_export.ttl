dgm-spike:R_STREET_MIN_WIDTH_18_V_A1 a dgm-spike:ClassAtom,
        owl:NamedIndividual ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:atomId "R_STREET_MIN_WIDTH_18_V_A1" ;
    dgm-spike:atomIri "ex:Street" ;
    dgm-spike:atomSwrlLabel "Street" ;
    dgm-spike:atomType "ClassAtom" .

dgm-spike:R_STREET_MIN_WIDTH_18_V_A2 a dgm-spike:DataPropertyAtom,
        owl:NamedIndividual ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:atomId "R_STREET_MIN_WIDTH_18_V_A2" ;
    dgm-spike:atomIri "ex:hasWidthM" ;
    dgm-spike:atomSwrlLabel "hasWidthM" ;
    dgm-spike:atomType "DataPropertyAtom" .

dgm-spike:R_STREET_MIN_WIDTH_18_V_A3 a dgm-spike:BuiltinAtom,
        owl:NamedIndividual ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:atomId "R_STREET_MIN_WIDTH_18_V_A3" ;
    dgm-spike:atomIri "swrlb:lessThan" ;
    dgm-spike:atomSwrlLabel "lessThan" ;
    dgm-spike:atomType "BuiltinAtom" ;
    dgm-spike:refersTo dgm-spike:lessThan .

dgm-spike:R_STREET_MIN_WIDTH_18_V_H1 a dgm-spike:DataPropertyAtom,
