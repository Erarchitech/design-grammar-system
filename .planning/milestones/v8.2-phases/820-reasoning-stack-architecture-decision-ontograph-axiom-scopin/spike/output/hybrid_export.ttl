    dgm-spike:atomSwrlLabel "violatesMinWidth" ;
    dgm-spike:atomType "DataPropertyAtom" .

dgm-spike:R_UNIT_MIN_WINDOW_2_V a dgm-spike:Rule,
        owl:NamedIndividual ;
    rdfs:label "R_UNIT_MIN_WINDOW_2_V"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "Test Project" ;
    dgm-spike:SWRL "Unit(?u)^hasWindowCount(?u,?w)^swrlb:lessThan(?w,2)->violatesMinWindowCount(?u,true)" ;
    dgm-spike:ruleId "R_UNIT_MIN_WINDOW_2_V" ;
    dgm-spike:ruleKind "violation" .

dgm-spike:RuleDescription a owl:DatatypeProperty ;
    rdfs:label "RuleDescription"@en ;
    rdfs:comment "Natural-language description of a rule's intent — a longer explanation than RuleName's short title, distinct from SWRL's machine expression string. NEW in v7.0 (no V6 predecessor); matches the GH_DesignGrammars.pdf schema (DG.Layer.Metagraph.RuleDescription; Output=Rule().Description). Exposed by RULE DECONSTRUCT and VALIDATOR."@en ;
    rdfs:domain dgm-spike:Rule ;
    rdfs:range xsd:string .

dgm-spike:RuleName a owl:DatatypeProperty ;
    rdfs:label "RuleName"@en ;
    rdfs:comment "Optional human-readable title for a rule. v7.0 rename of the V6 rule-title property to match the GH_DesignGrammars.pdf schema (DG.Layer.Metagraph.RuleName)."@en ;
    rdfs:domain dgm-spike:Rule ;
    rdfs:range xsd:string .

dgm-spike:SWRL a owl:DatatypeProperty ;
    rdfs:label "SWRL"@en ;
    rdfs:comment "The SWRL expression string for a rule (e.g. Building(?b)^hasHeightM(?b,?h)^swrlb:greaterThan(?h,75)->violatesMaxHeight(?b,true)). v7.0 rename of the V6 rule-text property to match the GH_DesignGrammars.pdf schema (DG.Layer.Metagraph.SWRL)."@en ;
    rdfs:domain dgm-spike:Rule ;
    rdfs:range xsd:string .

dgm-spike:atomId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Atom_Id"@en ;
    rdfs:comment "Unique identifier for an atom. Body: {Rule_Id}_A{n}, Head: {Rule_Id}_H{n}. Characteristics: Functional."@en ;
    rdfs:domain dgm-spike:Atom ;
    rdfs:range xsd:string .

dgm-spike:atomIri a owl:DatatypeProperty ;
    rdfs:label "iri"@en ;
    rdfs:comment "IRI of the ontology entity referenced by this atom (e.g. ex:Building, swrlb:greaterThan)."@en ;
    rdfs:domain dgm-spike:Atom ;
    rdfs:range xsd:string .

dgm-spike:atomSwrlLabel a owl:DatatypeProperty ;
    rdfs:label "SWRL_label"@en ;
    rdfs:comment "Display label for the atom in SWRL notation."@en ;
    rdfs:domain dgm-spike:Atom ;
    rdfs:range xsd:string .

dgm-spike:atomType a owl:DatatypeProperty ;
    rdfs:label "type"@en ;
    rdfs:comment "Atom type discriminator: ClassAtom, DataPropertyAtom, ObjectPropertyAtom, BuiltinAtom."@en ;
    rdfs:domain dgm-spike:Atom ;
    rdfs:range xsd:string .

dgm-spike:builtinIri a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "iri"@en ;
    rdfs:comment "IRI of the SWRL builtin (e.g. swrlb:greaterThan). Characteristics: Functional."@en ;
    rdfs:domain dgm-spike:Builtin ;
    rdfs:range xsd:anyURI .

dgm-spike:builtinLabel a owl:DatatypeProperty ;
    rdfs:label "label"@en ;
    rdfs:comment "Display label for the builtin (e.g. greaterThan, lessThan)."@en ;
    rdfs:domain dgm-spike:Builtin ;
    rdfs:range xsd:string .

dgm-spike:equal a dgm-spike:Builtin,
        owl:NamedIndividual ;
    rdfs:label "equal"@en ;
    rdfs:comment "swrlb:equal — checks if two arguments are equal."@en .

dgm-spike:greaterThanOrEqual a dgm-spike:Builtin,
        owl:NamedIndividual ;
    rdfs:label "greaterThanOrEqual"@en ;
    rdfs:comment "swrlb:greaterThanOrEqual — checks if first arg is greater than or equal to second."@en .

dgm-spike:hasArg a owl:ObjectProperty ;
    rdfs:label "ARG"@en ;
    rdfs:comment "Connects an Atom to its arguments (Variable or Literal). Property: pos (integer, 1-indexed position). Characteristics: none (Atoms have multiple args; same Variable may appear in multiple Atoms). Range: union of {Variable, Literal}."@en ;
    rdfs:domain dgm-spike:Atom ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( dgm-spike:Variable dgm-spike:Literal ) ] .

dgm-spike:hasBody a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_BODY"@en ;
    rdfs:comment "Connects a Rule to its body (condition) atoms. The body checks the condition that breaks the rule in violation mode. Property: order (integer, 1-indexed). Characteristics: InverseFunctional — each Atom belongs to exactly one Rule's body. Disjoint with hasHead: no Atom may simultaneously be a body and head atom of the same Rule. Equivalent to swrl:body."@en ;
    rdfs:domain dgm-spike:Rule ;
    rdfs:range dgm-spike:Atom ;
    owl:propertyDisjointWith dgm-spike:hasHead .

dgm-spike:hasRule a owl:ObjectProperty ;
    rdfs:label "HAS_RULE"@en ;
    rdfs:comment "Connects a RuleSet to the Rules it contains. A RuleSet groups multiple Rules as a regulatory package."@en ;
    rdfs:domain dgm-spike:RuleSet ;
    rdfs:range dgm-spike:Rule ;
    rdfs:subPropertyOf dg:hasPart .

dgm-spike:inferredDatatype a owl:DatatypeProperty ;
    rdfs:label "inferredDatatype"@en ;
    rdfs:comment "XSD datatype inferred for this variable from SWRL atom context (e.g. xsd:decimal for a variable used in hasHeightM). Set by VariableTypeInferrer."@en ;
    rdfs:domain dgm-spike:Variable ;
    rdfs:range xsd:string .

dgm-spike:lessThanOrEqual a dgm-spike:Builtin,
        owl:NamedIndividual ;
    rdfs:label "lessThanOrEqual"@en ;
    rdfs:comment "swrlb:lessThanOrEqual — checks if first arg is less than or equal to second."@en .

dgm-spike:literalDatatype a owl:DatatypeProperty ;
    rdfs:label "datatype"@en ;
    rdfs:comment "XSD datatype of the literal (e.g. xsd:decimal, xsd:integer, xsd:boolean, xsd:string)."@en ;
    rdfs:domain dgm-spike:Literal ;
    rdfs:range xsd:string .

dgm-spike:literalLex a owl:DatatypeProperty ;
    rdfs:label "lex"@en ;
    rdfs:comment "Lexical form of the literal value (e.g. \"75\", \"true\", \"2.8\")."@en ;
    rdfs:domain dgm-spike:Literal ;
    rdfs:range xsd:string .

dgm-spike:literal_18 a dgm-spike:Literal,
        owl:NamedIndividual ;
    rdfs:label "18"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:literalDatatype "xsd:decimal" ;
    dgm-spike:literalLex "18" .

dgm-spike:literal_2 a dgm-spike:Literal,
        owl:NamedIndividual ;
    rdfs:label "2"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:literalDatatype "xsd:integer" ;
    dgm-spike:literalLex "2" .

dgm-spike:literal_80 a dgm-spike:Literal,
        owl:NamedIndividual ;
    rdfs:label "80"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:literalDatatype "xsd:decimal" ;
    dgm-spike:literalLex "80" .

dgm-spike:notEqual a dgm-spike:Builtin,
        owl:NamedIndividual ;
    rdfs:label "notEqual"@en ;
    rdfs:comment "swrlb:notEqual — checks if two arguments are not equal. Used for equality constraints (violation when value differs)."@en .

dgm-spike:order a owl:DatatypeProperty ;
    rdfs:label "order"@en ;
    rdfs:comment "Ordinal position of an atom within a rule's body or head (1-indexed). Stored on HAS_BODY and HAS_HEAD relationships."@en ;
    rdfs:range xsd:integer .

dgm-spike:pos a owl:DatatypeProperty ;
    rdfs:label "pos"@en ;
    rdfs:comment "Positional index of an argument within an atom (1-indexed). Stored on ARG relationships."@en ;
    rdfs:range xsd:integer .

dgm-spike:refersTo a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "REFERS_TO"@en ;
    rdfs:comment "Connects an Atom to the ontology entity it references (Class, DataProperty, ObjProperty, or Builtin). Each Atom has exactly one REFERS_TO. Characteristics: Functional. Range: union of {Class, DataProperty, ObjProperty, Builtin}."@en ;
    rdfs:domain dgm-spike:Atom ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( dg:Class dg:DataProperty dg:ObjProperty dgm-spike:Builtin ) ] .

dgm-spike:ruleId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "Rule_Id"@en ;
    rdfs:comment "Unique identifier for a rule. Format: R_<DOMAIN>_<PROPERTY>_<LIMIT>_V (e.g. R_URB_HEIGHT_MAX_75_V). Characteristics: Functional."@en ;
    rdfs:domain dgm-spike:Rule ;
    rdfs:range xsd:string .

dgm-spike:ruleKind a owl:DatatypeProperty ;
    rdfs:label "kind"@en ;
    rdfs:comment "Rule kind: 'violation' (body fires on constraint breach) or 'compliance' (body fires on constraint satisfaction)."@en ;
    rdfs:domain dgm-spike:Rule ;
    rdfs:range xsd:string .

dgm-spike:ruleSetName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Display name of a RuleSet (e.g. 'BuildingCode2024', 'ZoningRegulation'). Characteristics: Functional."@en ;
    rdfs:domain dgm-spike:RuleSet ;
    rdfs:range xsd:string .

dgm-spike:usesReasoner a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "USES_REASONER"@en ;
    rdfs:comment "Connects a RuleSet to the Reasoner used to evaluate its rules. Characteristics: Functional — a RuleSet uses exactly one Reasoner."@en ;
    rdfs:domain dgm-spike:RuleSet ;
    rdfs:range dgv:Reasoner .

dgm-spike:validates a owl:ObjectProperty ;
    rdfs:label "VALIDATES"@en ;
    rdfs:comment "Connects a Metagraph Rule to the Core DesignState (the ERD 'STATE') it validates. The Ontograph-defined classes and properties referenced by the rule's atoms are evaluated against the captured Design State."@en ;
    rdfs:domain dgm-spike:Rule ;
    rdfs:range dg:DesignState .

dgm-spike:var_s a dgm-spike:ObjectVariable,
        owl:NamedIndividual ;
    rdfs:label "?s"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:variableName "?s" ;
    rdfs:comment "Object variable representing a Street instance. Inferred from ClassAtom Street(?s). Cross-rule scoped (VTYP-02)."@en .

dgm-spike:var_u a dgm-spike:ObjectVariable,
        owl:NamedIndividual ;
    rdfs:label "?u"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:variableName "?u" ;
    rdfs:comment "Object variable representing a LivingUnit/Unit instance. Inferred from ClassAtom. Cross-rule scoped (VTYP-02)."@en .

dgm-spike:var_w a dgm-spike:PropertyVariable,
        owl:NamedIndividual ;
    rdfs:label "?w"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:variableName "?w" ;
    rdfs:comment "Property variable representing width/window count. Inferred from DataPropertyAtom arg-2. Rule-scoped (VTYP-03)."@en .

dgm-spike:variableName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Variable name prefixed with '?' (e.g. ?b, ?h, ?lu). Characteristics: Functional."@en ;
    rdfs:domain dgm-spike:Variable ;
    rdfs:range xsd:string .

