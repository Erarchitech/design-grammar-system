dgv:ValidStatus a owl:DatatypeProperty ;
    rdfs:label "ValidStatus"@en ;
    rdfs:comment "NEW in v7.0 (no V6 predecessor). Boolean LIST per Run, one element per ObjState in the validated DesignState, index-matched to the DesignState's ObjState order (D-06). Each element is that object's pass/fail against the rule. Overall pass = AND(ValidStatus), derived at read time, never stored as a separate field (D-07) — unifies the PDF's VALIDATOR-port ValidStatus(Boolean) and VALIDATION GRAPH-port Status(text) naming split into this one field. Not declared FunctionalProperty (multiple values per Run form the list). Population semantics (which ObjStates the list covers) are Phase 18 scope (VALIDATOR variable binding), not locked here. Matches the GH_DesignGrammars.pdf schema (DG.Layer.Validgraph.ValidStatus)."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range xsd:boolean .

dgv:baseModelId a owl:DatatypeProperty ;
    rdfs:label "baseModelId"@en ;
    rdfs:comment "ID of the base geometry model in the external platform. Stored on the IntegrationConfig node."@en ;
    rdfs:domain dgv:IntegrationConfig ;
    rdfs:range xsd:string .

dgv:baseModelName a owl:DatatypeProperty ;
    rdfs:label "baseModelName"@en ;
    rdfs:comment "Display name of the base geometry model in the external platform."@en ;
    rdfs:domain dgv:IntegrationConfig ;
    rdfs:range xsd:string .

dgv:baseVersionId a owl:DatatypeProperty ;
    rdfs:label "baseVersionId"@en ;
    rdfs:comment "Version ID of the base model (in the external platform) used in this validation run."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range xsd:string .

dgv:capturedAtUtc a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "capturedAtUtc"@en ;
    rdfs:comment "UTC timestamp when a design state or validation run was captured. Characteristics: Functional — one capture time per snapshot. Domain union: DesignState ∪ Run. Aligned with: prov:startedAtTime (R2) — semantically, the moment an activity started / a sample was captured."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( dg:DesignState dgv:Run ) ] ;
    rdfs:range xsd:dateTime .

dgv:designStateLabel a owl:DatatypeProperty ;
    rdfs:label "designStateLabel"@en ;
    rdfs:comment "Human-readable label assigned by the user in DESIGN STATE component. Surfaces as a tile header in the Model Viewer and as an output of DESIGN STATE DECONSTRUCT. NEW in v7.0 post-release (2026-07-08)."@en ;
    rdfs:domain dg:DesignState ;
    rdfs:range xsd:string .

dgv:dgEntityId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "dgEntityId"@en ;
    rdfs:comment "Unique DG identifier for a BIM entity in a validation run. Characteristics: Functional."@en ;
    rdfs:domain dgv:ValidationEntity ;
    rdfs:range xsd:string .

dgv:displayName a owl:DatatypeProperty ;
    rdfs:label "displayName"@en ;
    rdfs:comment "Human-readable name for a validation entity."@en ;
    rdfs:domain dgv:ValidationEntity ;
    rdfs:range xsd:string .

dgv:externalProjectId a owl:DatatypeProperty ;
    rdfs:label "externalProjectId"@en ;
    rdfs:comment "ID of the linked project in the external geometry/viewer platform. Stored on the IntegrationConfig node for the project."@en ;
    rdfs:domain dgv:IntegrationConfig ;
    rdfs:range xsd:string .

dgv:geoRefId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "geoRefId"@en ;
    rdfs:comment "Source-system handle for a geometry primitive (an external source-system object handle). The value wired into the GeoRef input of OBJECT STATE per CTRCT-09. Characteristics: Functional."@en ;
    rdfs:domain dgv:GeoRef ;
    rdfs:range xsd:string .

dgv:hasEntity a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_ENTITY"@en ;
    rdfs:comment "Connects a Run to its evaluated ValidationEntity results. Characteristics: InverseFunctional — each ValidationEntity belongs to exactly one Run. Aligned with: prov:generated (R2) — a ValidationEntity is generated by the run."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range dgv:ValidationEntity .

dgv:hasGeoRef a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_GEO_REF"@en ;
    rdfs:comment "Connects an ObjState to its geometry handles wired into the GeoRef input of OBJECT STATE (CTRCT-09). One ObjState may have many GeoRefs (the geometry elements composing the ObjectInstance). Characteristics: InverseFunctional — each GeoRef belongs to exactly one ObjState. Aligned with: geo:hasGeometry (R6) — the GeoSPARQL pattern for object↔geometry linking."@en ;
    rdfs:domain dg:ObjState ;
    rdfs:range dgv:GeoRef .

dgv:hasObjState a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_OBJECT_STATE"@en ;
    rdfs:comment "Connects an ObjectInstance to its current ObjState (the geometry + variable binding snapshot). Characteristics: Functional + InverseFunctional — strict 1:1 cardinality per CMPST-06. Inverse of representsInstance."@en ;
    rdfs:domain dgv:ObjectInstance ;
    rdfs:range dg:ObjState ;
    owl:inverseOf dgv:representsInstance .

dgv:hasObjectVariable a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_OBJECT_VARIABLE"@en ;
    rdfs:comment "Connects an ObjState to the SWRL Object Variable wired into the ObjectRef input of OBJECT STATE (CTRCT-08). The ObjectVariable is cross-rule (VTYP-02) — same variable name identifies the same ObjectInstance across all rules in a project. Characteristics: Functional — one canonical variable per ObjState."@en ;
    rdfs:domain dg:ObjState ;
    rdfs:range dgm-spike:ObjectVariable .

dgv:hasParameter a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_PARAMETER"@en ;
    rdfs:comment "Connects a DesignState snapshot to its individual parameters. Characteristics: InverseFunctional — each DesignStateParameter belongs to exactly one DesignState."@en ;
    rdfs:domain dg:DesignState ;
    rdfs:range dgv:DesignStateParameter .

dgv:idRefValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "idRefValue"@en ;
    rdfs:comment "The auto-regenerated identifier string produced by DESIGN STATE (CMPST-03, CMPST-05). Changes whenever ParamState changes. Note: IdRef is the DesignState's ID, NOT ObjState's ID — ObjState carries its own stateId (OS_ prefix). Characteristics: Functional."@en ;
    rdfs:domain dgv:IdRef ;
    rdfs:range xsd:string .

dgv:instanceId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "instanceId"@en ;
    rdfs:comment "Stable cross-rule identifier of an ObjectInstance. Format: OI_<hash>. Persists across geometry edits (CMPST-06). Characteristics: Functional."@en ;
    rdfs:domain dgv:ObjectInstance ;
    rdfs:range xsd:string .

dgv:modelViewerUrl a owl:DatatypeProperty ;
    rdfs:label "modelViewerUrl"@en ;
    rdfs:comment "URL to view the validation results in the Model Viewer."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range xsd:string .

dgv:objectRefName a owl:DatatypeProperty ;
    rdfs:label "objectRef"@en ;
    rdfs:comment "Object variable reference string for an ObjState (e.g. the variable name from a ClassAtom). Links this ObjState to the SWRL Object variable it represents."@en ;
    rdfs:domain dg:ObjState ;
    rdfs:range xsd:string .

dgv:parameterId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "parameterId"@en ;
    rdfs:comment "Identifier of a design state parameter (maps to a DatatypeProperty iri in the Ontograph). Characteristics: Functional."@en ;
    rdfs:domain dgv:DesignStateParameter ;
    rdfs:range xsd:string .

dgv:parameterType a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "parameterType"@en ;
    rdfs:comment "Type discriminator for parameter value (enum-valued): ParameterType_Number, ParameterType_Integer, or ParameterType_Boolean. Characteristics: Functional."@en ;
    rdfs:domain dgv:DesignStateParameter ;
    rdfs:range dgv:DesignStateParameterTypeValue .

dgv:propValue a owl:DatatypeProperty ;
    rdfs:label "propValue"@en ;
    rdfs:comment "The validated property value for this ValidationEntity (SCHM-05). One value per (Run, Rule, ObjectInstance) cell — the \"main attribute\" the rule checked. Shown in the Model Viewer's passing/failing item list per rule. Lex form (xsd:string) for display; actual typed value lives on the DesignStateParameter. Aligned with: sosa:hasSimpleResult (R3) — the validated value IS the observation's simple result."@en ;
    rdfs:domain dgv:ValidationEntity ;
    rdfs:range xsd:string .

dgv:propValueOf a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "PROP_VALUE_OF"@en ;
    rdfs:comment "Connects a ValidationEntity to the PropertyVariable whose value the rule checked (SCHM-05). The \"main attribute being validated\" — determines which property's value is shown in the Model Viewer's passing/failing list. Characteristics: Functional — one main property per ValidationEntity cell. Aligned with: sosa:observedProperty (R3, equivalent) and sh:resultPath (R4, subProperty)."@en ;
    rdfs:domain dgv:ValidationEntity ;
    rdfs:range dgm-spike:PropertyVariable .

dgv:provider a owl:DatatypeProperty ;
    rdfs:label "provider"@en ;
    rdfs:comment "Integration provider name identifying the external geometry/viewer platform."@en ;
    rdfs:domain dgv:IntegrationConfig ;
    rdfs:range xsd:string .

dgv:reasonerName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Display name of a Reasoner (e.g. 'SWRLForwardChainer', 'GrasshopperSolver'). Characteristics: Functional."@en ;
    rdfs:domain dgv:Reasoner ;
    rdfs:range xsd:string .

dgv:refersToGeometry a owl:ObjectProperty ;
    rdfs:label "REFERS_TO_GEOMETRY"@en ;
    rdfs:comment "Connects a GeoRef to the Core Geometry it points at. Completes the ERD chain ObjState -hasGeoRef-> GeoRef -refersToGeometry-> Geometry, i.e. Geometry is linked to ObjState through the GeoRef handle. Geometry is part of Structure (Structure -hasGeometry-> Geometry)."@en ;
    rdfs:domain dgv:GeoRef ;
    rdfs:range dg:Geometry .

dgv:resolvesTo a owl:ObjectProperty ;
    rdfs:label "RESOLVES_TO"@en ;
    rdfs:comment "Connects an IdRef to the ObjectInstance(s) it tracks across runs (INTG-03). Characteristics: none — an IdRef may resolve to many ObjectInstances (the run's full object set), and an ObjectInstance is referenced by many IdRefs over time (one per ParamState configuration)."@en ;
    rdfs:domain dgv:IdRef ;
    rdfs:range dgv:ObjectInstance .

dgv:ruleId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "ruleId"@en ;
    rdfs:comment "Rule ID associated with a validation entity result. Characteristics: Functional — each ValidationEntity references exactly one rule."@en ;
    rdfs:domain dgv:ValidationEntity ;
    rdfs:range xsd:string .

dgv:rulesJson a owl:DatatypeProperty ;
    rdfs:label "rulesJson"@en ;
    rdfs:comment "JSON-serialized array of rules evaluated in this run."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range xsd:string .

dgv:runId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "runId"@en ;
    rdfs:comment "Unique identifier for a validation run. Characteristics: Functional."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range xsd:string .

dgv:stateId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "stateId"@en ;
    rdfs:comment "Unique identifier for a DesignState snapshot. Characteristics: Functional."@en ;
    rdfs:domain dg:DesignState ;
    rdfs:range xsd:string .

dgv:statePayloadJson a owl:DatatypeProperty ;
    rdfs:label "statePayloadJson"@en ;
    rdfs:comment "JSON-serialized DesignState snapshot used as input to this run."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range xsd:string .

dgv:status a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "status"@en ;
    rdfs:comment "Status of a validation run (Status_Completed) or entity result (Status_Passed / Status_Failed). Domain union: Run ∪ ValidationEntity. Characteristics: Functional."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( dgv:Run dgv:ValidationEntity ) ] ;
    rdfs:range dgv:ValidationStatusValue .

dgv:validatesInstance a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "VALIDATES_INSTANCE"@en ;
    rdfs:comment "Connects a ValidationEntity result cell to the ObjectInstance it describes. Characteristics: Functional — each ValidationEntity describes exactly one ObjectInstance. Inverse direction is NOT functional: an ObjectInstance has many ValidationEntities (one per rule per run). Aligned with: sosa:hasFeatureOfInterest (R3, equivalent) and sh:focusNode (R4, subProperty). The SOSA mapping is the stronger semantic match; SHACL is a sibling subPropertyOf to avoid asserting transitive equivalence between sosa:hasFeatureOfInterest and sh:focusNode."@en ;
    rdfs:domain dgv:ValidationEntity ;
    rdfs:range dgv:ObjectInstance .

dgv:validationModelId a owl:DatatypeProperty ;
    rdfs:label "validationModelId"@en ;
    rdfs:comment "ID of the validation overlay model in the external platform. Stored on the IntegrationConfig node."@en ;
    rdfs:domain dgv:IntegrationConfig ;
    rdfs:range xsd:string .

dgv:validationVersionId a owl:DatatypeProperty ;
    rdfs:label "validationVersionId"@en ;
    rdfs:comment "Version ID of the validation overlay (in the external platform) created by this run."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range xsd:string .

dg:Behavior_Frame a dg:Behavior,
        owl:NamedIndividual ;
    rdfs:label "Frame Behavior"@en ;
    dg:graph dgc:Computgraph ;
    dgc:hasAlgorithm dgc:Algorithm_1 .

dg:OS_b1_var_b a dg:ObjState,
        owl:NamedIndividual ;
    rdfs:label "ObjState: OI_Building_b1 ↔ ?b"@en ;
    dg:graph dgv:Validgraph ;
    dg:project "TestA" ;
    dgv:hasGeoRef dgv:GR_geom_1,
        dgv:GR_geom_2 ;
    dgv:hasObjectVariable dgm-spike:var_b ;
    dgv:objectRefName "obj-9f3e2a" ;
    dgv:representsInstance dgv:OI_Building_b1 ;
    dgv:stateId "OS_a1b2c3d4" ;
    rdfs:comment "Binding snapshot pairing OI_Building_b1 with Object variable ?b (var_b) and its current GeoRef set. State_Id computed as OS_<SHA256(projectId + objectInstanceId + variableName)> per CMPST-07."@en .

dg:Structure_Frame a dg:Structure,
        owl:NamedIndividual ;
    rdfs:label "Frame Structure"@en ;
    dg:graph dgc:Computgraph .

dgc:Algorithm_1 a dgc:Algorithm,
        owl:NamedIndividual ;
    rdfs:label "1_Algorithm"@en ;
    dg:graph dgc:Computgraph ;
    dgc:algorithmName "1_Algorithm" ;
    dgc:hasProcedure dgc:Proc_11,
        dgc:Proc_12 .

dgc:Const_11_TrussConfig a dgc:ConstantParam,
        owl:NamedIndividual ;
    rdfs:label "11_Const_TrussConfig"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Integer ;
    dgc:parameterDisplayName "Truss web configuration" ;
    dgc:parameterName "11_Const_TrussConfig" .

dgc:Const_11_ptZero a dgc:ConstantParam,
        owl:NamedIndividual ;
    rdfs:label "11_Const_ptZero"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Geometry ;
    dgc:parameterDisplayName "Origin point" ;
    dgc:parameterName "11_Const_ptZero" .

dgc:Const_12_IndList_1 a dgc:ConstantParam,
        owl:NamedIndividual ;
    rdfs:label "12_Const_IndList_1"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Integer ;
    dgc:parameterDisplayName "Index list 1" ;
    dgc:parameterName "12_Const_IndList_1" .

dgc:IntF_11_MergeRes a dgc:Output,
        owl:NamedIndividual ;
    rdfs:label "11_IntF_MergeRes"@en ;
    dg:graph dgc:Computgraph ;
    dgc:interfaceName "11_IntF_MergeRes" .

dgc:IntF_11_ParSplitAt a dgc:Output,
        owl:NamedIndividual ;
    rdfs:label "11_IntF_ParSplitAt"@en ;
    dg:graph dgc:Computgraph ;
    dgc:interfaceName "11_IntF_ParSplitAt" .

dgc:IntF_11_TrussConfig a dgc:Output,
        owl:NamedIndividual ;
    rdfs:label "11_IntF_TrussConfig"@en ;
    dg:graph dgc:Computgraph ;
    dgc:interfaceName "11_IntF_TrussConfig" .

dgc:IntF_12_FooterFrame a dgc:Output,
        owl:NamedIndividual ;
    rdfs:label "12_IntF_FooterFrame"@en ;
    dg:graph dgc:Computgraph ;
    dgc:interfaceName "12_IntF_FooterFrame" .

dgc:ListStructure_Flatten a dgc:ListStructureValue,
        owl:NamedIndividual ;
    rdfs:label "Flatten"@en .

dgc:ListStructure_Graft a dgc:ListStructureValue,
        owl:NamedIndividual ;
    rdfs:label "Graft"@en .

dgc:ListStructure_Reverse a dgc:ListStructureValue,
        owl:NamedIndividual ;
    rdfs:label "Reverse"@en .

dgc:ListStructure_Simplify a dgc:ListStructureValue,
        owl:NamedIndividual ;
    rdfs:label "Simplify"@en .

dgc:ParamDataType_Boolean a dgc:ParamDataTypeValue,
        owl:NamedIndividual ;
    rdfs:label "Boolean"@en .

dgc:ParamDataType_Text a dgc:ParamDataTypeValue,
        owl:NamedIndividual ;
    rdfs:label "Text"@en .

dgc:Pat_11_DivideLine a dgc:Pattern,
        owl:NamedIndividual ;
    rdfs:label "11_Pat_DivideLine"@en ;
    dg:graph dgc:Computgraph ;
    dgc:hasParameter dgc:Const_11_ptZero,
        dgc:Var_11_SpansCount ;
    dgc:patternName "11_Pat_DivideLine" .

dgc:Pat_11_TopChord a dgc:Pattern,
        owl:NamedIndividual ;
    rdfs:label "11_Pat_TopChord"@en ;
    dg:graph dgc:Computgraph ;
    dgc:hasParameter dgc:Const_11_TrussConfig,
        dgc:Var_11_HTotal ;
    dgc:patternName "11_Pat_TopChord" .

dgc:Pat_12_FooterBottomLines a dgc:Pattern,
        owl:NamedIndividual ;
    rdfs:label "12_Pat_1 - Create footer bottom lines"@en ;
    dg:graph dgc:Computgraph ;
    dgc:hasParameter dgc:Const_12_IndList_1,
        dgc:Var_12_HFooter ;
    dgc:patternName "12_Pat_1 - Create footer bottom lines" .

dgc:Proc_11 a dgc:Procedure,
        owl:NamedIndividual ;
    rdfs:label "11_Proc - 2D Truss Configuration"@en ;
    dg:graph dgc:Computgraph ;
    dgc:hasInterface dgc:IntF_11_MergeRes,
        dgc:IntF_11_ParSplitAt,
        dgc:IntF_11_TrussConfig ;
    dgc:hasPattern dgc:Pat_11_DivideLine,
        dgc:Pat_11_TopChord ;
    dgc:procedureName "11_Proc - 2D Truss Configuration" ;
    dgc:procedureOrder 11 .

dgc:Proc_12 a dgc:Procedure,
        owl:NamedIndividual ;
    rdfs:label "12_Proc - 2D Footer Configuration"@en ;
    dg:graph dgc:Computgraph ;
    dgc:hasInterface dgc:IntF_12_FooterFrame ;
    dgc:hasPattern dgc:Pat_12_FooterBottomLines ;
    dgc:procedureName "12_Proc - 2D Footer Configuration" ;
    dgc:procedureOrder 12 .

dgc:Var_11_HTotal a dgc:VariableParam,
        owl:NamedIndividual ;
    rdfs:label "11_Var_HTotal"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Float ;
    dgc:parameterDisplayName "Total height" ;
    dgc:parameterName "11_Var_HTotal" .

dgc:Var_11_SpansCount a dgc:VariableParam,
        owl:NamedIndividual ;
    rdfs:label "11_Var_SpansCount"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Integer ;
    dgc:parameterDisplayName "Count of spans" ;
    dgc:parameterName "11_Var_SpansCount" .

dgc:Var_12_HFooter a dgc:VariableParam,
        owl:NamedIndividual ;
    rdfs:label "12_Var_HFooter"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Float ;
    dgc:parameterDisplayName "Footer height" ;
    dgc:parameterName "12_Var_HFooter" .

ex:Block a owl:Class ;
    rdfs:label "Block" .

ex:Door a owl:Class ;
    rdfs:label "Door" ;
    owl:disjointWith ex:Window .

ex:Facade a owl:Class ;
    rdfs:label "Facade" .

ex:LivingUnit a owl:Class ;
    rdfs:label "LivingUnit" .

ex:hasAreaM2 a owl:DatatypeProperty ;
    rdfs:label "hasAreaM2" ;
    rdfs:range xsd:decimal .

ex:hasDistanceM a owl:DatatypeProperty ;
    rdfs:label "hasDistanceM" ;
    rdfs:range xsd:decimal .

ex:hasFootprintM2 a owl:DatatypeProperty ;
    rdfs:label "hasFootprintM2" ;
    rdfs:range xsd:decimal .

ex:hasGridType a owl:DatatypeProperty ;
    rdfs:label "hasGridType" ;
    rdfs:range xsd:string .

ex:hasStoreyCount a owl:DatatypeProperty ;
    rdfs:label "hasStoreyCount" ;
    rdfs:range xsd:integer .

ex:violatesGridType a owl:DatatypeProperty ;
    rdfs:label "violatesGridType" ;
    rdfs:range xsd:boolean .

ex:violatesMaxStoreyCount a owl:DatatypeProperty ;
    rdfs:label "violatesMaxStoreyCount" ;
    rdfs:range xsd:boolean .

ex:violatesMinArea a owl:DatatypeProperty ;
    rdfs:label "violatesMinArea" ;
    rdfs:range xsd:boolean .

ex:violatesMinDistance a owl:DatatypeProperty ;
    rdfs:label "violatesMinDistance" ;
    rdfs:range xsd:boolean .

ex:violatesMinFootprintPct a owl:DatatypeProperty ;
    rdfs:label "violatesMinFootprintPct" ;
    rdfs:range xsd:boolean .

dgm-spike:ObjectPropertyAtom a owl:Class ;
    rdfs:label "ObjectPropertyAtom"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "An atom asserting an object property relationship (e.g. locatedIn(?b, ?block)). Takes two variable arguments."@en ;
    rdfs:subClassOf dgm-spike:Atom .

dgm-spike:R_BUILDING_MAX_HEIGHT_75_V_A1 a dgm-spike:ClassAtom,
        owl:NamedIndividual ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dgm-spike:atomId "R_BUILDING_MAX_HEIGHT_75_V_A1" ;
    dgm-spike:atomIri "ex:Building" ;
    dgm-spike:atomSwrlLabel "Building" ;
    dgm-spike:atomType "ClassAtom" ;
    dgm-spike:hasArg dgm-spike:var_b .

dgm-spike:R_BUILDING_MAX_HEIGHT_75_V_A2 a dgm-spike:DataPropertyAtom,
        owl:NamedIndividual ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dgm-spike:atomId "R_BUILDING_MAX_HEIGHT_75_V_A2" ;
    dgm-spike:atomIri "ex:hasHeightM" ;
    dgm-spike:atomSwrlLabel "hasHeightM" ;
    dgm-spike:atomType "DataPropertyAtom" ;
    dgm-spike:hasArg dgm-spike:var_b,
        dgm-spike:var_h .

dgm-spike:R_BUILDING_MAX_HEIGHT_75_V_A3 a dgm-spike:BuiltinAtom,
        owl:NamedIndividual ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dgm-spike:atomId "R_BUILDING_MAX_HEIGHT_75_V_A3" ;
    dgm-spike:atomIri "swrlb:greaterThan" ;
    dgm-spike:atomSwrlLabel "greaterThan" ;
    dgm-spike:atomType "BuiltinAtom" ;
    dgm-spike:hasArg dgm-spike:literal_75,
        dgm-spike:var_h ;
    dgm-spike:refersTo dgm-spike:greaterThan .

dgm-spike:R_BUILDING_MAX_HEIGHT_75_V_H1 a dgm-spike:DataPropertyAtom,
        owl:NamedIndividual ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dgm-spike:atomId "R_BUILDING_MAX_HEIGHT_75_V_H1" ;
    dgm-spike:atomIri "ex:violatesMaxHeight" ;
    dgm-spike:atomSwrlLabel "violatesMaxHeight" ;
    dgm-spike:atomType "DataPropertyAtom" ;
    dgm-spike:hasArg dgm-spike:literal_true,
        dgm-spike:var_b .

dgm-spike:greaterThan a dgm-spike:Builtin,
        owl:NamedIndividual ;
    rdfs:label "greaterThan"@en ;
    rdfs:comment "swrlb:greaterThan — checks if first arg is strictly greater than second. Used for maximum constraints (violation when value exceeds limit)."@en .

dgm-spike:hasHead a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_HEAD"@en ;
    rdfs:comment "Connects a Rule to its head (conclusion) atoms. The head sets the violation flag to true when the body fires. Property: order (integer, 1-indexed). Characteristics: InverseFunctional — each Atom belongs to exactly one Rule's head. Disjoint with hasBody (declared on hasBody side). Equivalent to swrl:head."@en ;
    rdfs:domain dgm-spike:Rule ;
    rdfs:range dgm-spike:Atom .

dgm-spike:lessThan a dgm-spike:Builtin,
        owl:NamedIndividual ;
    rdfs:label "lessThan"@en ;
    rdfs:comment "swrlb:lessThan — checks if first arg is strictly less than second. Used for minimum constraints (violation when value below limit)."@en .

dgm-spike:literal_75 a dgm-spike:Literal,
        owl:NamedIndividual ;
    rdfs:label "75"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dgm-spike:literalDatatype "xsd:decimal" ;
    dgm-spike:literalLex "75" .

dgm-spike:literal_true a dgm-spike:Literal,
        owl:NamedIndividual ;
    rdfs:label "true"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:literalDatatype "xsd:boolean" ;
    dgm-spike:literalLex "true" .

<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_BLOCK_MIN_FOOTPRINT_PCT_18_V_A1> a swrl:ClassAtom ;
    swrl:argument1 <http://example.org/design-grammar/project/v8-ui-smoke/var/b> ;
    swrl:classPredicate ex:Block .

<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_BLOCK_MIN_FOOTPRINT_PCT_18_V_A2> a swrl:DatavaluedPropertyAtom ;
    swrl:argument1 <http://example.org/design-grammar/project/v8-ui-smoke/var/b> ;
    swrl:argument2 <http://example.org/design-grammar/project/v8-ui-smoke/var/f> ;
