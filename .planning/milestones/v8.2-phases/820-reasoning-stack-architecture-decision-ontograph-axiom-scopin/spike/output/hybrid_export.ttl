    swrl:arguments ( <http://example.org/design-grammar/project/v8-ui-smoke/var/f> 0.18 ) ;
    swrl:builtin swrlb:greaterThan .

<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_BLOCK_MIN_FOOTPRINT_PCT_18_V_H1> a swrl:DatavaluedPropertyAtom ;
    swrl:argument1 <http://example.org/design-grammar/project/v8-ui-smoke/var/b> ;
