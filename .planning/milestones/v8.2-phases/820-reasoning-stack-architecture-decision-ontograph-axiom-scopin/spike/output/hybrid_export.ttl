dgv:GR_geom_2 a dgv:GeoRef,
        owl:NamedIndividual ;
    rdfs:label "GeoRef: obj:xyz2"@en ;
    dg:graph dgv:Validgraph ;
    dg:project "TestA" ;
    dgv:geoRefId "obj:xyz2" ;
    rdfs:comment "External source-system object handle for the roof geometry of Building #1."@en .

dgv:IDR_DS_def_h25_w12 a dgv:IdRef,
        owl:NamedIndividual ;
    rdfs:label "IdRef for DS_def_h25_w12"@en ;
    dg:graph dgv:Validgraph ;
    dg:project "TestA" ;
    dgv:idRefValue "IDR_a1b2c3d4e5f6" ;
    dgv:resolvesTo dgv:OI_Building_b1 ;
    rdfs:comment "Auto-generated identifier for ParamState DS_def_h25_w12 (CMPST-08). Resolves to OI_Building_b1 for cross-run tracking (INTG-03). Will regenerate if any slider value in the ParamState changes."@en .

dgv:ParameterType_Boolean a dgv:DesignStateParameterTypeValue,
        owl:NamedIndividual ;
    rdfs:label "Boolean"@en ;
    rdfs:comment "Boolean parameter value. From Boolean Toggles in Grasshopper."@en .

dgv:ParameterType_Integer a dgv:DesignStateParameterTypeValue,
        owl:NamedIndividual ;
    rdfs:label "Integer"@en ;
    rdfs:comment "Integer parameter value (long). From Integer Sliders in Grasshopper."@en .

dgv:ParameterType_Number a dgv:DesignStateParameterTypeValue,
        owl:NamedIndividual ;
    rdfs:label "Number"@en ;
    rdfs:comment "Floating-point parameter value (double). From Number Sliders in Grasshopper."@en .

dgv:ReStatus_AmbiguousTarget a dgv:ReStatusValue,
        owl:NamedIndividual ;
    rdfs:label "AmbiguousTarget"@en ;
    rdfs:comment "Multiple matching sliders/toggles found — cannot determine which to reinstate."@en .

dgv:ReStatus_Applied a dgv:ReStatusValue,
        owl:NamedIndividual ;
    rdfs:label "Applied"@en ;
    rdfs:comment "Parameter value was successfully applied to the target slider/toggle."@en .

dgv:ReStatus_MissingTarget a dgv:ReStatusValue,
        owl:NamedIndividual ;
    rdfs:label "MissingTarget"@en ;
    rdfs:comment "No matching slider/toggle found on the canvas for this parameter."@en .

dgv:ReStatus_OutOfRange a dgv:ReStatusValue,
        owl:NamedIndividual ;
    rdfs:label "OutOfRange"@en ;
    rdfs:comment "Parameter value exceeds the target slider's min/max range."@en .

dgv:ReStatus_TypeMismatch a dgv:ReStatusValue,
        owl:NamedIndividual ;
    rdfs:label "TypeMismatch"@en ;
    rdfs:comment "Target slider type does not match parameter type (e.g. Number param wired to Integer slider)."@en .

dgv:ReStatus_Unchanged a dgv:ReStatusValue,
        owl:NamedIndividual ;
    rdfs:label "Unchanged"@en ;
    rdfs:comment "Target slider already has the requested value — no change needed."@en .

dgv:ReStatus_WouldApply a dgv:ReStatusValue,
        owl:NamedIndividual ;
    rdfs:label "WouldApply"@en ;
    rdfs:comment "Dry-run mode — parameter would be applied if reinstatement were executed."@en .

dgv:VEntity_a5671cb1bd30_b1_height a dgv:ValidationEntity,
        owl:NamedIndividual ;
    rdfs:label "Entity: Building #1 height check (passed)"@en ;
    dg:graph dgv:Validgraph ;
    dg:project "TestA" ;
    dgv:dgEntityId "VE_a5671cb1bd30_b1_height" ;
    dgv:displayName "Building #1" ;
    dgv:propValue "25" ;
    dgv:propValueOf dgm-spike:var_h ;
    dgv:ruleId "R_BUILDING_MAX_HEIGHT_75_V" ;
    dgv:status dgv:Status_Passed ;
    dgv:validatesInstance dgv:OI_Building_b1 ;
    rdfs:comment "Per-rule, per-instance validation result cell. Records that Building #1 passed R_BUILDING_MAX_HEIGHT_75_V with a measured height value of 25 (the propValue — SCHM-05). Belongs to run a5671cb1bd30."@en .

dgv:VEntity_a5671cb1bd30_b1_overflow a dgv:ValidationEntity,
        owl:NamedIndividual ;
    rdfs:label "Entity: Building #1 height check (failed example)"@en ;
    dg:graph dgv:Validgraph ;
    dg:project "TestA" ;
    dgv:dgEntityId "VE_a5671cb1bd30_b1_overflow" ;
    dgv:displayName "Building #1" ;
    dgv:propValue "80" ;
    dgv:propValueOf dgm-spike:var_h ;
    dgv:ruleId "R_BUILDING_MAX_HEIGHT_75_V" ;
    dgv:status dgv:Status_Failed ;
    dgv:validatesInstance dgv:OI_Building_b1 ;
    rdfs:comment "Illustrative failing case: same ObjectInstance, different parametric run, height exceeded the 75m limit (value 80). Shows that ObjectInstance can be referenced by multiple ValidationEntities — one per (Run × Rule)."@en .

dgv:hasIdRef a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_ID_REF"@en ;
    rdfs:comment "Connects a ParamState to its auto-generated IdRef. Characteristics: Functional + InverseFunctional — IdRef IS the ParamState-generated DesignState ID, so strict 1:1 cardinality (CMPST-08). Domain restricted to ParamState (NOT all DesignState): per CMPST-05, only ParamState triggers IdRef regeneration. ObjState carries its own stateId (OS_ prefix) and never has an IdRef — see the ObjState SubClassOf (hasIdRef max 0) restriction below."@en ;
    rdfs:domain dg:ParamState ;
    rdfs:range dgv:IdRef .

dgv:representsInstance a owl:FunctionalProperty,
        owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "REPRESENTS_INSTANCE"@en ;
    rdfs:comment "Connects an ObjState back to the ObjectInstance it captures. Characteristics: Functional + InverseFunctional — strict 1:1 cardinality. Inverse of hasObjState."@en ;
    rdfs:domain dg:ObjState ;
    rdfs:range dgv:ObjectInstance .

swrlb:equalTo a swrl:Builtin .

swrlb:greaterThan a swrl:Builtin .

dg:PropState a owl:Class ;
    rdfs:label "PropState"@en ;
    rdfs:comment "Property state — the third DesignState kind (v7.0), composing a Rule's DataProperty result and its validated PropValue for a specific ObjectInstance. Built on the existing dgv:propValue / dgv:propValueOf datatype/object properties, which already attach per-instance validation-result values to ValidationEntity — PropState generalises that per-cell value into a first-class DesignState kind alongside ObjState and ParamState (ONTO-03, GHST-03). ID prefix: PS_."@en ;
    rdfs:subClassOf dg:DesignState .

dg:Topology a owl:Class ;
    rdfs:label "Topology"@en ;
    rdfs:comment "Spatial topology of geometric structure — decomposition via Topologic library (Cluster, CellComplex, Cell, Shell, Face, Wire, Edge, Vertex). Used for spatial analysis of design output. Alignment with external Topologic vocabulary defined in DesignGrammar-Topologic-extension.owl."@en ;
    rdfs:subClassOf dg:Core .

dgc:Input a owl:Class ;
    rdfs:label "Input"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "An input port on an Interface — receives data into a Procedure or Pattern."@en ;
    rdfs:subClassOf dgc:Interface .

ex:Building a owl:Class ;
    rdfs:label "Building" .

ex:Window a owl:Class .

dgm-spike:BuiltinVariable a owl:Class ;
    rdfs:label "BuiltinVariable"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "A variable bound only inside BuiltinAtom arguments (e.g. an arithmetic intermediate). Not surfaced on the Grasshopper canvas — the VariableTypeInferrer recognizes this category to keep RULE DECONSTRUCT outputs clean (VTYP-01 priority chain step 3)."@en ;
    rdfs:subClassOf dgm-spike:Variable .

dgm-spike:VariableScope_CrossRule a dgm-spike:VariableScopeValue,
        owl:NamedIndividual ;
    rdfs:label "cross-rule"@en ;
    rdfs:comment "Shared identity across all rules in a project. Applies to Object variables (VTYP-02)."@en .

dgm-spike:VariableScope_RuleLocal a dgm-spike:VariableScopeValue,
        owl:NamedIndividual ;
    rdfs:label "rule-scoped"@en ;
    rdfs:comment "Independent variable per rule. Applies to Property variables (VTYP-03)."@en .

dgm-spike:variableScope a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "variableScope"@en ;
    rdfs:comment "Scoping semantics (enum-valued): VariableScope_CrossRule for Object variables (shared identity across rules in a project, VTYP-02) or VariableScope_RuleLocal for Property variables (independent per rule, VTYP-03). Derived from variableKind. Characteristics: Functional."@en ;
    rdfs:domain dgm-spike:Variable ;
    rdfs:range dgm-spike:VariableScopeValue .

<http://example.org/design-grammar/project/v8-ui-smoke/var/a> a swrl:Variable .

<http://example.org/design-grammar/project/v8-ui-smoke/var/d> a swrl:Variable .

<http://example.org/design-grammar/project/v8-ui-smoke/var/g> a swrl:Variable .

<http://example.org/design-grammar/project/v8-ui-smoke/var/s> a swrl:Variable .

dgs:Tag_guimaraes a dgs:SpecTag,
        owl:NamedIndividual ;
    dg:graph dgs:SpecGraph ;
    dg:project "TestA" ;
    dgs:tagName "guimaraes" .

dgs:Tag_portugal a dgs:SpecTag,
        owl:NamedIndividual ;
    dg:graph dgs:SpecGraph ;
    dg:project "TestA" ;
    dgs:tagName "portugal" .

dgv:Status_Failed a dgv:ValidationStatusValue,
        owl:NamedIndividual ;
    rdfs:label "failed"@en ;
    rdfs:comment "Validation entity failed one or more rules — violations detected."@en .

dgv:Status_Passed a dgv:ValidationStatusValue,
        owl:NamedIndividual ;
    rdfs:label "passed"@en ;
    rdfs:comment "Validation entity passed all rules — no violations detected."@en .

dg:Geometry a owl:Class ;
    rdfs:label "Geometry"@en ;
    rdfs:comment "Typed geometric data flowing through the parametric definition. Represents GH geometry types (Line, Point, Vector, Brep, Mesh, etc.). Connected to Structure as the physical form output. Distinct from dgv:ObjectInstance (which is a validated entity in Validgraph)."@en ;
    rdfs:subClassOf dg:Core .

dg:ObjProperty a owl:Class ;
    rdfs:label "ObjProperty"@en ;
    dg:graph dg:Ontograph ;
    rdfs:comment "A dynamically generated object property in the Ontograph layer. Represents relationships between domain classes (e.g. locatedIn). Key property: iri. Aligned with: owl:ObjectProperty (R7)."@en ;
    rdfs:subClassOf dg:Ontograph,
        owl:ObjectProperty .

dgc:ParamDataType_Float a dgc:ParamDataTypeValue,
        owl:NamedIndividual ;
    rdfs:label "Float"@en .

dgm-spike:BuiltinAtom a owl:Class ;
    rdfs:label "BuiltinAtom"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "An atom invoking a SWRL builtin comparison operator (e.g. swrlb:greaterThan(?h, 75)). Takes two arguments for comparison."@en ;
    rdfs:subClassOf dgm-spike:Atom .

dgm-spike:ClassAtom a owl:Class ;
    rdfs:label "ClassAtom"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "An atom asserting class membership (e.g. Building(?b)). Takes one variable argument at pos 1."@en ;
    rdfs:subClassOf dgm-spike:Atom .

<http://example.org/design-grammar/project/v8-ui-smoke/var/u> a swrl:Variable .

swrlb:lessThan a swrl:Builtin .

dg:Behavior a owl:Class ;
    rdfs:label "Behavior"@en ;
    rdfs:comment "How the design achieves its function — the computational process. Described by an Algorithm (Grasshopper definition). Behavior produces Structure (geometric form). In DCM: Behavior IS the parametric definition that generates design output."@en ;
    rdfs:subClassOf dg:Core .

dg:Function a owl:Class ;
    rdfs:label "Function"@en ;
    rdfs:comment "What the design object is supposed to achieve — its purpose or design intent. Rules enforce Functions. A Function is realized through Behavior (the computation that achieves it). Connected to Reasoner (as the mechanism evaluating design intent)."@en ;
    rdfs:subClassOf dg:Core .

dg:ParamState a owl:Class ;
    rdfs:label "ParamState"@en ;
    rdfs:comment "Definition state — a named set of Number/Integer/Boolean parameters captured from Grasshopper sliders and toggles. Represents the current parametric configuration. When ParamState changes, dependent IdRefs regenerate. ID prefix: DS_."@en ;
    rdfs:subClassOf dg:DesignState .

dgm-spike:RuleSet a owl:Class ;
    rdfs:label "RuleSet"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "A named collection of design grammar rules applied together as a regulatory package (e.g. \"BuildingCode2024\"). A RuleSet is NOT a sequence — rules within it have no precedence order. Rules can only host each other (nesting). Contains Rules via dgm:hasRule. Linked to a Reasoner via dgm:usesReasoner."@en ;
    rdfs:subClassOf dgm-spike:Metagraph .

dgm-spike:VariableScopeValue a owl:Class ;
    rdfs:label "VariableScope"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "Enumeration of variable scoping semantics derived from VariableKind. SCHM-06: enum class mirroring DesignStateParameterTypeValue pattern. Closed via owl:oneOf."@en ;
    rdfs:subClassOf dgm-spike:Metagraph ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( dgm-spike:VariableScope_CrossRule dgm-spike:VariableScope_RuleLocal ) ] .

dgm-spike:var_b a dgm-spike:ObjectVariable,
        owl:NamedIndividual ;
    rdfs:label "?b"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dgm-spike:variableName "?b" ;
    rdfs:comment "Object variable representing a Building instance. Inferred from ClassAtom Building(?b). Cross-rule scoped (VTYP-02)."@en .

dgm-spike:var_h a dgm-spike:PropertyVariable,
        owl:NamedIndividual ;
    rdfs:label "?h"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dgm-spike:inferredDatatype "xsd:decimal" ;
    dgm-spike:variableName "?h" ;
    rdfs:comment "Property variable representing height. Inferred from DataPropertyAtom hasHeightM(?b,?h) arg-2. Rule-scoped (VTYP-03)."@en .

dgs:SpecClass a owl:Class ;
    rdfs:label "SpecClass"@en ;
    dg:graph dgs:SpecGraph ;
    rdfs:comment "Parent hub node connecting all instances of a knowledge type. Acts as a type discriminator (e.g. SpecNote, Session)."@en ;
    rdfs:subClassOf dgs:SpecGraph .

dgv:DesignStateParameter a owl:Class ;
    rdfs:label "DesignStateParameter"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "A single measurable parameter within a ParamState snapshot. Has a parameterId, displayName, type (Number/Integer/Boolean), and the corresponding typed value."@en ;
    rdfs:subClassOf dgv:Validgraph .

dgv:OI_Building_b1 a dgv:ObjectInstance,
        owl:NamedIndividual ;
    rdfs:label "ObjectInstance: Building #1"@en ;
    dg:graph dgv:Validgraph ;
    dg:project "TestA" ;
    dgv:hasObjState dg:OS_b1_var_b ;
    dgv:instanceId "OI_Building_b1" ;
    rdfs:comment "Cross-rule identity for the first Building in the TestA model. Bound to Object variable ?b via its ObjState."@en .

dgv:Reasoner a owl:Class ;
    rdfs:label "Reasoner"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "An evaluation engine concept representing the strategy used to apply rules to design state. Different reasoners may process rules differently (SWRL forward-chaining, Grasshopper constraint solver, parametric propagation). Linked from RuleSet (dgm:usesReasoner) and from Core Function (dg:evaluatedBy, as the mechanism that evaluates design intent). Corresponds to the Grasshopper \"Validator\" add-in component. Reconsidered as part of the Validgraph layer in v6.0."@en ;
    rdfs:subClassOf dgv:Validgraph .

dg:LayerEntity a owl:Class ;
    rdfs:label "LayerEntity"@en ;
    rdfs:comment "Abstract root for DG entities that belong to one of the four graph layers. Direct subclasses are the four layer hubs: dg:Ontograph, dgm:Metagraph, dgv:Validgraph, dgs:SpecGraph. Each hub IRI is simultaneously a class (grouping its layer's DG entities) AND a NamedIndividual of dg:GraphLayer via OWL 2 punning (v3.4 unified structure). dg:LayerEntity itself is intentionally NOT tagged with a dg:graph annotation because it is cross-cutting — it is the parent of all four layer hubs, not a member of any single layer."@en .

dg:Structure a owl:Class ;
    rdfs:label "Structure"@en ;
    rdfs:comment "What the design IS — its physical/geometric form resulting from Behavior. Connects to Geometry (data) and Topology (spatial decomposition). Represents the output of parametric computation."@en ;
    rdfs:subClassOf dg:Core .

dgc:Algorithm a owl:Class ;
    rdfs:label "Algorithm"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "A complete parametric definition — the top-level container for the computational process. Maps to a Grasshopper definition file (the whole canvas). Contains Procedures. Example: '1_Algorithm' generating a Frame object."@en ;
    rdfs:subClassOf dgc:Computgraph .

dgm-spike:DataPropertyAtom a owl:Class ;
    rdfs:label "DataPropertyAtom"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "An atom asserting a datatype property value (e.g. hasHeightM(?b, ?h)). Takes two arguments: entity variable (pos 1) and value variable/literal (pos 2)."@en ;
    rdfs:subClassOf dgm-spike:Atom .

dgm-spike:PropertyVariable a owl:Class ;
    rdfs:label "PropertyVariable"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "A variable representing a datatype property value (e.g. ?h for height). Inferred from DataPropertyAtom arg-2 position (VTYP-01). Property variables are rule-scoped: the same name in different rules represents independent variables (VTYP-03). The rule-local scope is inferred by reasoner via the SubClassOf restriction below (v4.1)."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue dgm-spike:VariableScope_RuleLocal ;
            owl:onProperty dgm-spike:variableScope ],
        dgm-spike:Variable .

<http://example.org/design-grammar/project/v8-ui-smoke/var/f> a swrl:Variable .

dgv:DesignStateParameterTypeValue a owl:Class ;
    rdfs:label "DesignStateParameterType"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "Enumeration of supported parameter value types for DesignState snapshots. Corresponds to C# enum DG.Core.Models.DesignStateParameterType. Closed via owl:oneOf."@en ;
    rdfs:subClassOf dgv:Validgraph ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( dgv:ParameterType_Number dgv:ParameterType_Integer dgv:ParameterType_Boolean ) ] .

dgv:ValidationStatusValue a owl:Class ;
    rdfs:label "ValidationStatus"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "Status values for validation runs and entity results. Closed via owl:oneOf — value space is fixed at Completed, Passed, Failed."@en ;
    rdfs:subClassOf dgv:Validgraph ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( dgv:Status_Completed dgv:Status_Passed dgv:Status_Failed ) ] .

dg:GraphLayer a owl:Class ;
    rdfs:label "GraphLayer"@en ;
    rdfs:comment "A logical partition of the single Neo4j database. The Design Grammar System organizes all persisted nodes into exactly four layers (closed enumeration via owl:oneOf below, v4.1): Ontograph, Metagraph, Validgraph, SpecGraph. The four layer IRIs are punned per OWL 2 — each is both a class (parent of the layer's DG entities, under LayerEntity) and an individual (member of this GraphLayer enum). Every DG class carries a `dg:graph` annotation pointing at its layer."@en ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( dg:Ontograph dgm-spike:Metagraph dgv:Validgraph dgs:SpecGraph dgc:Computgraph ) ] .

dgc:ConstantParam a owl:Class ;
    rdfs:label "ConstantParam"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "A fixed configuration value — preset and not intended for user adjustment. Example: '11_Const_ptZero' (origin point), '11_Const_TrussConfig' (Truss Web Configuration)."@en ;
    rdfs:subClassOf dgc:Parameter .

dgc:EmergentParam a owl:Class ;
    rdfs:label "EmergentParam"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "A computed output value — emerges from Pattern execution. Not directly set by user; derived from computation. Example: '11_Emg_LineSDL' (computed line), '12_Emg_FooterFrame' (generated frame geometry)."@en ;
    rdfs:subClassOf dgc:Parameter .

dgc:ListStructureValue a owl:Class ;
    rdfs:label "ListStructure"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "Enumeration of Grasshopper data tree management operations applicable to Interfaces. Closed via owl:oneOf."@en ;
    rdfs:subClassOf dgc:Computgraph ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( dgc:ListStructure_Flatten dgc:ListStructure_Graft dgc:ListStructure_Simplify dgc:ListStructure_Reverse ) ] .

dgc:Output a owl:Class ;
    rdfs:label "Output"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "An output port on an Interface — emits data from a Procedure or Pattern."@en ;
    rdfs:subClassOf dgc:Interface .

dgc:ParamDataType_Geometry a dgc:ParamDataTypeValue,
        owl:NamedIndividual ;
    rdfs:label "Geometry"@en .

dgc:ParamDataType_Integer a dgc:ParamDataTypeValue,
        owl:NamedIndividual ;
    rdfs:label "Integer"@en .

dgc:VariableParam a owl:Class ;
    rdfs:label "VariableParam"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "A user-adjustable input parameter (GH slider, number input, toggle). Value can be changed by the user at design time. Example: '11_Var_SpansCount' (Count of spans), '12_Var_HFooter' (Footer Height)."@en ;
    rdfs:subClassOf dgc:Parameter .

dgm-spike:ObjectVariable a owl:Class ;
    rdfs:label "ObjectVariable"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "A variable representing a domain entity instance (e.g. ?b for Building). Inferred from ClassAtom arguments (VTYP-01). Object variables are cross-rule scoped: the same variable name maps to the same entity across all rules in a project (VTYP-02). Can be wired to OBJECT STATE component to create ObjState (CMPST-01). The cross-rule scope is inferred by reasoner via the SubClassOf restriction below (v4.1)."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:hasValue dgm-spike:VariableScope_CrossRule ;
            owl:onProperty dgm-spike:variableScope ],
        dgm-spike:Variable .

dgv:Status_Completed a dgv:ValidationStatusValue,
        owl:NamedIndividual ;
    rdfs:label "completed"@en ;
    rdfs:comment "Validation run finished successfully."@en .

dg:Class a owl:Class ;
    rdfs:label "Class"@en ;
    dg:graph dg:Ontograph ;
    rdfs:comment "A dynamically generated OWL class in the Ontograph layer. Created from user prompts (e.g. Building, UrbanBlock). Key property: iri. Aligned with: owl:Class (R7, subClassOf rather than equivalentClass — DG reifies the OWL meta-schema as Neo4j data, so dg:Class instances are also conceptually owl:Class instances, but using subClassOf keeps the meta-level reification clear)."@en ;
    rdfs:subClassOf dg:Ontograph,
        owl:Class .

dg:Object a owl:Class ;
    rdfs:label "Object"@en ;
    rdfs:comment "A design entity described through its Function, Behavior, and Structure (FBS framework). Represents a parametric design object whose behavior is defined by Grasshopper algorithms. Example: a Frame object whose algorithm generates a 2D truss. Bridges to dg:Class instances (a Building IS an Object in DCM terms)."@en ;
    rdfs:subClassOf dg:Core .

dgc:Interface a owl:Class ;
    rdfs:label "Interface"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "An inter-procedure connector — exposes data between Procedures. Maps to Grasshopper connection points at procedure boundaries. Has InterfaceType (Input/Output) and optional ListStructure for data tree management. Example: '11_IntF_ParSplitAt', '11_IntF_MergeRes'. Every Interface is necessarily an Input OR an Output (owl:disjointUnionOf)."@en ;
    rdfs:subClassOf dgc:Computgraph ;
    owl:disjointUnionOf ( dgc:Input dgc:Output ) .

dgc:ParamDataTypeValue a owl:Class ;
    rdfs:label "ParamDataType"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "Enumeration of parameter data types in the computation graph. Maps to Grasshopper data types. Closed via owl:oneOf."@en ;
    rdfs:subClassOf dgc:Computgraph ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( dgc:ParamDataType_Float dgc:ParamDataType_Integer dgc:ParamDataType_Text dgc:ParamDataType_Boolean dgc:ParamDataType_Geometry ) ] .

dgv:GeoRef a owl:Class ;
    rdfs:label "GeoRef"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "Geometry reference — a handle to a geometry primitive in the source model (an external source-system object handle) wired into the OBJECT STATE component (CMPST-01, CTRCT-09). One ObjState may reference multiple GeoRefs (the geometry elements that compose the ObjectInstance). Aligned with: geo:Geometry (R6) — note that DG stores a source-system handle (geoRefId) rather than serialized geometry (geo:asWKT)."@en ;
    rdfs:subClassOf dgv:Validgraph .

dgv:IdRef a owl:Class ;
    rdfs:label "IdRef"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "Auto-generated DesignState identifier (CMPST-08). IdRef = DesignState ID — NOT ObjState ID. Regenerates whenever ParamState changes (CMPST-05). Persisted in statePayloadJson for cross-run object identity tracking (INTG-03). Resolves to one or more ObjectInstance(s). ID prefix: IDR_."@en ;
    rdfs:subClassOf dgv:Validgraph .

dgv:IntegrationConfig a owl:Class ;
    rdfs:label "IntegrationConfig"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "Configuration node linking a DG project to its external geometry/viewer integration. Stores the external project ID, base model, and validation model references. One per project per provider."@en ;
    rdfs:subClassOf dgv:Validgraph .

dg:Core a owl:Class ;
    rdfs:label "Core"@en ;
    rdfs:comment "Top-level grouping for the main Design Grammar entities considered over the layer structure: Object, Function, Behavior, Structure (Gero FBS), Geometry, Topology, DesignState (with ObjState/ParamState), and the shared Session. Core entities are referenced by the five graph layers but belong to none of them — they carry no dg:graph annotation (cross-cutting, like dg:LayerEntity). An Object has Function, Behavior, and Structure; its Function is covered by the Ontograph layer (dg:definesFunction), and its Design State is validated by the Metagraph layer (dgm:validates)."@en .

dgc:Procedure a owl:Class ;
    rdfs:label "Procedure"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "A grouped sequence of Patterns within an Algorithm — an organizational unit of computation. Maps to a Grasshopper Cluster or Group. Contains Patterns and exposes Interfaces for inter-procedure data flow. Example: '11_Proc - 2D Truss Configuration', '12_Proc - 2D Footer Configuration'."@en ;
    rdfs:subClassOf dgc:Computgraph .

dgm-spike:Variable a owl:Class ;
    rdfs:label "Variable"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "A SWRL variable (e.g. ?b, ?h). Key property: name (prefixed with '?'). Every Variable individual is necessarily an ObjectVariable, PropertyVariable, OR BuiltinVariable (owl:disjointUnionOf below — VTYP-01 priority chain). MERGE key includes project to prevent cross-project collision (SCHM-02). STORAGE NOTE: In the Neo4j layer, variable kind is inferred at read time by VariableTypeInferrer.Infer() — not stored on the Var node. The OWL ontology uses rdf:type plus disjointUnionOf to discriminate; no separate kind property exists (v4.1)."@en ;
    rdfs:subClassOf dgm-spike:Metagraph ;
    owl:disjointUnionOf ( dgm-spike:ObjectVariable dgm-spike:PropertyVariable dgm-spike:BuiltinVariable ) .

dgv:ObjectInstance a owl:Class ;
    rdfs:label "ObjectInstance"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "Cross-rule identity of a validated geometric element (CMPST-06). The noun — the actual thing in the model that gets validated. Stable across geometry edits. Each ObjectInstance has exactly one ObjState (its current binding snapshot). ID prefix: OI_. Both ObjectInstance and ObjState live above rule scope. Aligned with: sosa:FeatureOfInterest (R3) and geo:Feature (R6)."@en ;
    rdfs:subClassOf dgv:Validgraph .

dgv:ReStatusValue a owl:Class ;
    rdfs:label "ReStatus"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "Outcome status for a single parameter during design state reinstatement. Corresponds to C# enum DG.Core.Models.ReStatus. Used by the REINSTATE component to report per-parameter results. Closed via owl:oneOf."@en ;
    rdfs:subClassOf dgv:Validgraph ;
    owl:equivalentClass [ a owl:Class ;
            owl:oneOf ( dgv:ReStatus_Applied dgv:ReStatus_MissingTarget dgv:ReStatus_TypeMismatch dgv:ReStatus_AmbiguousTarget dgv:ReStatus_OutOfRange dgv:ReStatus_Unchanged dgv:ReStatus_WouldApply ) ] .

dg:DesignState a owl:Class ;
    rdfs:label "DesignState"@en ;
    rdfs:comment "A snapshot of design parameters captured from Grasshopper. Every DesignState individual is necessarily one of ParamState, ObjState, or PropState (owl:disjointUnionOf below) — mutually exclusive, never more than one. ID prefixes: DS_ (ParamState), OS_ (ObjState), PS_ (PropState). Composed by DESIGN STATE and persisted in validation runs (v7.0: CLASSIFICATOR is eliminated; VALIDATOR binds directly from the composed DesignState). STORAGE NOTE: In the Neo4j layer (SCHM-01), this discrimination is materialized as a `kind` property with values \"ParamState\" | \"ObjState\" | \"PropState\" on a single :DesignState node label — a runtime convenience because Cypher does not infer subclass membership. The OWL ontology does not include the kind property because rdf:type plus disjointUnionOf already discriminate (v4.1)."@en ;
    rdfs:subClassOf dg:Core ;
    owl:disjointUnionOf ( dg:ParamState dg:ObjState dg:PropState ) .

dgm-spike:Literal a owl:Class ;
    rdfs:label "Literal"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "A constant value used as an atom argument (e.g. 75, true). Key properties: lex (lexical form) + datatype (xsd type)."@en ;
    rdfs:subClassOf dgm-spike:Metagraph .

<http://example.org/design-grammar/project/v8-ui-smoke/var/b> a swrl:Variable .

dg:DataProperty a owl:Class ;
    rdfs:label "DataProperty"@en ;
    dg:graph dg:Ontograph ;
    rdfs:comment "A dynamically generated datatype property in the Ontograph layer. Represents measurable attributes (e.g. hasHeightM) and violation flags (e.g. violatesMaxHeight). Key property: iri. Aligned with: owl:DatatypeProperty (R7)."@en ;
    rdfs:subClassOf dg:Ontograph,
        owl:DatatypeProperty .

dg:ObjState a owl:Class ;
    rdfs:label "ObjState"@en ;
    rdfs:comment "Object state — associates an Object variable reference (from SWRL ClassAtom) with geometry elements. Created by the OBJECT STATE component by wiring ObjectRef + GeoRef. Composed into DESIGN STATE alongside ParamState to produce stable IdRefs. ID prefix: OS_. NEVER has an IdRef — carries its own stateId (OS_ prefix). Enforced via SubClassOf (hasIdRef max 0)."@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass dgv:IdRef ;
            owl:onProperty dgv:hasIdRef ],
        dg:DesignState .

dgc:Parameter a owl:Class ;
    rdfs:label "Parameter"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "A typed value in a parametric definition — data flowing through the computation graph. Distinct from dgm:Variable (which is a SWRL runtime binding): Parameter is a GH definition-time concept. Has ParameterType (Var/Const/Emergent) and ParamDataType. Bridge: Atoms can reference Parameters via dgc:attributeOf. Every Parameter is necessarily a VariableParam, ConstantParam, OR EmergentParam (owl:disjointUnionOf)."@en ;
    rdfs:subClassOf dgc:Computgraph ;
    owl:disjointUnionOf ( dgc:VariableParam dgc:ConstantParam dgc:EmergentParam ) .

dgc:Pattern a owl:Class ;
    rdfs:label "Pattern"@en ;
    dg:graph dgc:Computgraph ;
    rdfs:comment "The atomic unit of parametric computation — a single operation node. Maps to a Grasshopper Component (a node on the canvas). Has Interfaces (I/O ports) and receives Parameters. Patterns can host other Patterns (nesting). Example: '11_Pat_DivideLine', '11_Pat_TopChord', '12_Pat_1 - Create footer bottom lines'."@en ;
    rdfs:subClassOf dgc:Computgraph .

dgm-spike:Builtin a owl:Class ;
    rdfs:label "Builtin"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "A SWRL builtin comparison or arithmetic operator. Referenced by BuiltinAtom via REFERS_TO. Key property: iri (swrlb: prefix)."@en ;
    rdfs:subClassOf dgm-spike:Metagraph .

dg:hasPart a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "HAS_PART"@en ;
    rdfs:comment "Generic composition (part-whole) relation. Transitive super-property of the ERD containment hierarchy: Object hasPart {Function, Behavior, Structure}; Structure hasPart {Geometry, Topology}; RuleSet hasPart Rule; Algorithm hasPart Procedure; Procedure hasPart Pattern; Pattern hasPart {Parameter, Interface}. Transitivity yields the full decomposition, e.g. Object hasPart Geometry and Algorithm hasPart Parameter. Inverse: dg:partOf. Not used in cardinality restrictions (kept simple-property-safe for OWL 2 DL)."@en .

dgv:ValidationEntity a owl:Class ;
    rdfs:label "ValidationEntity"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "A BIM entity evaluated in a validation run. Records the entity's DG ID, display name, and overall pass/fail status for the specific run and rule. Aligned with: prov:Entity (R2), sosa:Observation (R3), and sh:ValidationResult (R4) — the cell (Run × Rule × ObjectInstance) is simultaneously a provenance entity, an observation of a property on a feature, and a validation result."@en ;
    rdfs:subClassOf dgv:Validgraph .

dg:Session a owl:Class ;
    rdfs:label "Session"@en ;
    rdfs:comment "A unified interaction-log entity common to all layers (v6.0 — unifies the former Metagraph rule-session and Spec knowledge-session logs). Records an LLM-driven interaction (the user prompt and generated result); the sessionMode discriminates the operation (ingest/query/edit for rule sessions, insert/query/update for spec sessions). Aligned with: prov:Activity (see standards extension)."@en ;
    rdfs:subClassOf dg:Core .

dgm-spike:Atom a owl:Class ;
    rdfs:label "Atom"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "An individual SWRL atom — a single predicate assertion within a rule. Types: ClassAtom, DataPropertyAtom, ObjectPropertyAtom, BuiltinAtom. Key property: Atom_Id."@en ;
    rdfs:subClassOf dgm-spike:Metagraph .

dgm-spike:Rule a owl:Class ;
    rdfs:label "Rule"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "A design grammar rule expressed as a SWRL implication. Contains body atoms (conditions) and head atoms (conclusions). Key property: Rule_Id. Format: R_<DOMAIN>_<PROPERTY>_<LIMIT>_V"@en ;
    rdfs:subClassOf dgm-spike:Metagraph .

dgs:SpecNote a owl:Class ;
    rdfs:label "SpecNote"@en ;
    dg:graph dgs:SpecGraph ;
    rdfs:comment "A project knowledge entry (from folder ingest or NL prompt). Contains title, content, tags, and source reference."@en ;
    rdfs:subClassOf dgs:SpecGraph .

dgv:Run a owl:Class ;
    rdfs:label "Run"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "A single execution of rule evaluation against design state. Records which rules were evaluated, the external model version created, and entity-level pass/fail results. Created by the DG Grasshopper plugin's validation workflow. Aligned with: prov:Activity (R2) and sh:ValidationReport (R4)."@en ;
    rdfs:subClassOf dgv:Validgraph .

dg:Ontograph a dg:GraphLayer,
        owl:Class,
        owl:NamedIndividual ;
    rdfs:label "Ontograph"@en ;
    dg:graph dg:Ontograph ;
    rdfs:comment "Hub class for the Ontograph layer (dynamic domain ontology meta-schema). Top-level subclasses: Class, DatatypeProperty, ObjectProperty."@en ;
    rdfs:subClassOf dg:LayerEntity .

dgs:SpecTag a owl:Class ;
    rdfs:label "SpecTag"@en ;
    dg:graph dgs:SpecGraph ;
    rdfs:comment "A tag label shared across knowledge notes for categorization. Aligned with: skos:Concept (R5) — a Tag IS a concept in a project's tag taxonomy."@en ;
    rdfs:subClassOf dgs:SpecGraph .

dgv:Validgraph a dg:GraphLayer,
        owl:Class,
        owl:NamedIndividual ;
    rdfs:label "Validgraph"@en ;
    dg:graph dgv:Validgraph ;
    rdfs:comment "Hub class for the Validgraph layer (validation runs, design state, integration config). Top-level subclasses: Run, ValidationEntity, Reasoner, DesignStateParameter, IntegrationConfig, ObjectInstance, GeoRef, IdRef, and three enum value classes (DesignStateParameterTypeValue, ValidationStatusValue, ReStatusValue). (The design-state classes moved to Core in v6.0.)"@en ;
    rdfs:subClassOf dg:LayerEntity .

dgs:SpecGraph a dg:GraphLayer,
        owl:Class,
        owl:NamedIndividual ;
    rdfs:label "SpecGraph"@en ;
    dg:graph dgs:SpecGraph ;
    rdfs:comment "Hub class for the SpecGraph layer (project specification notes and tags). Top-level subclasses: SpecClass, SpecNote, SpecTag. (Renamed in v6.0; sessions unified into Core.)"@en ;
    rdfs:subClassOf dg:LayerEntity .

dgc:Computgraph a dg:GraphLayer,
        owl:Class,
        owl:NamedIndividual ;
    rdfs:label "Computgraph"@en ;
    rdfs:comment "Hub class for the Computgraph layer (DCM parametric design model). Contains: Algorithm, Procedure, Pattern, Parameter, Interface. (FBS Object/Function/Behavior/Structure, Geometry and Topology moved to Core; ParametricState dropped; in v6.0.) Conceptual layer for future Grasshopper integration — enables translation of design grammars into/from parametric definitions."@en,
        "Named individual for the Computgraph layer (OWL 2 punning: simultaneously a class and an individual of dg:GraphLayer)."@en ;
    rdfs:subClassOf dg:LayerEntity .

dgm-spike:Metagraph a dg:GraphLayer,
        owl:Class,
        owl:NamedIndividual ;
    rdfs:label "Metagraph"@en ;
    dg:graph dgm-spike:Metagraph ;
    rdfs:comment "Hub class for the Metagraph layer (SWRL rule structure). Top-level subclasses: Rule, Atom (with ClassAtom/DataPropertyAtom/ObjectPropertyAtom/BuiltinAtom children), Variable (with ObjectVariable/PropertyVariable/BuiltinVariable children), Literal, Builtin, RuleSet, VariableScopeValue. (Reasoner moved to Validgraph and sessions unified into Core in v6.0.)"@en ;
    rdfs:subClassOf dg:LayerEntity .

[] a owl:AllDisjointClasses ;
    owl:members ( dgc:Algorithm dgc:Procedure dgc:Pattern dgc:Parameter dgc:Interface ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgv:ObjectInstance dg:ObjState dgv:IdRef dgv:GeoRef ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dg:Object dg:Function dg:Behavior dg:Structure dg:Geometry dg:Topology dg:DesignState dg:Session ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgm-spike:Rule dgm-spike:Atom dgm-spike:Variable dgm-spike:Literal dgm-spike:Builtin dgm-spike:RuleSet ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgm-spike:VariableScopeValue dgv:DesignStateParameterTypeValue dgv:ValidationStatusValue dgv:ReStatusValue dgc:ParamDataTypeValue dgc:ListStructureValue ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dg:ParamState dg:ObjState dg:PropState ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgm-spike:ClassAtom dgm-spike:DataPropertyAtom dgm-spike:ObjectPropertyAtom dgm-spike:BuiltinAtom ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dg:Class dg:DataProperty dg:ObjProperty ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgm-spike:ObjectVariable dgm-spike:PropertyVariable dgm-spike:BuiltinVariable ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgc:VariableParam dgc:ConstantParam dgc:EmergentParam ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgc:Input dgc:Output ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgv:Run dgv:ValidationEntity dgv:Reasoner dgv:DesignStateParameter dgv:IntegrationConfig dgv:ObjectInstance dgv:GeoRef dgv:IdRef ) .

[] a owl:AllDisjointClasses ;
    owl:members ( dgs:SpecClass dgs:SpecNote dgs:SpecTag ) .

