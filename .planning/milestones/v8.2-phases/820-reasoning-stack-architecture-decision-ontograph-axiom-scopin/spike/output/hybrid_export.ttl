<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_BUILDING_MIN_DISTANCE_12_V_A1> a swrl:ClassAtom ;
    swrl:argument1 <http://example.org/design-grammar/project/v8-ui-smoke/var/b> ;
