<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_BUILDING_MAX_STOREY_9_V_A3> a swrl:BuiltinAtom ;
    swrl:arguments ( <http://example.org/design-grammar/project/v8-ui-smoke/var/s> 9 ) ;
    swrl:builtin swrlb:lessThan .

<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_BUILDING_MAX_STOREY_9_V_H1> a swrl:DatavaluedPropertyAtom ;
    swrl:argument1 <http://example.org/design-grammar/project/v8-ui-smoke/var/b> ;
