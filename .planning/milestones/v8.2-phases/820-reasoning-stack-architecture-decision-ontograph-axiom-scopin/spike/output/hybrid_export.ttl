<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_FACADE_GRID_HEX_V_A1> a swrl:ClassAtom ;
    swrl:argument1 <http://example.org/design-grammar/project/v8-ui-smoke/var/f> ;
    swrl:classPredicate ex:Facade .

<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_FACADE_GRID_HEX_V_A2> a swrl:DatavaluedPropertyAtom ;
    swrl:argument1 <http://example.org/design-grammar/project/v8-ui-smoke/var/f> ;
