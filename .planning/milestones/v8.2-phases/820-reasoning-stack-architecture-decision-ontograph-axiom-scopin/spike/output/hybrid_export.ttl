    rdfs:label "R_STREET_MIN_WIDTH_18_V"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:SWRL "Street(?s)^hasWidthM(?s,?w)^swrlb:lessThan(?w,18)->violatesMinWidth(?s,true)" ;
