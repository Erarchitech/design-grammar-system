dgs:content a owl:DatatypeProperty ;
    rdfs:label "content"@en ;
    rdfs:comment "Full text content of a knowledge note. Aligned with: skos:note (R5) — the SKOS pattern for the textual body of a concept-related artifact."@en ;
    rdfs:domain dgs:SpecNote ;
    rdfs:range xsd:string .

dgs:createdAt a owl:DatatypeProperty ;
    rdfs:label "createdAt"@en ;
    rdfs:comment "ISO 8601 UTC timestamp of creation. Aligned with: dcterms:created (R5)."@en ;
    rdfs:range xsd:dateTime .

dgs:instanceOf a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "INSTANCE_OF"@en ;
    rdfs:comment "Connects a SpecNote or Session to its parent SpecClass hub node. Characteristics: Functional — each Note/Session has exactly one parent hub."@en ;
    rdfs:range dgs:SpecClass .

dgs:noteId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "noteId"@en ;
    rdfs:comment "Unique identifier for a knowledge note. Characteristics: Functional. Aligned with: dcterms:identifier (R5)."@en ;
    rdfs:domain dgs:SpecNote ;
    rdfs:range xsd:string .

dgs:source a owl:DatatypeProperty ;
    rdfs:label "source"@en ;
    rdfs:comment "Source file path or reference for a knowledge note (e.g. notes/site.md). Aligned with: dcterms:source (R5)."@en ;
    rdfs:domain dgs:SpecNote ;
    rdfs:range xsd:string .

dgs:tagName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Tag name string (e.g. \"zoning\", \"structural\"). Characteristics: Functional — one canonical name per Tag. Aligned with: skos:prefLabel (R5) — the SKOS canonical label for a concept."@en ;
    rdfs:domain dgs:SpecTag ;
    rdfs:range xsd:string .

dgs:taggedWith a owl:ObjectProperty ;
    rdfs:label "TAGGED_WITH"@en ;
    rdfs:comment "Connects a SpecNote to its SpecTag nodes. Characteristics: none (many-to-many — a Note has multiple Tags, a Tag is reused across Notes)."@en ;
    rdfs:domain dgs:SpecNote ;
    rdfs:range dgs:SpecTag .

dgs:tags a owl:DatatypeProperty ;
    rdfs:label "tags"@en ;
    rdfs:comment "Array of tag names associated with a knowledge note (stored as Neo4j list property)."@en ;
    rdfs:domain dgs:SpecNote ;
    rdfs:range xsd:string .

dgs:title a owl:DatatypeProperty ;
    rdfs:label "title"@en ;
    rdfs:comment "Title of a knowledge note. Aligned with: dcterms:title (R5)."@en ;
    rdfs:domain dgs:SpecNote ;
    rdfs:range xsd:string .

dgs:updatedAt a owl:DatatypeProperty ;
    rdfs:label "updatedAt"@en ;
    rdfs:comment "ISO 8601 UTC timestamp of last update. Aligned with: dcterms:modified (R5)."@en ;
    rdfs:range xsd:dateTime .

dgv:Integration_TestA a dgv:IntegrationConfig,
        owl:NamedIndividual ;
    rdfs:label "External Integration (TestA)"@en ;
    dg:graph dgv:Validgraph ;
    dg:project "TestA" ;
    dgv:baseModelId "4c546c0771" ;
    dgv:externalProjectId "44088eefc6" ;
    dgv:provider "ExternalViewer" ;
    dgv:validationModelId "a6d1e0c5da" ;
    rdfs:comment "Integration config from Neo4j Validgraph. Connects project TestA to an external geometry/viewer platform for 3D validation overlay."@en .

dgv:SendStatus a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "SendStatus"@en ;
    rdfs:comment "NEW in v7.0 (no V6 predecessor). Single Boolean per Run: whether publishing this run's results to the external geometry/viewer platform succeeded (D-08). Orthogonal to ValidStatus — set true when the publish operation completes successfully, independent of the rule pass/fail outcome. Publishing is one operation per run, so SendStatus is not per-object. Characteristics: Functional. Matches the GH_DesignGrammars.pdf schema (DG.Layer.Validgraph.SendStatus; Output=Run().SendStatus Datatype: Boolean)."@en ;
    rdfs:domain dgv:Run ;
    rdfs:range xsd:boolean .

