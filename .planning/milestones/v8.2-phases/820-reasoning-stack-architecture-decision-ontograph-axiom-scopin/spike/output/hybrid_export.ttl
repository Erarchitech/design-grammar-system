dg:createdAt a owl:DatatypeProperty ;
    rdfs:label "createdAt"@en ;
    rdfs:comment "ISO 8601 UTC timestamp of node creation. Used across all graph layers. Aligned with: dcterms:created (R5/R7 — cross-cutting Dublin Core creation timestamp)."@en ;
    rdfs:range xsd:dateTime .

dg:definesFunction a owl:ObjectProperty ;
    rdfs:label "DEFINES_FUNCTION"@en ;
    rdfs:comment "Connects an Ontograph entity (Class, ObjProperty, or DataProperty) to the Core Function it realises for an Object. The Ontograph layer defines, from NL input, what classes and properties exist and links them to the Function of a specific Object — so one Object may have many Functions, and a group of Objects may share some Functions while differing in others."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( dg:Class dg:ObjProperty dg:DataProperty ) ] ;
    rdfs:range dg:Function .

dg:drs_4cab136231cf a dg:Session,
        owl:NamedIndividual ;
    rdfs:label "drs-4cab136231cf"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dg:sessionId "drs-4cab136231cf" ;
    dg:sessionMode "ingest" ;
    dg:sessionPrompt "Street minimum width is 15 meters." .

dg:drs_79ba197cc693 a dg:Session,
        owl:NamedIndividual ;
    rdfs:label "drs-79ba197cc693"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dg:sessionId "drs-79ba197cc693" ;
    dg:sessionMode "edit" ;
    dg:sessionPrompt "Street minimum width is 18 meters." .

dg:drs_96d1ebd8dc8a a dg:Session,
        owl:NamedIndividual ;
    rdfs:label "drs-96d1ebd8dc8a"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dg:sessionId "drs-96d1ebd8dc8a" ;
    dg:sessionMode "ingest" ;
    dg:sessionPrompt "All building must be maximum 75 meters high" .

dg:drs_ac4c176afeeb a dg:Session,
        owl:NamedIndividual ;
    rdfs:label "drs-ac4c176afeeb"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dg:sessionId "drs-ac4c176afeeb" ;
    dg:sessionMode "query" ;
    dg:sessionPrompt "list all rules" .

dg:evaluatedBy a owl:ObjectProperty ;
    rdfs:label "EVALUATED_BY"@en ;
    rdfs:comment "Connects a Function to the Reasoner that evaluates design rules against it. Links design intent (Function) to rule evaluation strategy (Reasoner)."@en ;
    rdfs:domain dg:Function ;
    rdfs:range dgv:Reasoner .

dg:graph a owl:AnnotationProperty ;
    rdfs:label "graph layer"@en ;
    rdfs:comment "Logical graph partition within the single Neo4j database. Values are resource references to the four punned hub IRIs that are simultaneously classes (parents of layer-member entities) and NamedIndividuals of dg:GraphLayer: dg:Ontograph, dgm:Metagraph, dgv:Validgraph, dgs:SpecGraph. The range below documents this; OWL annotation properties do not enforce range."@en ;
    rdfs:range dg:GraphLayer .

dg:hasBehavior a owl:ObjectProperty ;
    rdfs:label "HAS_BEHAVIOR"@en ;
    rdfs:comment "Connects an Object to its Behavior (computational process achieving the function)."@en ;
    rdfs:domain dg:Object ;
    rdfs:range dg:Behavior ;
    rdfs:subPropertyOf dg:hasPart .

dg:hasFunction a owl:ObjectProperty ;
    rdfs:label "HAS_FUNCTION"@en ;
    rdfs:comment "Connects an Object to its Function (design intent). An Object may have multiple Functions."@en ;
    rdfs:domain dg:Object ;
    rdfs:range dg:Function ;
    rdfs:subPropertyOf dg:hasPart .

dg:hasGeometry a owl:ObjectProperty ;
    rdfs:label "HAS_GEOMETRY"@en ;
    rdfs:comment "Connects a Structure to its Geometry data (the physical form representation)."@en ;
    rdfs:domain dg:Structure ;
    rdfs:range dg:Geometry ;
    rdfs:subPropertyOf dg:hasPart .

dg:hasStructure a owl:ObjectProperty ;
    rdfs:label "HAS_STRUCTURE"@en ;
    rdfs:comment "Connects an Object to its Structure (physical/geometric form)."@en ;
    rdfs:domain dg:Object ;
    rdfs:range dg:Structure ;
    rdfs:subPropertyOf dg:hasPart .

dg:hasTopology a owl:ObjectProperty ;
    rdfs:label "HAS_TOPOLOGY"@en ;
    rdfs:comment "Connects a Structure to its Topology (spatial decomposition via Topologic)."@en ;
    rdfs:domain dg:Structure ;
    rdfs:range dg:Topology ;
    rdfs:subPropertyOf dg:hasPart .

dg:iri a owl:DatatypeProperty ;
    rdfs:label "iri"@en ;
    rdfs:comment "IRI identifier for ontology entities. Format: ex:<Name> (e.g. ex:Building, ex:hasHeightM). Aligned with: dcterms:identifier (R7-adjacent) — the IRI IS the canonical identifier."@en ;
    rdfs:range xsd:string .

dg:label a owl:DatatypeProperty ;
    rdfs:label "label"@en ;
    rdfs:comment "Human-readable display label for Class and ObjectProperty nodes. Aligned with: rdfs:label (R7)."@en ;
    rdfs:range xsd:string ;
    rdfs:subPropertyOf rdfs:label .

dg:objectName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Display name of a DCM Object (e.g. 'Frame', 'Truss'). Characteristics: Functional."@en ;
    rdfs:domain dg:Object ;
    rdfs:range xsd:string .

dg:objectRef a owl:ObjectProperty ;
    rdfs:label "OBJECT_REF"@en ;
    rdfs:comment "Connects an ObjState to the Core Object it instantiates (the ERD 'ObjectRef' edge). The ObjState binds geometry to a specific design Object whose Function/Behavior/Structure are defined across the layers. (The string handle for the SWRL Object-variable name is dgv:objectRefName.)"@en ;
    rdfs:domain dg:ObjState ;
    rdfs:range dg:Object .

dg:partOf a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "PART_OF"@en ;
    rdfs:comment "Inverse of dg:hasPart — a component is part of its container. Transitive."@en ;
    owl:inverseOf dg:hasPart .

dg:project a owl:AnnotationProperty ;
    rdfs:label "project"@en ;
    rdfs:comment "Project isolation key. Every persisted node must include this property for multi-project support."@en .

dg:range a owl:DatatypeProperty ;
    rdfs:label "range"@en ;
    rdfs:comment "XSD datatype range for DatatypeProperty nodes (e.g. xsd:decimal, xsd:integer, xsd:boolean)."@en ;
    rdfs:domain dg:DataProperty ;
    rdfs:range xsd:string .

dg:sessionId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "sessionId"@en ;
    rdfs:comment "Unique identifier for a Session (e.g. drs-<hex12> for rule sessions, ks-<hex12> for spec sessions). Characteristics: Functional."@en ;
    rdfs:domain dg:Session ;
    rdfs:range xsd:string .

dg:sessionMode a owl:DatatypeProperty ;
    rdfs:label "mode"@en ;
    rdfs:comment "Interaction mode of a Session: 'ingest' | 'query' | 'edit' (rule sessions) or 'insert' | 'query' | 'update' (spec sessions)."@en ;
    rdfs:domain dg:Session ;
    rdfs:range xsd:string .

dg:sessionPrompt a owl:DatatypeProperty ;
    rdfs:label "prompt"@en ;
    rdfs:comment "The user's natural-language prompt that triggered this Session."@en ;
    rdfs:domain dg:Session ;
    rdfs:range xsd:string .

dg:sessionResult a owl:DatatypeProperty ;
    rdfs:label "result"@en ;
    rdfs:comment "The LLM-generated result of the Session (Cypher, answer text, or update summary)."@en ;
    rdfs:domain dg:Session ;
    rdfs:range xsd:string .

dgc:Const_12_TrussConfig a dgc:ConstantParam,
        owl:NamedIndividual ;
    rdfs:label "12_Const_TrussConfig"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Integer ;
    dgc:parameterDisplayName "Truss configuration (footer)" ;
    dgc:parameterName "12_Const_TrussConfig" .

dgc:Emg_11_LineSDL a dgc:EmergentParam,
        owl:NamedIndividual ;
    rdfs:label "11_Emg_LineSDL"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Geometry ;
    dgc:parameterDisplayName "Line SDL (computed)" ;
    dgc:parameterName "11_Emg_LineSDL" .

dgc:Emg_11_UpperChord a dgc:EmergentParam,
        owl:NamedIndividual ;
    rdfs:label "11_Emr_UpperChord"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Geometry ;
    dgc:parameterDisplayName "Upper chord geometry" ;
    dgc:parameterName "11_Emr_UpperChord" .

dgc:Emg_12_BottomLn a dgc:EmergentParam,
        owl:NamedIndividual ;
    rdfs:label "12_Emg_BottomLn"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Geometry ;
    dgc:parameterDisplayName "Footer bottom lines" ;
    dgc:parameterName "12_Emg_BottomLn" .

dgc:Emg_12_FooterFrame a dgc:EmergentParam,
        owl:NamedIndividual ;
    rdfs:label "12_Emg_FooterFrame"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Geometry ;
    dgc:parameterDisplayName "Footer frame geometry" ;
    dgc:parameterName "12_Emg_FooterFrame" .

dgc:Var_12_FooterCount a dgc:VariableParam,
        owl:NamedIndividual ;
    rdfs:label "12_Var_FooterCount"@en ;
    dg:graph dgc:Computgraph ;
    dgc:paramDataType dgc:ParamDataType_Integer ;
    dgc:parameterDisplayName "Footer count" ;
    dgc:parameterName "12_Var_FooterCount" .

dgc:algorithmName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Display name of an Algorithm (e.g. '1_Algorithm'). Characteristics: Functional."@en ;
    rdfs:domain dgc:Algorithm ;
    rdfs:range xsd:string .

dgc:attributeOf a owl:ObjectProperty ;
    rdfs:label "ATTRIBUTE_OF"@en ;
    rdfs:comment "Cross-layer bridge connecting a Metagraph Atom to a Computgraph Parameter. This is the semantic link enabling bidirectional translation between SWRL rules and Grasshopper parametric definitions: a rule atom can reference a parametric parameter. Follows the same cross-layer pattern as dgm:refersTo (Metagraph → Ontograph)."@en ;
    rdfs:domain dgm-spike:Atom ;
    rdfs:range dgc:Parameter .

dgc:hasAlgorithm a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "HAS_ALGORITHM"@en ;
    rdfs:comment "Connects a Behavior to its Algorithm (the complete parametric definition describing it). Characteristics: Functional — one Behavior has one Algorithm."@en ;
    rdfs:domain dg:Behavior ;
    rdfs:range dgc:Algorithm .

dgc:hasInterface a owl:ObjectProperty ;
    rdfs:label "HAS_INTERFACE"@en ;
    rdfs:comment "Connects a Pattern (or Procedure) to its Interface connector. Interfaces expose data at procedure boundaries."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( dgc:Pattern dgc:Procedure ) ] ;
    rdfs:range dgc:Interface ;
    rdfs:subPropertyOf dg:hasPart .

dgc:hasParameter a owl:ObjectProperty ;
    rdfs:label "HAS_PARAMETER"@en ;
    rdfs:comment "Connects a Pattern to its Parameters (input values consumed by the component)."@en ;
    rdfs:domain dgc:Pattern ;
    rdfs:range dgc:Parameter ;
    rdfs:subPropertyOf dg:hasPart .

dgc:hasPattern a owl:ObjectProperty ;
    rdfs:label "HAS_PATTERN"@en ;
    rdfs:comment "Connects a Procedure to its constituent Patterns. A Procedure contains multiple Patterns (GH components)."@en ;
    rdfs:domain dgc:Procedure ;
    rdfs:range dgc:Pattern ;
    rdfs:subPropertyOf dg:hasPart .

dgc:hasProcedure a owl:ObjectProperty ;
    rdfs:label "HAS_PROCEDURE"@en ;
    rdfs:comment "Connects an Algorithm to its constituent Procedures. An Algorithm contains multiple Procedures."@en ;
    rdfs:domain dgc:Algorithm ;
    rdfs:range dgc:Procedure ;
    rdfs:subPropertyOf dg:hasPart .

dgc:interfaceName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Display name of an Interface (e.g. '11_IntF_ParSplitAt'). Characteristics: Functional."@en ;
    rdfs:domain dgc:Interface ;
    rdfs:range xsd:string .

dgc:listStructure a owl:ObjectProperty ;
    rdfs:label "listStructure"@en ;
    rdfs:comment "Data tree management operation applied to an Interface (Flatten, Graft, Simplify, Reverse)."@en ;
    rdfs:domain dgc:Interface ;
    rdfs:range dgc:ListStructureValue .

dgc:paramDataType a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "paramDataType"@en ;
    rdfs:comment "Data type of a Parameter (Float, Integer, Text, Boolean, Geometry). Characteristics: Functional."@en ;
    rdfs:domain dgc:Parameter ;
    rdfs:range dgc:ParamDataTypeValue .

dgc:paramLink a owl:ObjectProperty ;
    rdfs:label "PARAM_LINK"@en ;
    rdfs:comment "Connects a Parameter to the Interface it flows through. Models data wiring between Parameters and Interface connectors."@en ;
    rdfs:domain dgc:Parameter ;
    rdfs:range dgc:Interface .

dgc:parameterDisplayName a owl:DatatypeProperty ;
    rdfs:label "displayName"@en ;
    rdfs:comment "Human-readable label for a Parameter (e.g. 'Count of spans', 'Footer Height')."@en ;
    rdfs:domain dgc:Parameter ;
    rdfs:range xsd:string .

dgc:parameterName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Display name of a Parameter (e.g. '11_Var_SpansCount', '11_Const_ptZero'). Characteristics: Functional."@en ;
    rdfs:domain dgc:Parameter ;
    rdfs:range xsd:string .

dgc:patternHostTo a owl:ObjectProperty ;
    rdfs:label "PATTERN_HOST_TO"@en ;
    rdfs:comment "Nesting relationship — a Pattern can host (contain) other Patterns. Models GH component grouping within a procedure."@en ;
    rdfs:domain dgc:Pattern ;
    rdfs:range dgc:Pattern .

dgc:patternName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Display name of a Pattern (e.g. '11_Pat_DivideLine'). Characteristics: Functional."@en ;
    rdfs:domain dgc:Pattern ;
    rdfs:range xsd:string .

dgc:procedureName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "name"@en ;
    rdfs:comment "Display name of a Procedure (e.g. '11_Proc - 2D Truss Configuration'). Characteristics: Functional."@en ;
    rdfs:domain dgc:Procedure ;
    rdfs:range xsd:string .

dgc:procedureOrder a owl:DatatypeProperty ;
    rdfs:label "order"@en ;
    rdfs:comment "Ordinal position of a Procedure within its Algorithm (numeric prefix, e.g. 11, 12)."@en ;
    rdfs:domain dgc:Procedure ;
    rdfs:range xsd:integer .

ex:Column a owl:Class ;
    rdfs:label "Column" .

ex:Corridor a owl:Class ;
    rdfs:label "Corridor" .

ex:FacadePanel a owl:Class ;
    rdfs:label "Facade panel" .

ex:Floor a owl:Class ;
    rdfs:label "Floor" .

ex:Roof a owl:Class ;
    rdfs:label "Roof" .

ex:SlidingDoor a owl:Class ;
    rdfs:subClassOf ex:Door,
        ex:Window .

ex:hasContinuity a owl:DatatypeProperty ;
    rdfs:label "hasContinuity" ;
    rdfs:range xsd:boolean .

ex:hasFacingDirection a owl:DatatypeProperty ;
    rdfs:label "hasFacingDirection" ;
    rdfs:range xsd:string .

ex:hasFacingDirectionEast a owl:DatatypeProperty ;
    rdfs:label "hasFacingDirectionEast" ;
    rdfs:range xsd:boolean .

ex:hasFacingDirectionWest a owl:DatatypeProperty ;
    rdfs:label "hasFacingDirectionWest" ;
    rdfs:range xsd:boolean .

ex:hasFlatness a owl:DatatypeProperty ;
    rdfs:label "hasFlatness" ;
    rdfs:range xsd:boolean .

ex:hasHeightM a owl:DatatypeProperty ;
    rdfs:label "hasHeightM" ;
    rdfs:range xsd:decimal .

ex:hasLengthM a owl:DatatypeProperty ;
    rdfs:label "hasLengthM" ;
    rdfs:range xsd:decimal .

ex:hasOrientation a owl:DatatypeProperty ;
    rdfs:label "hasOrientation" ;
    rdfs:range xsd:string .

ex:violatesContinuity a owl:DatatypeProperty ;
    rdfs:label "violatesContinuity" ;
    rdfs:range xsd:boolean .

ex:violatesDoorOrientation a owl:DatatypeProperty ;
    rdfs:label "violatesDoorOrientation" ;
    rdfs:range xsd:boolean .

ex:violatesFillet a owl:DatatypeProperty ;
    rdfs:label "violatesFillet" ;
    rdfs:range xsd:boolean .

ex:violatesFlatness a owl:DatatypeProperty ;
    rdfs:label "violatesFlatness" ;
    rdfs:range xsd:boolean .

ex:violatesMaxHeight a owl:DatatypeProperty ;
    rdfs:label "violatesMaxHeight" ;
    rdfs:range xsd:boolean .

ex:violatesMaxLength a owl:DatatypeProperty ;
    rdfs:label "violatesMaxLength" ;
    rdfs:range xsd:boolean .

ex:violatesSameHeight a owl:DatatypeProperty ;
    rdfs:label "violatesSameHeight" ;
    rdfs:range xsd:boolean .

dgm-spike:R_BUILDING_MAX_HEIGHT_75_V a dgm-spike:Rule,
        owl:NamedIndividual ;
    rdfs:label "R_BUILDING_MAX_HEIGHT_75_V"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "UrbanBlock" ;
    dgm-spike:SWRL "Building(?b)^hasHeightM(?b,?h)^swrlb:greaterThan(?h,75)->violatesMaxHeight(?b,true)" ;
    dgm-spike:hasBody dgm-spike:R_BUILDING_MAX_HEIGHT_75_V_A1,
        dgm-spike:R_BUILDING_MAX_HEIGHT_75_V_A2,
        dgm-spike:R_BUILDING_MAX_HEIGHT_75_V_A3 ;
    dgm-spike:hasHead dgm-spike:R_BUILDING_MAX_HEIGHT_75_V_H1 ;
    dgm-spike:ruleId "R_BUILDING_MAX_HEIGHT_75_V" ;
    dgm-spike:ruleKind "violation" .

dgm-spike:R_BUILDING_MAX_HEIGHT_80_V a dgm-spike:Rule,
        owl:NamedIndividual ;
    rdfs:label "R_BUILDING_MAX_HEIGHT_80_V"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:SWRL "Building(?b)^hasHeightM(?b,?h)^swrlb:greaterThan(?h,80)->violatesMaxHeight(?b,true)" ;
    dgm-spike:ruleId "R_BUILDING_MAX_HEIGHT_80_V" ;
    dgm-spike:ruleKind "violation" .

dgm-spike:R_LIVINGUNIT_MIN_WINDOW_2_V a dgm-spike:Rule,
        owl:NamedIndividual ;
    rdfs:label "R_LIVINGUNIT_MIN_WINDOW_2_V"@en ;
    dg:graph dgm-spike:Metagraph ;
    dg:project "TestA" ;
    dgm-spike:SWRL "LivingUnit(?u)^hasWindowCount(?u,?w)^swrlb:lessThan(?w,2)->violatesMinWindowCount(?u,true)" ;
    dgm-spike:ruleId "R_LIVINGUNIT_MIN_WINDOW_2_V" ;
    dgm-spike:ruleKind "violation" .

dgm-spike:R_STREET_MIN_WIDTH_18_V a dgm-spike:Rule,
