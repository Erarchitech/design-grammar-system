dg:DS_def_h25_w12 a dg:ParamState,
        owl:NamedIndividual ;
    rdfs:label "ParamState: height=25, width=12"@en ;
    dg:graph dgv:Validgraph ;
    dg:project "TestA" ;
    dgv:hasIdRef dgv:IDR_DS_def_h25_w12 ;
    dgv:stateId "DS_def_h25_w12" ;
    rdfs:comment "Parametric capture of a Building configuration. Changes in this ParamState regenerate the linked IdRef per CMPST-05."@en .

dg:Object_Frame a dg:Object,
        owl:NamedIndividual ;
    rdfs:label "Frame"@en ;
    dg:graph dgc:Computgraph ;
    dg:hasBehavior dg:Behavior_Frame ;
    dg:hasStructure dg:Structure_Frame ;
    dg:objectName "Frame" .

dg:SWRL_label a owl:AnnotationProperty ;
    rdfs:label "SWRL label"@en ;
    rdfs:comment "Display label used in SWRL expressions for datatype properties and atoms."@en .

