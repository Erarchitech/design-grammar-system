<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_LIVINGUNIT_MIN_AREA_30_V_A3> a swrl:BuiltinAtom ;
    swrl:arguments ( <http://example.org/design-grammar/project/v8-ui-smoke/var/a> 30.0 ) ;
