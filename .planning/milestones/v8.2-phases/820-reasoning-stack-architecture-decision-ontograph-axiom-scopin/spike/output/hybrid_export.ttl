    swrl:propertyPredicate ex:hasGridType .

<http://example.org/design-grammar/project/v8-ui-smoke/atom/R_FACADE_GRID_HEX_V_A3> a swrl:BuiltinAtom ;
    swrl:arguments ( <http://example.org/design-grammar/project/v8-ui-smoke/var/g> "hexagonal"^^xsd:string ) ;
