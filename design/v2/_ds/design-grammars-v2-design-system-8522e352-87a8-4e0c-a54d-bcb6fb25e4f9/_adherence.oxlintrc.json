{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/display/**",
              "components/forms/**",
              "components/surfaces/**",
              "ui_kits/design-grammars/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono|Oswald))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono, Oswald."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|soft|outline|signal)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'soft' | 'outline' | 'signal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|selected|disabled|children|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, selected, disabled, children, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|title|subtitle|detail|signal|marker|style|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: date, title, subtitle, detail, signal, marker, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|checked|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, checked, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|onRemove|children|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: selected, onRemove, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|style|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: label, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Collapsible'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|count|open|onToggle|signal|children|style|key|ref|className|style|children)$/]",
        "message": "<Collapsible> doesn't accept that prop. Declared props: label, count, open, onToggle, signal, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|open|onClose|footer|children|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: title, open, onClose, footer, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|placeholder|value|mono|invalid|type|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, placeholder, value, mono, invalid, type, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KVRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|mono|style|key|ref|className|style|children)$/]",
        "message": "<KVRow> doesn't accept that prop. Declared props: label, value, mono, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|frost|children|style|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, frost, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Progress'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|steps|style|key|ref|className|style|children)$/]",
        "message": "<Progress> doesn't accept that prop. Declared props: value, steps, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PropertiesTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:rows|editable|style|key|ref|className|style|children)$/]",
        "message": "<PropertiesTable> doesn't accept that prop. Declared props: rows, editable, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:ruleId|date|kind|active|onSelect|onDelete|style|key|ref|className|style|children)$/]",
        "message": "<RunTile> doesn't accept that prop. Declared props: ruleId, date, kind, active, onSelect, onDelete, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|shortcut|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: placeholder, shortcut, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|showValue|unit|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, value, onChange, showValue, unit, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, active, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|value|rows|mono|readOnly|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: label, placeholder, value, rows, mono, readOnly, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tile'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|thumbnail|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Tile> doesn't accept that prop. Declared props: title, description, thumbnail, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
