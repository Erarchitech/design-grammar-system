    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Pat_11_TopChord">
        <rdf:type rdf:resource="&dgc;Pattern"/>
        <rdfs:label xml:lang="en">11_Pat_TopChord</rdfs:label>
        <dgc:patternName>11_Pat_TopChord</dgc:patternName>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
        <dgc:hasParameter rdf:resource="&dgc;Var_11_HTotal"/>
        <dgc:hasParameter rdf:resource="&dgc;Const_11_TrussConfig"/>
    </owl:NamedIndividual>

    <!-- === PATTERNS (Procedure 12) === -->

    <owl:NamedIndividual rdf:about="&dgc;Pat_12_FooterBottomLines">
        <rdf:type rdf:resource="&dgc;Pattern"/>
