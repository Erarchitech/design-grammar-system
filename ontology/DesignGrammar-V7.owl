    <!-- ************************************************************
         v3.1 EXAMPLE INSTANCES — ObjectInstance, ObjState, GeoRef, IdRef, ValidationEntity
         Illustrative ABox demonstrating the v3.0 composable-state structure.
         Project: TestA. Linked to existing VRun_a5671cb1bd30.
         ************************************************************ -->

    <owl:NamedIndividual rdf:about="&dgv;OI_Building_b1">
        <rdf:type rdf:resource="&dgv;ObjectInstance"/>
        <rdfs:label xml:lang="en">ObjectInstance: Building #1</rdfs:label>
        <rdfs:comment xml:lang="en">Cross-rule identity for the first Building in the TestA model. Bound to Object variable ?b via its ObjState.</rdfs:comment>
        <dgv:instanceId>OI_Building_b1</dgv:instanceId>
        <dgv:hasObjState rdf:resource="&dg;OS_b1_var_b"/>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;Validgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;OS_b1_var_b">
        <rdf:type rdf:resource="&dg;ObjState"/>
        <rdfs:label xml:lang="en">ObjState: OI_Building_b1 ↔ ?b</rdfs:label>
        <rdfs:comment xml:lang="en">Binding snapshot pairing OI_Building_b1 with Object variable ?b (var_b) and its current GeoRef set. State_Id computed as OS_&lt;SHA256(projectId + objectInstanceId + variableName)&gt; per CMPST-07.</rdfs:comment>
        <dgv:stateId>OS_a1b2c3d4</dgv:stateId>
        <dgv:objectRefName>obj-9f3e2a</dgv:objectRefName>
        <dgv:representsInstance rdf:resource="&dgv;OI_Building_b1"/>
        <dgv:hasObjectVariable rdf:resource="&dgm;var_b"/>
        <dgv:hasGeoRef rdf:resource="&dgv;GR_geom_1"/>
        <dgv:hasGeoRef rdf:resource="&dgv;GR_geom_2"/>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;Validgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;GR_geom_1">
        <rdf:type rdf:resource="&dgv;GeoRef"/>
        <rdfs:label xml:lang="en">GeoRef: obj:xyz1</rdfs:label>
        <rdfs:comment xml:lang="en">External source-system object handle for the primary mass geometry of Building #1.</rdfs:comment>
        <dgv:geoRefId>obj:xyz1</dgv:geoRefId>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;Validgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;GR_geom_2">
        <rdf:type rdf:resource="&dgv;GeoRef"/>
        <rdfs:label xml:lang="en">GeoRef: obj:xyz2</rdfs:label>
        <rdfs:comment xml:lang="en">External source-system object handle for the roof geometry of Building #1.</rdfs:comment>
        <dgv:geoRefId>obj:xyz2</dgv:geoRefId>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;Validgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;DS_def_h25_w12">
        <rdf:type rdf:resource="&dg;ParamState"/>
        <rdfs:label xml:lang="en">ParamState: height=25, width=12</rdfs:label>
        <rdfs:comment xml:lang="en">Parametric capture of a Building configuration. Changes in this ParamState regenerate the linked IdRef per CMPST-05.</rdfs:comment>
        <dgv:stateId>DS_def_h25_w12</dgv:stateId>
        <dgv:hasIdRef rdf:resource="&dgv;IDR_DS_def_h25_w12"/>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;Validgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;IDR_DS_def_h25_w12">
        <rdf:type rdf:resource="&dgv;IdRef"/>
        <rdfs:label xml:lang="en">IdRef for DS_def_h25_w12</rdfs:label>
        <rdfs:comment xml:lang="en">Auto-generated identifier for ParamState DS_def_h25_w12 (CMPST-08). Resolves to OI_Building_b1 for cross-run tracking (INTG-03). Will regenerate if any slider value in the ParamState changes.</rdfs:comment>
        <dgv:idRefValue>IDR_a1b2c3d4e5f6</dgv:idRefValue>
        <dgv:resolvesTo rdf:resource="&dgv;OI_Building_b1"/>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;Validgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;VEntity_a5671cb1bd30_b1_height">
        <rdf:type rdf:resource="&dgv;ValidationEntity"/>
        <rdfs:label xml:lang="en">Entity: Building #1 height check (passed)</rdfs:label>
        <rdfs:comment xml:lang="en">Per-rule, per-instance validation result cell. Records that Building #1 passed R_BUILDING_MAX_HEIGHT_75_V with a measured height value of 25 (the propValue — SCHM-05). Belongs to run a5671cb1bd30.</rdfs:comment>
        <dgv:dgEntityId>VE_a5671cb1bd30_b1_height</dgv:dgEntityId>
        <dgv:displayName>Building #1</dgv:displayName>
        <dgv:ruleId>R_BUILDING_MAX_HEIGHT_75_V</dgv:ruleId>
        <dgv:status rdf:resource="&dgv;Status_Passed"/>
        <dgv:propValue>25</dgv:propValue>
        <dgv:propValueOf rdf:resource="&dgm;var_h"/>
        <dgv:validatesInstance rdf:resource="&dgv;OI_Building_b1"/>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;Validgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;VEntity_a5671cb1bd30_b1_overflow">
        <rdf:type rdf:resource="&dgv;ValidationEntity"/>
        <rdfs:label xml:lang="en">Entity: Building #1 height check (failed example)</rdfs:label>
        <rdfs:comment xml:lang="en">Illustrative failing case: same ObjectInstance, different parametric run, height exceeded the 75m limit (value 80). Shows that ObjectInstance can be referenced by multiple ValidationEntities — one per (Run × Rule).</rdfs:comment>
        <dgv:dgEntityId>VE_a5671cb1bd30_b1_overflow</dgv:dgEntityId>
        <dgv:displayName>Building #1</dgv:displayName>
        <dgv:ruleId>R_BUILDING_MAX_HEIGHT_75_V</dgv:ruleId>
        <dgv:status rdf:resource="&dgv;Status_Failed"/>
        <dgv:propValue>80</dgv:propValue>
        <dgv:propValueOf rdf:resource="&dgm;var_h"/>
        <dgv:validatesInstance rdf:resource="&dgv;OI_Building_b1"/>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;Validgraph"/>
    </owl:NamedIndividual>

    <!-- Wire the example ValidationEntities into VRun_a5671cb1bd30 (HAS_ENTITY) -->
    <rdf:Description rdf:about="&dgv;VRun_a5671cb1bd30">
        <dgv:hasEntity rdf:resource="&dgv;VEntity_a5671cb1bd30_b1_height"/>
        <dgv:hasEntity rdf:resource="&dgv;VEntity_a5671cb1bd30_b1_overflow"/>
    </rdf:Description>

    <!-- ============================================================

         LAYER 4: KNOWLEDGE GRAPH
         Classes for project knowledge storage — notes, tags,
         sessions, and parent class hub nodes.

         ============================================================ -->

    <owl:Class rdf:about="&dgs;SpecClass">
        <rdfs:label xml:lang="en">SpecClass</rdfs:label>
        <rdfs:comment xml:lang="en">Parent hub node connecting all instances of a knowledge type. Acts as a type discriminator (e.g. SpecNote, Session).</rdfs:comment>
        <dg:graph rdf:resource="&dgs;SpecGraph"/>
        <rdfs:subClassOf rdf:resource="&dgs;SpecGraph"/>
    </owl:Class>

    <owl:Class rdf:about="&dgs;SpecNote">
        <rdfs:label xml:lang="en">SpecNote</rdfs:label>
        <rdfs:comment xml:lang="en">A project knowledge entry (from folder ingest or NL prompt). Contains title, content, tags, and source reference.</rdfs:comment>
        <dg:graph rdf:resource="&dgs;SpecGraph"/>
        <rdfs:subClassOf rdf:resource="&dgs;SpecGraph"/>
    </owl:Class>

    <owl:Class rdf:about="&dgs;SpecTag">
        <rdfs:label xml:lang="en">SpecTag</rdfs:label>
        <rdfs:comment xml:lang="en">A tag label shared across knowledge notes for categorization. Aligned with: skos:Concept (R5) — a Tag IS a concept in a project's tag taxonomy.</rdfs:comment>
        <dg:graph rdf:resource="&dgs;SpecGraph"/>
        <rdfs:subClassOf rdf:resource="&dgs;SpecGraph"/>
    </owl:Class>


    <!-- SpecGraph datatype properties -->

    <owl:DatatypeProperty rdf:about="&dgs;noteId">
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:label xml:lang="en">noteId</rdfs:label>
        <rdfs:comment xml:lang="en">Unique identifier for a knowledge note. Characteristics: Functional. Aligned with: dcterms:identifier (R5).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgs;SpecNote"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgs;title">
        <rdfs:label xml:lang="en">title</rdfs:label>
        <rdfs:comment xml:lang="en">Title of a knowledge note. Aligned with: dcterms:title (R5).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgs;SpecNote"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgs;content">
        <rdfs:label xml:lang="en">content</rdfs:label>
        <rdfs:comment xml:lang="en">Full text content of a knowledge note. Aligned with: skos:note (R5) — the SKOS pattern for the textual body of a concept-related artifact.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgs;SpecNote"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgs;source">
        <rdfs:label xml:lang="en">source</rdfs:label>
        <rdfs:comment xml:lang="en">Source file path or reference for a knowledge note (e.g. notes/site.md). Aligned with: dcterms:source (R5).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgs;SpecNote"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgs;tags">
        <rdfs:label xml:lang="en">tags</rdfs:label>
        <rdfs:comment xml:lang="en">Array of tag names associated with a knowledge note (stored as Neo4j list property).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgs;SpecNote"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgs;tagName">
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:label xml:lang="en">name</rdfs:label>
        <rdfs:comment xml:lang="en">Tag name string (e.g. "zoning", "structural"). Characteristics: Functional — one canonical name per Tag. Aligned with: skos:prefLabel (R5) — the SKOS canonical label for a concept.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgs;SpecTag"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>



    <owl:DatatypeProperty rdf:about="&dgs;createdAt">
        <rdfs:label xml:lang="en">createdAt</rdfs:label>
        <rdfs:comment xml:lang="en">ISO 8601 UTC timestamp of creation. Aligned with: dcterms:created (R5).</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;dateTime"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgs;updatedAt">
        <rdfs:label xml:lang="en">updatedAt</rdfs:label>
        <rdfs:comment xml:lang="en">ISO 8601 UTC timestamp of last update. Aligned with: dcterms:modified (R5).</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;dateTime"/>
    </owl:DatatypeProperty>

    <!-- SpecGraph object properties -->

    <owl:ObjectProperty rdf:about="&dgs;taggedWith">
        <rdfs:label xml:lang="en">TAGGED_WITH</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a SpecNote to its SpecTag nodes. Characteristics: none (many-to-many — a Note has multiple Tags, a Tag is reused across Notes).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgs;SpecNote"/>
        <rdfs:range rdf:resource="&dgs;SpecTag"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&dgs;instanceOf">
        <rdf:type rdf:resource="&owl;FunctionalProperty"/>
        <rdfs:label xml:lang="en">INSTANCE_OF</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a SpecNote or Session to its parent SpecClass hub node. Characteristics: Functional — each Note/Session has exactly one parent hub.</rdfs:comment>
        <rdfs:range rdf:resource="&dgs;SpecClass"/>
    </owl:ObjectProperty>

