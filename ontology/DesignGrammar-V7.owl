        <dgc:procedureOrder rdf:datatype="&xsd;integer">12</dgc:procedureOrder>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
        <dgc:hasPattern rdf:resource="&dgc;Pat_12_FooterBottomLines"/>
