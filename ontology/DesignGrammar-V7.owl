    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Emg_11_UpperChord">
        <rdf:type rdf:resource="&dgc;EmergentParam"/>
        <rdfs:label xml:lang="en">11_Emr_UpperChord</rdfs:label>
        <dgc:parameterName>11_Emr_UpperChord</dgc:parameterName>
        <dgc:parameterDisplayName>Upper chord geometry</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Geometry"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Emg_12_BottomLn">
        <rdf:type rdf:resource="&dgc;EmergentParam"/>
        <rdfs:label xml:lang="en">12_Emg_BottomLn</rdfs:label>
        <dgc:parameterName>12_Emg_BottomLn</dgc:parameterName>
        <dgc:parameterDisplayName>Footer bottom lines</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Geometry"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Emg_12_FooterFrame">
        <rdf:type rdf:resource="&dgc;EmergentParam"/>
        <rdfs:label xml:lang="en">12_Emg_FooterFrame</rdfs:label>
        <dgc:parameterName>12_Emg_FooterFrame</dgc:parameterName>
        <dgc:parameterDisplayName>Footer frame geometry</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Geometry"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <!-- === INTERFACES (inter-procedure connectors) === -->

    <owl:NamedIndividual rdf:about="&dgc;IntF_11_ParSplitAt">
        <rdf:type rdf:resource="&dgc;Output"/>
        <rdfs:label xml:lang="en">11_IntF_ParSplitAt</rdfs:label>
        <dgc:interfaceName>11_IntF_ParSplitAt</dgc:interfaceName>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;IntF_11_TrussConfig">
        <rdf:type rdf:resource="&dgc;Output"/>
        <rdfs:label xml:lang="en">11_IntF_TrussConfig</rdfs:label>
        <dgc:interfaceName>11_IntF_TrussConfig</dgc:interfaceName>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;IntF_11_MergeRes">
        <rdf:type rdf:resource="&dgc;Output"/>
        <rdfs:label xml:lang="en">11_IntF_MergeRes</rdfs:label>
        <dgc:interfaceName>11_IntF_MergeRes</dgc:interfaceName>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;IntF_12_FooterFrame">
        <rdf:type rdf:resource="&dgc;Output"/>
        <rdfs:label xml:lang="en">12_IntF_FooterFrame</rdfs:label>
        <dgc:interfaceName>12_IntF_FooterFrame</dgc:interfaceName>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <!-- === PARAMETRIC STATE (snapshot of all parameter values) === -->


    <!-- ============================================================

         DISJOINTNESS AXIOMS
         v3.1 — ensure key class kinds are mutually disjoint so HermiT
         can catch misclassification (e.g. a node typed as both
         ObjState and IdRef would be flagged inconsistent).

         ============================================================ -->

    <!-- Validgraph: state and identity classes are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dg;ParamState"/>
            <owl:Class rdf:about="&dg;ObjState"/>
            <owl:Class rdf:about="&dg;PropState"/>
        </owl:members>
    </rdf:Description>

    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgv;ObjectInstance"/>
            <owl:Class rdf:about="&dg;ObjState"/>
            <owl:Class rdf:about="&dgv;IdRef"/>
            <owl:Class rdf:about="&dgv;GeoRef"/>
        </owl:members>
    </rdf:Description>

    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgv;Run"/>
            <owl:Class rdf:about="&dgv;ValidationEntity"/>
            <owl:Class rdf:about="&dgv;Reasoner"/>
            <owl:Class rdf:about="&dgv;DesignStateParameter"/>
            <owl:Class rdf:about="&dgv;IntegrationConfig"/>
            <owl:Class rdf:about="&dgv;ObjectInstance"/>
            <owl:Class rdf:about="&dgv;GeoRef"/>
            <owl:Class rdf:about="&dgv;IdRef"/>
        </owl:members>
    </rdf:Description>

    <!-- Metagraph: atom subtypes are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgm;ClassAtom"/>
            <owl:Class rdf:about="&dgm;DataPropertyAtom"/>
            <owl:Class rdf:about="&dgm;ObjectPropertyAtom"/>
            <owl:Class rdf:about="&dgm;BuiltinAtom"/>
        </owl:members>
    </rdf:Description>

    <!-- Metagraph: variable subtypes are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgm;ObjectVariable"/>
            <owl:Class rdf:about="&dgm;PropertyVariable"/>
            <owl:Class rdf:about="&dgm;BuiltinVariable"/>
        </owl:members>
    </rdf:Description>

    <!-- Metagraph: top-level node kinds are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgm;Rule"/>
            <owl:Class rdf:about="&dgm;Atom"/>
            <owl:Class rdf:about="&dgm;Variable"/>
            <owl:Class rdf:about="&dgm;Literal"/>
            <owl:Class rdf:about="&dgm;Builtin"/>
            <owl:Class rdf:about="&dgm;RuleSet"/>
        </owl:members>
    </rdf:Description>

    <!-- Ontograph: meta-level entity kinds are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dg;Class"/>
            <owl:Class rdf:about="&dg;DataProperty"/>
            <owl:Class rdf:about="&dg;ObjProperty"/>
        </owl:members>
    </rdf:Description>

    <!-- SpecGraph: knowledge node kinds are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgs;SpecClass"/>
            <owl:Class rdf:about="&dgs;SpecNote"/>
            <owl:Class rdf:about="&dgs;SpecTag"/>
        </owl:members>
    </rdf:Description>

    <!-- Enum classes are mutually exclusive (v4.1: VariableKindValue and DesignStateKindValue removed — their semantic role is now provided by class hierarchies + disjointUnionOf on Variable and DesignState) -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgm;VariableScopeValue"/>
            <owl:Class rdf:about="&dgv;DesignStateParameterTypeValue"/>
            <owl:Class rdf:about="&dgv;ValidationStatusValue"/>
            <owl:Class rdf:about="&dgv;ReStatusValue"/>
            <owl:Class rdf:about="&dgc;ParamDataTypeValue"/>
            <owl:Class rdf:about="&dgc;ListStructureValue"/>
        </owl:members>
    </rdf:Description>

    <!-- Computgraph: top-level node kinds are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgc;Algorithm"/>
            <owl:Class rdf:about="&dgc;Procedure"/>
            <owl:Class rdf:about="&dgc;Pattern"/>
            <owl:Class rdf:about="&dgc;Parameter"/>
            <owl:Class rdf:about="&dgc;Interface"/>
        </owl:members>
    </rdf:Description>

    <!-- Computgraph: parameter subtypes are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgc;VariableParam"/>
            <owl:Class rdf:about="&dgc;ConstantParam"/>
            <owl:Class rdf:about="&dgc;EmergentParam"/>
        </owl:members>
    </rdf:Description>

    <!-- Computgraph: interface subtypes are mutually exclusive -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dgc;Input"/>
            <owl:Class rdf:about="&dgc;Output"/>
        </owl:members>
    </rdf:Description>

    <!-- Core: over-layer main entities are mutually exclusive (v6.0) -->
    <rdf:Description>
        <rdf:type rdf:resource="&owl;AllDisjointClasses"/>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="&dg;Object"/>
            <owl:Class rdf:about="&dg;Function"/>
            <owl:Class rdf:about="&dg;Behavior"/>
            <owl:Class rdf:about="&dg;Structure"/>
            <owl:Class rdf:about="&dg;Geometry"/>
            <owl:Class rdf:about="&dg;Topology"/>
            <owl:Class rdf:about="&dg;DesignState"/>
            <owl:Class rdf:about="&dg;Session"/>
        </owl:members>
    </rdf:Description>

    <!-- ============================================================

         COMMON PROPERTIES (cross-layer)
         Properties used across all graph layers.

         ============================================================ -->

    <owl:DatatypeProperty rdf:about="&dg;createdAt">
        <rdfs:label xml:lang="en">createdAt</rdfs:label>
        <rdfs:comment xml:lang="en">ISO 8601 UTC timestamp of node creation. Used across all graph layers. Aligned with: dcterms:created (R5/R7 — cross-cutting Dublin Core creation timestamp).</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;dateTime"/>
    </owl:DatatypeProperty>
</rdf:RDF>
