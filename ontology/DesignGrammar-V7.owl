        <dgc:patternName>12_Pat_1 - Create footer bottom lines</dgc:patternName>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
        <dgc:hasParameter rdf:resource="&dgc;Var_12_HFooter"/>
        <dgc:hasParameter rdf:resource="&dgc;Const_12_IndList_1"/>
    </owl:NamedIndividual>

    <!-- === PARAMETERS: Variables (user-adjustable) === -->

    <owl:NamedIndividual rdf:about="&dgc;Var_11_SpansCount">
        <rdf:type rdf:resource="&dgc;VariableParam"/>
        <rdfs:label xml:lang="en">11_Var_SpansCount</rdfs:label>
        <dgc:parameterName>11_Var_SpansCount</dgc:parameterName>
        <dgc:parameterDisplayName>Count of spans</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Integer"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Var_11_HTotal">
        <rdf:type rdf:resource="&dgc;VariableParam"/>
        <rdfs:label xml:lang="en">11_Var_HTotal</rdfs:label>
        <dgc:parameterName>11_Var_HTotal</dgc:parameterName>
        <dgc:parameterDisplayName>Total height</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Float"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Var_12_HFooter">
        <rdf:type rdf:resource="&dgc;VariableParam"/>
        <rdfs:label xml:lang="en">12_Var_HFooter</rdfs:label>
        <dgc:parameterName>12_Var_HFooter</dgc:parameterName>
        <dgc:parameterDisplayName>Footer height</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Float"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Var_12_FooterCount">
        <rdf:type rdf:resource="&dgc;VariableParam"/>
        <rdfs:label xml:lang="en">12_Var_FooterCount</rdfs:label>
        <dgc:parameterName>12_Var_FooterCount</dgc:parameterName>
        <dgc:parameterDisplayName>Footer count</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Integer"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <!-- === PARAMETERS: Constants (fixed values) === -->

    <owl:NamedIndividual rdf:about="&dgc;Const_11_ptZero">
        <rdf:type rdf:resource="&dgc;ConstantParam"/>
        <rdfs:label xml:lang="en">11_Const_ptZero</rdfs:label>
        <dgc:parameterName>11_Const_ptZero</dgc:parameterName>
        <dgc:parameterDisplayName>Origin point</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Geometry"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Const_11_TrussConfig">
        <rdf:type rdf:resource="&dgc;ConstantParam"/>
        <rdfs:label xml:lang="en">11_Const_TrussConfig</rdfs:label>
        <dgc:parameterName>11_Const_TrussConfig</dgc:parameterName>
        <dgc:parameterDisplayName>Truss web configuration</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Integer"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Const_12_IndList_1">
        <rdf:type rdf:resource="&dgc;ConstantParam"/>
        <rdfs:label xml:lang="en">12_Const_IndList_1</rdfs:label>
        <dgc:parameterName>12_Const_IndList_1</dgc:parameterName>
        <dgc:parameterDisplayName>Index list 1</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Integer"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgc;Const_12_TrussConfig">
        <rdf:type rdf:resource="&dgc;ConstantParam"/>
        <rdfs:label xml:lang="en">12_Const_TrussConfig</rdfs:label>
        <dgc:parameterName>12_Const_TrussConfig</dgc:parameterName>
        <dgc:parameterDisplayName>Truss configuration (footer)</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Integer"/>
        <dg:graph rdf:resource="&dgc;Computgraph"/>
    </owl:NamedIndividual>

    <!-- === PARAMETERS: Emergent (computed outputs) === -->

    <owl:NamedIndividual rdf:about="&dgc;Emg_11_LineSDL">
        <rdf:type rdf:resource="&dgc;EmergentParam"/>
        <rdfs:label xml:lang="en">11_Emg_LineSDL</rdfs:label>
        <dgc:parameterName>11_Emg_LineSDL</dgc:parameterName>
        <dgc:parameterDisplayName>Line SDL (computed)</dgc:parameterDisplayName>
        <dgc:paramDataType rdf:resource="&dgc;ParamDataType_Geometry"/>
