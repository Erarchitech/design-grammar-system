dgsh:ProcedureShape
    a sh:NodeShape ;
    sh:targetClass dgc:Procedure ;
    sh:property dgsh:ProcedureShape_procedureName,
                dgsh:ProcedureShape_procIndex,
                dgsh:ProcedureShape_project .

dgsh:ProcedureShape_procedureName
    sh:path dgc:procedureName ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Violation ;
    sh:message "A Procedure node is missing its procedureName — every procedure must have a display name." ;
    dgsh:howToFix "Ensure the entity carries a procedureName before publishing." .

dgsh:ProcedureShape_procIndex
    sh:path dgc:procIndex ;
    sh:minCount 1 ;
    sh:datatype xsd:integer ;
    sh:severity sh:Violation ;
    sh:message "A Procedure node is missing its procIndex — every procedure must carry its position within the algorithm." ;
    dgsh:howToFix "Set procIndex to the integer position of this procedure within its parent algorithm." .

dgsh:ProcedureShape_project
    sh:path dgc:project ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Violation ;
    sh:message "A Procedure node is missing the project property — every node must carry project isolation." ;
    dgsh:howToFix "Set project on the Procedure node to the owning project." .

#############################################
# 15. Pattern — Computgraph runtime entity (Phase 36)
#############################################
dgsh:PatternShape
    a sh:NodeShape ;
    sh:targetClass dgc:Pattern ;
    sh:property dgsh:PatternShape_patternName,
                dgsh:PatternShape_project .

dgsh:PatternShape_patternName
    sh:path dgc:patternName ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Violation ;
    sh:message "A Pattern node is missing its patternName — every pattern must have a display name." ;
    dgsh:howToFix "Ensure the entity carries a patternName before publishing." .

dgsh:PatternShape_project
    sh:path dgc:project ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Violation ;
    sh:message "A Pattern node is missing the project property — every node must carry project isolation." ;
    dgsh:howToFix "Set project on the Pattern node to the owning project." .

#############################################
# 16. Parameter — Computgraph runtime entity (Phase 36)
#############################################
dgsh:ParameterShape
    a sh:NodeShape ;
    sh:targetClass dgc:Parameter ;
    sh:property dgsh:ParameterShape_parameterName,
                dgsh:ParameterShape_paramKind,
                dgsh:ParameterShape_dataType,
                dgsh:ParameterShape_project .

dgsh:ParameterShape_parameterName
    sh:path dgc:parameterName ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Violation ;
    sh:message "A Parameter node is missing its parameterName — every parameter must have a display name." ;
    dgsh:howToFix "Ensure the entity carries a parameterName before publishing." .

dgsh:ParameterShape_paramKind
    sh:path dgc:paramKind ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:in ("Variable" "Constant" "Emergent") ;
    sh:severity sh:Violation ;
    sh:message "A Parameter node has a missing or invalid paramKind — must be Variable, Constant, or Emergent." ;
    dgsh:howToFix "Set paramKind to Variable (user-adjustable), Constant (fixed), or Emergent (derived during computation)." .

dgsh:ParameterShape_dataType
    sh:path dgc:dataType ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:in ("Float" "Integer" "Text" "Boolean" "Geometry") ;
    sh:severity sh:Violation ;
    sh:message "A Parameter node has a missing or invalid dataType — must be Float, Integer, Text, Boolean, or Geometry." ;
    dgsh:howToFix "Set dataType to one of the supported types: Float, Integer, Text, Boolean, or Geometry." .

dgsh:ParameterShape_project
    sh:path dgc:project ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Violation ;
    sh:message "A Parameter node is missing the project property — every node must carry project isolation." ;
    dgsh:howToFix "Set project on the Parameter node to the owning project." .

#############################################
# 17. Interface — Computgraph runtime entity (Phase 36)
#############################################
dgsh:InterfaceShape
    a sh:NodeShape ;
    sh:targetClass dgc:Interface ;
    sh:property dgsh:InterfaceShape_interfaceName,
                dgsh:InterfaceShape_ifaceType,
                dgsh:InterfaceShape_project .

dgsh:InterfaceShape_interfaceName
    sh:path dgc:interfaceName ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Violation ;
    sh:message "An Interface node is missing its interfaceName — every interface must have a display name." ;
    dgsh:howToFix "Ensure the entity carries an interfaceName before publishing." .

dgsh:InterfaceShape_ifaceType
    sh:path dgc:ifaceType ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:in ("Input" "Output") ;
    sh:severity sh:Violation ;
    sh:message "An Interface node has a missing or invalid ifaceType — must be Input or Output." ;
    dgsh:howToFix "Set ifaceType to Input (receiving data) or Output (producing data)." .

dgsh:InterfaceShape_project
    sh:path dgc:project ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:severity sh:Violation ;
    sh:message "An Interface node is missing the project property — every node must carry project isolation." ;
    dgsh:howToFix "Set project on the Interface node to the owning project." .
