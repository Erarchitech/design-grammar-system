         ************************************************************ -->

    <owl:NamedIndividual rdf:about="&dgk;Session_ks_mnq4ixld">
        <rdf:type rdf:resource="&dgk;KnowledgeSession"/>
        <rdfs:label xml:lang="en">Query: Where buidling is located</rdfs:label>
