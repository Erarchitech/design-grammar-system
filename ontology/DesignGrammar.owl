        <dgm:ruleKind>violation</dgm:ruleKind>
        <dgm:ruleText>Street(?s)^hasWidthM(?s,?w)^swrlb:lessThan(?w,18)-&gt;violatesMinWidth(?s,true)</dgm:ruleText>
        <dg:graph>Metagraph</dg:graph>
        <dg:project>TestA</dg:project>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;R_UNIT_MIN_WINDOW_2_V">
        <rdf:type rdf:resource="&dgm;Rule"/>
