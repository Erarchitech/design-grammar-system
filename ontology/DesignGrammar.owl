    <!-- ============================================================

         LAYER 3: VALIDATION GRAPH
         Classes controlling validation data flow between the
         DG Grasshopper plugin, data-service, and Speckle viewer.

         ============================================================ -->

    <owl:Class rdf:about="&dgv;IntegrationConfig">
        <rdfs:label xml:lang="en">IntegrationConfig</rdfs:label>
        <rdfs:comment xml:lang="en">Configuration node linking a DG project to its Speckle integration. Stores Speckle project ID, base model, and validation model references. One per project per provider.</rdfs:comment>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgv;ValidationRun">
        <rdfs:label xml:lang="en">ValidationRun</rdfs:label>
        <rdfs:comment xml:lang="en">A single execution of rule evaluation against design state. Records which rules were evaluated, the Speckle version created, and entity-level pass/fail results. Created by the DG Grasshopper plugin's validation workflow.</rdfs:comment>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgv;ValidationEntity">
        <rdfs:label xml:lang="en">ValidationEntity</rdfs:label>
        <rdfs:comment xml:lang="en">A BIM entity evaluated in a validation run. Records the entity's DG ID, display name, and overall pass/fail status for the specific run and rule.</rdfs:comment>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgv;DesignState">
        <rdfs:label xml:lang="en">DesignState</rdfs:label>
        <rdfs:comment xml:lang="en">A snapshot of design parameters captured from Grasshopper. Single Neo4j label :DesignState with a `kind` property discriminating between DefState and ObjectState. ID prefixes: DS_ (DefState), OS_ (ObjectState). Used as input to CLASSIFICATOR and persisted in validation runs.</rdfs:comment>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgv;DefState">
        <rdfs:label xml:lang="en">DefState</rdfs:label>
        <rdfs:comment xml:lang="en">Definition state — a named set of Number/Integer/Boolean parameters captured from Grasshopper sliders and toggles. Represents the current parametric configuration. When DefState changes, dependent IdRefs regenerate. ID prefix: DS_.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="&dgv;DesignState"/>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgv;ObjectState">
        <rdfs:label xml:lang="en">ObjectState</rdfs:label>
        <rdfs:comment xml:lang="en">Object state — associates an Object variable reference (from SWRL ClassAtom) with geometry elements. Created by the OBJECT STATE component by wiring ObjectRef + GeoRef. Composed into DESIGN STATE alongside DefState to produce stable IdRefs. ID prefix: OS_.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="&dgv;DesignState"/>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgv;DesignStateParameter">
        <rdfs:label xml:lang="en">DesignStateParameter</rdfs:label>
        <rdfs:comment xml:lang="en">A single measurable parameter within a DefState snapshot. Has a parameterId, displayName, type (Number/Integer/Boolean), and the corresponding typed value.</rdfs:comment>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <!-- ValidationGraph datatype properties -->

    <owl:DatatypeProperty rdf:about="&dgv;kind">
        <rdfs:label xml:lang="en">kind</rdfs:label>
        <rdfs:comment xml:lang="en">DesignState kind discriminator. Values: 'DefState' (parameter snapshot from sliders/toggles) or 'ObjectState' (object variable + geometry association). Stored on the single :DesignState Neo4j label.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;DesignState"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;objectRef">
        <rdfs:label xml:lang="en">objectRef</rdfs:label>
        <rdfs:comment xml:lang="en">Object variable reference string for an ObjectState (e.g. the variable name from a ClassAtom). Links this ObjectState to the SWRL Object variable it represents.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ObjectState"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;runId">
        <rdfs:label xml:lang="en">runId</rdfs:label>
        <rdfs:comment xml:lang="en">Unique identifier for a validation run.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationRun"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;speckleProjectId">
        <rdfs:label xml:lang="en">speckleProjectId</rdfs:label>
        <rdfs:comment xml:lang="en">ID of the linked Speckle project.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;baseModelId">
        <rdfs:label xml:lang="en">baseModelId</rdfs:label>
        <rdfs:comment xml:lang="en">ID of the base geometry model in Speckle.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;baseModelName">
        <rdfs:label xml:lang="en">baseModelName</rdfs:label>
        <rdfs:comment xml:lang="en">Display name of the base geometry model in Speckle.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;IntegrationConfig"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;validationModelId">
        <rdfs:label xml:lang="en">validationModelId</rdfs:label>
        <rdfs:comment xml:lang="en">ID of the validation overlay model in Speckle.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;baseVersionId">
        <rdfs:label xml:lang="en">baseVersionId</rdfs:label>
        <rdfs:comment xml:lang="en">Speckle version ID of the base model used in this validation run.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationRun"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;validationVersionId">
        <rdfs:label xml:lang="en">validationVersionId</rdfs:label>
        <rdfs:comment xml:lang="en">Speckle version ID of the validation overlay created by this run.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationRun"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;modelViewerUrl">
        <rdfs:label xml:lang="en">modelViewerUrl</rdfs:label>
        <rdfs:comment xml:lang="en">URL to view the validation results in the Model Viewer.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationRun"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;rulesJson">
        <rdfs:label xml:lang="en">rulesJson</rdfs:label>
        <rdfs:comment xml:lang="en">JSON-serialized array of rules evaluated in this run.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationRun"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;statePayloadJson">
        <rdfs:label xml:lang="en">statePayloadJson</rdfs:label>
        <rdfs:comment xml:lang="en">JSON-serialized DesignState snapshot used as input to this run.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationRun"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;status">
        <rdfs:label xml:lang="en">status</rdfs:label>
        <rdfs:comment xml:lang="en">Status of a validation run ('completed') or entity result ('passed'/'failed').</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;dgEntityId">
        <rdfs:label xml:lang="en">dgEntityId</rdfs:label>
        <rdfs:comment xml:lang="en">Unique DG identifier for a BIM entity in a validation run.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationEntity"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;displayName">
        <rdfs:label xml:lang="en">displayName</rdfs:label>
        <rdfs:comment xml:lang="en">Human-readable name for a validation entity.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationEntity"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;ruleId">
        <rdfs:label xml:lang="en">ruleId</rdfs:label>
        <rdfs:comment xml:lang="en">Rule ID associated with a validation entity result.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationEntity"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;provider">
        <rdfs:label xml:lang="en">provider</rdfs:label>
        <rdfs:comment xml:lang="en">Integration provider name (e.g. 'Speckle').</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;IntegrationConfig"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;stateId">
        <rdfs:label xml:lang="en">stateId</rdfs:label>
        <rdfs:comment xml:lang="en">Unique identifier for a DesignState snapshot.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;DesignState"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;capturedAtUtc">
        <rdfs:label xml:lang="en">capturedAtUtc</rdfs:label>
        <rdfs:comment xml:lang="en">UTC timestamp when a design state or validation run was captured.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;dateTime"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;parameterId">
        <rdfs:label xml:lang="en">parameterId</rdfs:label>
        <rdfs:comment xml:lang="en">Identifier of a design state parameter (maps to a DatatypeProperty iri in the OntoGraph).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;DesignStateParameter"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgv;parameterType">
        <rdfs:label xml:lang="en">parameterType</rdfs:label>
        <rdfs:comment xml:lang="en">Type discriminator for parameter value: 'Number', 'Integer', or 'Boolean'.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;DesignStateParameter"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <!-- ValidationGraph object properties -->

    <owl:ObjectProperty rdf:about="&dgv;hasEntity">
        <rdfs:label xml:lang="en">HAS_ENTITY</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a ValidationRun to its evaluated ValidationEntity results.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;ValidationRun"/>
        <rdfs:range rdf:resource="&dgv;ValidationEntity"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&dgv;hasParameter">
        <rdfs:label xml:lang="en">HAS_PARAMETER</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a DesignState snapshot to its individual parameters.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgv;DesignState"/>
        <rdfs:range rdf:resource="&dgv;DesignStateParameter"/>
    </owl:ObjectProperty>

    <!-- ************************************************************
         VALIDATION ENUMERATIONS — DesignStateParameterType
         ************************************************************ -->

    <owl:Class rdf:about="&dgv;DesignStateParameterTypeValue">
        <rdfs:label xml:lang="en">DesignStateParameterType</rdfs:label>
        <rdfs:comment xml:lang="en">Enumeration of supported parameter value types for DesignState snapshots. Corresponds to C# enum DG.Core.Models.DesignStateParameterType.</rdfs:comment>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:NamedIndividual rdf:about="&dgv;ParameterType_Number">
        <rdf:type rdf:resource="&dgv;DesignStateParameterTypeValue"/>
        <rdfs:label xml:lang="en">Number</rdfs:label>
        <rdfs:comment xml:lang="en">Floating-point parameter value (double). From Number Sliders in Grasshopper.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;ParameterType_Integer">
        <rdf:type rdf:resource="&dgv;DesignStateParameterTypeValue"/>
        <rdfs:label xml:lang="en">Integer</rdfs:label>
        <rdfs:comment xml:lang="en">Integer parameter value (long). From Integer Sliders in Grasshopper.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;ParameterType_Boolean">
        <rdf:type rdf:resource="&dgv;DesignStateParameterTypeValue"/>
        <rdfs:label xml:lang="en">Boolean</rdfs:label>
        <rdfs:comment xml:lang="en">Boolean parameter value. From Boolean Toggles in Grasshopper.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ************************************************************
         VALIDATION ENUMERATIONS — ReinstatementStatus
         ************************************************************ -->

    <owl:Class rdf:about="&dgv;ReinstatementStatusValue">
        <rdfs:label xml:lang="en">ReinstatementStatus</rdfs:label>
        <rdfs:comment xml:lang="en">Outcome status for a single parameter during design state reinstatement. Corresponds to C# enum DG.Core.Models.ReinstatementStatus. Used by the REINSTATE component to report per-parameter results.</rdfs:comment>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:NamedIndividual rdf:about="&dgv;ReinstatementStatus_Applied">
        <rdf:type rdf:resource="&dgv;ReinstatementStatusValue"/>
        <rdfs:label xml:lang="en">Applied</rdfs:label>
        <rdfs:comment xml:lang="en">Parameter value was successfully applied to the target slider/toggle.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;ReinstatementStatus_MissingTarget">
        <rdf:type rdf:resource="&dgv;ReinstatementStatusValue"/>
        <rdfs:label xml:lang="en">MissingTarget</rdfs:label>
        <rdfs:comment xml:lang="en">No matching slider/toggle found on the canvas for this parameter.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;ReinstatementStatus_TypeMismatch">
        <rdf:type rdf:resource="&dgv;ReinstatementStatusValue"/>
        <rdfs:label xml:lang="en">TypeMismatch</rdfs:label>
        <rdfs:comment xml:lang="en">Target slider type does not match parameter type (e.g. Number param wired to Integer slider).</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;ReinstatementStatus_AmbiguousTarget">
        <rdf:type rdf:resource="&dgv;ReinstatementStatusValue"/>
        <rdfs:label xml:lang="en">AmbiguousTarget</rdfs:label>
        <rdfs:comment xml:lang="en">Multiple matching sliders/toggles found — cannot determine which to reinstate.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;ReinstatementStatus_OutOfRange">
        <rdf:type rdf:resource="&dgv;ReinstatementStatusValue"/>
        <rdfs:label xml:lang="en">OutOfRange</rdfs:label>
        <rdfs:comment xml:lang="en">Parameter value exceeds the target slider's min/max range.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;ReinstatementStatus_Unchanged">
        <rdf:type rdf:resource="&dgv;ReinstatementStatusValue"/>
        <rdfs:label xml:lang="en">Unchanged</rdfs:label>
        <rdfs:comment xml:lang="en">Target slider already has the requested value — no change needed.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;ReinstatementStatus_WouldApply">
        <rdf:type rdf:resource="&dgv;ReinstatementStatusValue"/>
        <rdfs:label xml:lang="en">WouldApply</rdfs:label>
        <rdfs:comment xml:lang="en">Dry-run mode — parameter would be applied if reinstatement were executed.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ************************************************************
         VALIDATION ENUMERATIONS — ValidationStatus
         ************************************************************ -->

    <owl:Class rdf:about="&dgv;ValidationStatusValue">
        <rdfs:label xml:lang="en">ValidationStatus</rdfs:label>
        <rdfs:comment xml:lang="en">Status values for validation runs and entity results.</rdfs:comment>
        <dg:graph>ValidationGraph</dg:graph>
    </owl:Class>

    <owl:NamedIndividual rdf:about="&dgv;Status_Completed">
        <rdf:type rdf:resource="&dgv;ValidationStatusValue"/>
        <rdfs:label xml:lang="en">completed</rdfs:label>
        <rdfs:comment xml:lang="en">Validation run finished successfully.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;Status_Passed">
        <rdf:type rdf:resource="&dgv;ValidationStatusValue"/>
        <rdfs:label xml:lang="en">passed</rdfs:label>
        <rdfs:comment xml:lang="en">Validation entity passed all rules — no violations detected.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgv;Status_Failed">
        <rdf:type rdf:resource="&dgv;ValidationStatusValue"/>
        <rdfs:label xml:lang="en">failed</rdfs:label>
        <rdfs:comment xml:lang="en">Validation entity failed one or more rules — violations detected.</rdfs:comment>
    </owl:NamedIndividual>

