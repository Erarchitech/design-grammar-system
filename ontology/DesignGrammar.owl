        <dgv:provider>Speckle</dgv:provider>
        <dgv:speckleProjectId>44088eefc6</dgv:speckleProjectId>
        <dgv:baseModelId>4c546c0771</dgv:baseModelId>
        <dgv:validationModelId>a6d1e0c5da</dgv:validationModelId>
        <dg:project>TestA</dg:project>
        <dg:graph rdf:resource="&dgv;ValidationGraph"/>
    </owl:NamedIndividual>

