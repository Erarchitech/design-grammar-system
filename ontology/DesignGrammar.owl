<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE rdf:RDF [
    <!ENTITY owl  "http://www.w3.org/2002/07/owl#">
    <!ENTITY rdf  "http://www.w3.org/1999/02/22-rdf-syntax-ns#">
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#">
    <!ENTITY xsd  "http://www.w3.org/2001/XMLSchema#">
    <!ENTITY dg   "http://example.org/design-grammar#">
    <!ENTITY dgm  "http://example.org/design-grammar/metagraph#">
    <!ENTITY dgv  "http://example.org/design-grammar/validation#">
    <!ENTITY dgk  "http://example.org/design-grammar/knowledge#">
]>

<rdf:RDF
    xmlns:rdf="&rdf;"
    xmlns:rdfs="&rdfs;"
    xmlns:owl="&owl;"
    xmlns:xsd="&xsd;"
    xmlns:dg="&dg;"
    xmlns:dgm="&dgm;"
    xmlns:dgv="&dgv;"
    xmlns:dgk="&dgk;"
    xml:base="http://example.org/design-grammar">

    <!-- ============================================================
         ONTOLOGY DECLARATION
         ============================================================ -->

    <owl:Ontology rdf:about="http://example.org/design-grammar">
        <rdfs:label xml:lang="en">Design Grammar System Ontology</rdfs:label>
        <rdfs:comment xml:lang="en">
            System-level ontology for the Design Grammar System (DG).
            Defines the common classes that control data flow in the DG Grasshopper
            plugin and Neo4j database. Domain-specific classes (Building, UrbanBlock, etc.)
            are dynamically generated from user prompts via the Grammar Viewer and are NOT
            part of this ontology.

            Graph layers:
            1. OntoGraph — dynamically generated domain classes and properties (not defined here)
            2. Metagraph — SWRL rule structure (Rule, Atom, Variable, Literal, Builtin)
            3. ValidationGraph — validation runs, entity results, integration config
            4. KnowledgeGraph — project knowledge notes, tags, sessions

            Schema version: v3
        </rdfs:comment>
        <owl:versionInfo>3.0</owl:versionInfo>
        <rdfs:seeAlso xml:lang="en">v3.0 requirements: Variable Typing (VTYP-01..04), Composable State (CMPST-01..05), Component Contracts (CTRCT-01..07), Schema &amp; Data (SCHM-01..04), Integration (INTG-01..03)</rdfs:seeAlso>
    </owl:Ontology>

    <!-- ============================================================
         ANNOTATION PROPERTIES
         ============================================================ -->

    <owl:AnnotationProperty rdf:about="&dg;SWRL_label">
        <rdfs:label xml:lang="en">SWRL label</rdfs:label>
        <rdfs:comment xml:lang="en">Display label used in SWRL expressions for datatype properties and atoms.</rdfs:comment>
    </owl:AnnotationProperty>

    <owl:AnnotationProperty rdf:about="&dg;graph">
        <rdfs:label xml:lang="en">graph layer</rdfs:label>
        <rdfs:comment xml:lang="en">Logical graph partition within the single Neo4j database. Values: OntoGraph, Metagraph, ValidationGraph, KnowledgeGraph.</rdfs:comment>
    </owl:AnnotationProperty>

    <owl:AnnotationProperty rdf:about="&dg;project">
        <rdfs:label xml:lang="en">project</rdfs:label>
        <rdfs:comment xml:lang="en">Project isolation key. Every persisted node must include this property for multi-project support.</rdfs:comment>
    </owl:AnnotationProperty>

    <!-- ============================================================

         GRAPH LAYERS
         The four logical partitions of the single Neo4j database.
         Each class in this ontology belongs to exactly one layer,
         identified by the dg:graph annotation. These named individuals
         make the layers explicit first-class entities.

         ============================================================ -->

    <owl:Class rdf:about="&dg;GraphLayer">
        <rdfs:label xml:lang="en">GraphLayer</rdfs:label>
        <rdfs:comment xml:lang="en">A logical partition of the single Neo4j database. The Design Grammar System organizes all persisted nodes into four layers: OntoGraph, Metagraph, ValidationGraph, KnowledgeGraph. Every node carries a `graph` property identifying its layer.</rdfs:comment>
    </owl:Class>

    <owl:NamedIndividual rdf:about="&dg;OntoGraph">
        <rdf:type rdf:resource="&dg;GraphLayer"/>
        <rdfs:label xml:lang="en">OntoGraph</rdfs:label>
        <rdfs:comment xml:lang="en">Dynamic domain ontology layer. Contains Class, DatatypeProperty, and ObjectProperty nodes generated from user prompts via LLM. These represent the project-specific domain vocabulary (e.g. Building, hasHeightM). Domain classes are NOT part of the system ontology — they are created at runtime.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;Metagraph">
        <rdf:type rdf:resource="&dg;GraphLayer"/>
        <rdfs:label xml:lang="en">Metagraph</rdfs:label>
        <rdfs:comment xml:lang="en">SWRL rule structure layer. Contains Rule, Atom, Variable (Object/Property), Literal, Builtin, and DesignRuleSession nodes. Rules reference OntoGraph entities via REFERS_TO. Per CTRCT-01: exposes Objects, DesignStates, and Runs as first-class outputs.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;ValidationGraphLayer">
        <rdf:type rdf:resource="&dg;GraphLayer"/>
        <rdfs:label xml:lang="en">ValidationGraph</rdfs:label>
        <rdfs:comment xml:lang="en">Validation data flow layer. Contains IntegrationConfig, ValidationRun, ValidationEntity, DesignState (DefState/ObjectState), and DesignStateParameter nodes. Manages the lifecycle from parameter capture through rule evaluation to Speckle publication.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;KnowledgeGraphLayer">
        <rdf:type rdf:resource="&dg;GraphLayer"/>
        <rdfs:label xml:lang="en">KnowledgeGraph</rdfs:label>
        <rdfs:comment xml:lang="en">Project knowledge storage layer. Contains KnowledgeNote, KnowledgeTag, KnowledgeSession, and KnowledgeClass nodes. Stores architectural knowledge ingested from project documentation or NL prompts.</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ============================================================

         LAYER 1: OntoGraph — DYNAMIC DOMAIN ONTOLOGY (meta-schema only)
         Domain classes (Class, DatatypeProperty, ObjectProperty) are
         generated dynamically from user prompts. This section defines
         only the meta-level node types that hold those dynamic entities.

         ============================================================ -->

    <owl:Class rdf:about="&dg;Class">
        <rdfs:label xml:lang="en">Class</rdfs:label>
        <rdfs:comment xml:lang="en">A dynamically generated OWL class in the OntoGraph layer. Created from user prompts (e.g. Building, UrbanBlock). Key property: iri.</rdfs:comment>
        <dg:graph>OntoGraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dg;DatatypeProperty">
        <rdfs:label xml:lang="en">DatatypeProperty</rdfs:label>
        <rdfs:comment xml:lang="en">A dynamically generated datatype property in the OntoGraph layer. Represents measurable attributes (e.g. hasHeightM) and violation flags (e.g. violatesMaxHeight). Key property: iri.</rdfs:comment>
        <dg:graph>OntoGraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dg;ObjectProperty">
        <rdfs:label xml:lang="en">ObjectProperty</rdfs:label>
        <rdfs:comment xml:lang="en">A dynamically generated object property in the OntoGraph layer. Represents relationships between domain classes (e.g. locatedIn). Key property: iri.</rdfs:comment>
        <dg:graph>OntoGraph</dg:graph>
    </owl:Class>

    <!-- OntoGraph node properties -->

    <owl:DatatypeProperty rdf:about="&dg;iri">
        <rdfs:label xml:lang="en">iri</rdfs:label>
        <rdfs:comment xml:lang="en">IRI identifier for ontology entities. Format: ex:&lt;Name&gt; (e.g. ex:Building, ex:hasHeightM).</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dg;label">
        <rdfs:label xml:lang="en">label</rdfs:label>
        <rdfs:comment xml:lang="en">Human-readable display label for Class and ObjectProperty nodes.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dg;range">
        <rdfs:label xml:lang="en">range</rdfs:label>
        <rdfs:comment xml:lang="en">XSD datatype range for DatatypeProperty nodes (e.g. xsd:decimal, xsd:integer, xsd:boolean).</rdfs:comment>
        <rdfs:domain rdf:resource="&dg;DatatypeProperty"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <!-- ************************************************************
         ONTOGRAPH CLASS INSTANCES — from Neo4j OntoGraph (all projects)
         ************************************************************ -->

    <owl:NamedIndividual rdf:about="&dg;Class_Building">
        <rdf:type rdf:resource="&dg;Class"/>
        <rdfs:label xml:lang="en">Building</rdfs:label>
        <dg:iri>ex:Building</dg:iri>
        <dg:label>Building</dg:label>
        <dg:project>UrbanBlock</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;Class_LivingUnit">
        <rdf:type rdf:resource="&dg;Class"/>
        <rdfs:label xml:lang="en">LivingUnit</rdfs:label>
        <dg:iri>ex:LivingUnit</dg:iri>
        <dg:label>LivingUnit</dg:label>
        <dg:project>TestA</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;Class_Street">
        <rdf:type rdf:resource="&dg;Class"/>
        <rdfs:label xml:lang="en">Street</rdfs:label>
        <dg:iri>ex:Street</dg:iri>
        <dg:label>Street</dg:label>
        <dg:project>TestA</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;Class_Unit">
        <rdf:type rdf:resource="&dg;Class"/>
        <rdfs:label xml:lang="en">Unit</rdfs:label>
        <dg:iri>ex:Unit</dg:iri>
        <dg:label>Unit</dg:label>
        <dg:project>Test Project</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <!-- ************************************************************
         ONTOGRAPH DATATYPE PROPERTY INSTANCES — from Neo4j OntoGraph (all projects)
         ************************************************************ -->

    <owl:NamedIndividual rdf:about="&dg;DProp_hasHeightM">
        <rdf:type rdf:resource="&dg;DatatypeProperty"/>
        <rdfs:label xml:lang="en">hasHeightM</rdfs:label>
        <dg:iri>ex:hasHeightM</dg:iri>
        <dg:range>xsd:decimal</dg:range>
        <dg:project>UrbanBlock</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;DProp_hasWidthM">
        <rdf:type rdf:resource="&dg;DatatypeProperty"/>
        <rdfs:label xml:lang="en">hasWidthM</rdfs:label>
        <dg:iri>ex:hasWidthM</dg:iri>
        <dg:range>xsd:decimal</dg:range>
        <dg:project>TestA</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;DProp_hasWindowCount">
        <rdf:type rdf:resource="&dg;DatatypeProperty"/>
        <rdfs:label xml:lang="en">hasWindowCount</rdfs:label>
        <dg:iri>ex:hasWindowCount</dg:iri>
        <dg:range>xsd:integer</dg:range>
        <dg:project>TestA</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;DProp_violatesMaxHeight">
        <rdf:type rdf:resource="&dg;DatatypeProperty"/>
        <rdfs:label xml:lang="en">violatesMaxHeight</rdfs:label>
        <dg:iri>ex:violatesMaxHeight</dg:iri>
        <dg:range>xsd:boolean</dg:range>
        <dg:project>UrbanBlock</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;DProp_violatesMinWidth">
        <rdf:type rdf:resource="&dg;DatatypeProperty"/>
        <rdfs:label xml:lang="en">violatesMinWidth</rdfs:label>
        <dg:iri>ex:violatesMinWidth</dg:iri>
        <dg:range>xsd:boolean</dg:range>
        <dg:project>TestA</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dg;DProp_violatesMinWindowCount">
        <rdf:type rdf:resource="&dg;DatatypeProperty"/>
        <rdfs:label xml:lang="en">violatesMinWindowCount</rdfs:label>
        <dg:iri>ex:violatesMinWindowCount</dg:iri>
        <dg:range>xsd:boolean</dg:range>
        <dg:project>TestA</dg:project>
        <dg:graph>OntoGraph</dg:graph>
    </owl:NamedIndividual>

    <!-- ============================================================

         LAYER 2: METAGRAPH — SWRL RULE STRUCTURE
         Meta-ontology classes that describe SWRL rules, atoms,
         variables, literals, and builtins as first-class graph nodes.

         ============================================================ -->

    <!-- ************************************************************
         METAGRAPH CLASSES
         ************************************************************ -->

    <owl:Class rdf:about="&dgm;Rule">
        <rdfs:label xml:lang="en">Rule</rdfs:label>
        <rdfs:comment xml:lang="en">A design grammar rule expressed as a SWRL implication. Contains body atoms (conditions) and head atoms (conclusions). Key property: Rule_Id. Format: R_&lt;DOMAIN&gt;_&lt;PROPERTY&gt;_&lt;LIMIT&gt;_V</rdfs:comment>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;Atom">
        <rdfs:label xml:lang="en">Atom</rdfs:label>
        <rdfs:comment xml:lang="en">An individual SWRL atom — a single predicate assertion within a rule. Types: ClassAtom, DataPropertyAtom, ObjectPropertyAtom, BuiltinAtom. Key property: Atom_Id.</rdfs:comment>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;ClassAtom">
        <rdfs:label xml:lang="en">ClassAtom</rdfs:label>
        <rdfs:comment xml:lang="en">An atom asserting class membership (e.g. Building(?b)). Takes one variable argument at pos 1.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="&dgm;Atom"/>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;DataPropertyAtom">
        <rdfs:label xml:lang="en">DataPropertyAtom</rdfs:label>
        <rdfs:comment xml:lang="en">An atom asserting a datatype property value (e.g. hasHeightM(?b, ?h)). Takes two arguments: entity variable (pos 1) and value variable/literal (pos 2).</rdfs:comment>
        <rdfs:subClassOf rdf:resource="&dgm;Atom"/>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;ObjectPropertyAtom">
        <rdfs:label xml:lang="en">ObjectPropertyAtom</rdfs:label>
        <rdfs:comment xml:lang="en">An atom asserting an object property relationship (e.g. locatedIn(?b, ?block)). Takes two variable arguments.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="&dgm;Atom"/>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;BuiltinAtom">
        <rdfs:label xml:lang="en">BuiltinAtom</rdfs:label>
        <rdfs:comment xml:lang="en">An atom invoking a SWRL builtin comparison operator (e.g. swrlb:greaterThan(?h, 75)). Takes two arguments for comparison.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="&dgm;Atom"/>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;Variable">
        <rdfs:label xml:lang="en">Variable</rdfs:label>
        <rdfs:comment xml:lang="en">A SWRL variable (e.g. ?b, ?h). Key property: name (prefixed with '?'). Variable kind (Object vs Property) is inferred at read-time from atom structure (VTYP-01). MERGE key includes project to prevent cross-project collision (SCHM-02).</rdfs:comment>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;ObjectVariable">
        <rdfs:label xml:lang="en">ObjectVariable</rdfs:label>
        <rdfs:comment xml:lang="en">A variable representing a domain entity instance (e.g. ?b for Building). Inferred from ClassAtom arguments (VTYP-01). Object variables are cross-rule scoped: the same variable name maps to the same entity across all rules in a project (VTYP-02). Can be wired to OBJECT STATE component to create ObjectState (CMPST-01).</rdfs:comment>
        <rdfs:subClassOf rdf:resource="&dgm;Variable"/>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;PropertyVariable">
        <rdfs:label xml:lang="en">PropertyVariable</rdfs:label>
        <rdfs:comment xml:lang="en">A variable representing a datatype property value (e.g. ?h for height). Inferred from DataPropertyAtom arg-2 position (VTYP-01). Property variables are rule-scoped: the same name in different rules represents independent variables (VTYP-03).</rdfs:comment>
        <rdfs:subClassOf rdf:resource="&dgm;Variable"/>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;Literal">
        <rdfs:label xml:lang="en">Literal</rdfs:label>
        <rdfs:comment xml:lang="en">A constant value used as an atom argument (e.g. 75, true). Key properties: lex (lexical form) + datatype (xsd type).</rdfs:comment>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;Builtin">
        <rdfs:label xml:lang="en">Builtin</rdfs:label>
        <rdfs:comment xml:lang="en">A SWRL builtin comparison or arithmetic operator. Referenced by BuiltinAtom via REFERS_TO. Key property: iri (swrlb: prefix).</rdfs:comment>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <owl:Class rdf:about="&dgm;DesignRuleSession">
        <rdfs:label xml:lang="en">DesignRuleSession</rdfs:label>
        <rdfs:comment xml:lang="en">An interaction log for rule ingest/query/edit operations. Stores the user prompt and LLM result for audit and undo capability.</rdfs:comment>
        <dg:graph>Metagraph</dg:graph>
    </owl:Class>

    <!-- ************************************************************
         METAGRAPH DATATYPE PROPERTIES
         ************************************************************ -->

    <owl:DatatypeProperty rdf:about="&dgm;ruleId">
        <rdfs:label xml:lang="en">Rule_Id</rdfs:label>
        <rdfs:comment xml:lang="en">Unique identifier for a rule. Format: R_&lt;DOMAIN&gt;_&lt;PROPERTY&gt;_&lt;LIMIT&gt;_V (e.g. R_URB_HEIGHT_MAX_75_V).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Rule"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;ruleText">
        <rdfs:label xml:lang="en">text</rdfs:label>
        <rdfs:comment xml:lang="en">The SWRL expression string for a rule (e.g. Building(?b)^hasHeightM(?b,?h)^swrlb:greaterThan(?h,75)-&gt;violatesMaxHeight(?b,true)).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Rule"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;ruleKind">
        <rdfs:label xml:lang="en">kind</rdfs:label>
        <rdfs:comment xml:lang="en">Rule kind: 'violation' (body fires on constraint breach) or 'compliance' (body fires on constraint satisfaction).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Rule"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;ruleTitle">
        <rdfs:label xml:lang="en">title</rdfs:label>
        <rdfs:comment xml:lang="en">Optional human-readable title for a rule.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Rule"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;atomId">
        <rdfs:label xml:lang="en">Atom_Id</rdfs:label>
        <rdfs:comment xml:lang="en">Unique identifier for an atom. Body: {Rule_Id}_A{n}, Head: {Rule_Id}_H{n}.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Atom"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;atomType">
        <rdfs:label xml:lang="en">type</rdfs:label>
        <rdfs:comment xml:lang="en">Atom type discriminator: ClassAtom, DataPropertyAtom, ObjectPropertyAtom, BuiltinAtom.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Atom"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;atomIri">
        <rdfs:label xml:lang="en">iri</rdfs:label>
        <rdfs:comment xml:lang="en">IRI of the ontology entity referenced by this atom (e.g. ex:Building, swrlb:greaterThan).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Atom"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;atomSwrlLabel">
        <rdfs:label xml:lang="en">SWRL_label</rdfs:label>
        <rdfs:comment xml:lang="en">Display label for the atom in SWRL notation.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Atom"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;variableName">
        <rdfs:label xml:lang="en">name</rdfs:label>
        <rdfs:comment xml:lang="en">Variable name prefixed with '?' (e.g. ?b, ?h, ?lu).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Variable"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;variableKind">
        <rdfs:label xml:lang="en">variableKind</rdfs:label>
        <rdfs:comment xml:lang="en">Variable kind discriminator: 'Object' (inferred from ClassAtom arg, cross-rule scoped per VTYP-02) or 'Property' (inferred from DataPropertyAtom arg-2, rule-scoped per VTYP-03). Inferred at read-time by VariableTypeInferrer.Infer() — not stored on the Neo4j Var node (VTYP-01).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Variable"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;variableScope">
        <rdfs:label xml:lang="en">variableScope</rdfs:label>
        <rdfs:comment xml:lang="en">Scoping semantics: 'cross-rule' for Object variables (shared identity across rules in a project, VTYP-02) or 'rule-scoped' for Property variables (independent per rule, VTYP-03). Derived from variableKind.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Variable"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;inferredDatatype">
        <rdfs:label xml:lang="en">inferredDatatype</rdfs:label>
        <rdfs:comment xml:lang="en">XSD datatype inferred for this variable from SWRL atom context (e.g. xsd:decimal for a variable used in hasHeightM). Set by VariableTypeInferrer.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Variable"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;literalLex">
        <rdfs:label xml:lang="en">lex</rdfs:label>
        <rdfs:comment xml:lang="en">Lexical form of the literal value (e.g. "75", "true", "2.8").</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Literal"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;literalDatatype">
        <rdfs:label xml:lang="en">datatype</rdfs:label>
        <rdfs:comment xml:lang="en">XSD datatype of the literal (e.g. xsd:decimal, xsd:integer, xsd:boolean, xsd:string).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Literal"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;builtinIri">
        <rdfs:label xml:lang="en">iri</rdfs:label>
        <rdfs:comment xml:lang="en">IRI of the SWRL builtin (e.g. swrlb:greaterThan).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Builtin"/>
        <rdfs:range rdf:resource="&xsd;anyURI"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;builtinLabel">
        <rdfs:label xml:lang="en">label</rdfs:label>
        <rdfs:comment xml:lang="en">Display label for the builtin (e.g. greaterThan, lessThan).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Builtin"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;sessionId">
        <rdfs:label xml:lang="en">sessionId</rdfs:label>
        <rdfs:comment xml:lang="en">Unique identifier for a DesignRuleSession (format: drs-&lt;hex12&gt;).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;DesignRuleSession"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;sessionMode">
        <rdfs:label xml:lang="en">mode</rdfs:label>
        <rdfs:comment xml:lang="en">Interaction mode: 'ingest', 'query', or 'edit'.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;DesignRuleSession"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;sessionPrompt">
        <rdfs:label xml:lang="en">prompt</rdfs:label>
        <rdfs:comment xml:lang="en">The user's natural-language prompt that triggered this session.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;DesignRuleSession"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;sessionResult">
        <rdfs:label xml:lang="en">result</rdfs:label>
        <rdfs:comment xml:lang="en">The LLM-generated Cypher result of the session.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;DesignRuleSession"/>
        <rdfs:range rdf:resource="&xsd;string"/>
    </owl:DatatypeProperty>

    <!-- ************************************************************
         METAGRAPH OBJECT PROPERTIES — Rule Structure Relationships
         ************************************************************ -->

    <owl:ObjectProperty rdf:about="&dgm;hasBody">
        <rdfs:label xml:lang="en">HAS_BODY</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a Rule to its body (condition) atoms. The body checks the condition that breaks the rule in violation mode. Property: order (integer, 1-indexed).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Rule"/>
        <rdfs:range rdf:resource="&dgm;Atom"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&dgm;hasHead">
        <rdfs:label xml:lang="en">HAS_HEAD</rdfs:label>
        <rdfs:comment xml:lang="en">Connects a Rule to its head (conclusion) atoms. The head sets the violation flag to true when the body fires. Property: order (integer, 1-indexed).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Rule"/>
        <rdfs:range rdf:resource="&dgm;Atom"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&dgm;refersTo">
        <rdfs:label xml:lang="en">REFERS_TO</rdfs:label>
        <rdfs:comment xml:lang="en">Connects an Atom to the ontology entity it references (Class, DatatypeProperty, ObjectProperty, or Builtin). Each Atom has exactly one REFERS_TO.</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Atom"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="&dgm;hasArg">
        <rdfs:label xml:lang="en">ARG</rdfs:label>
        <rdfs:comment xml:lang="en">Connects an Atom to its arguments (Variable or Literal). Property: pos (integer, 1-indexed position).</rdfs:comment>
        <rdfs:domain rdf:resource="&dgm;Atom"/>
    </owl:ObjectProperty>

    <!-- Relationship attribute properties -->

    <owl:DatatypeProperty rdf:about="&dgm;order">
        <rdfs:label xml:lang="en">order</rdfs:label>
        <rdfs:comment xml:lang="en">Ordinal position of an atom within a rule's body or head (1-indexed). Stored on HAS_BODY and HAS_HEAD relationships.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="&dgm;pos">
        <rdfs:label xml:lang="en">pos</rdfs:label>
        <rdfs:comment xml:lang="en">Positional index of an argument within an atom (1-indexed). Stored on ARG relationships.</rdfs:comment>
        <rdfs:range rdf:resource="&xsd;integer"/>
    </owl:DatatypeProperty>

    <!-- ************************************************************
         BUILTIN INDIVIDUALS — Supported SWRL comparison operators
         ************************************************************ -->

    <owl:NamedIndividual rdf:about="&dgm;greaterThan">
        <rdf:type rdf:resource="&dgm;Builtin"/>
        <rdfs:label xml:lang="en">greaterThan</rdfs:label>
        <rdfs:comment xml:lang="en">swrlb:greaterThan — checks if first arg is strictly greater than second. Used for maximum constraints (violation when value exceeds limit).</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;lessThan">
        <rdf:type rdf:resource="&dgm;Builtin"/>
        <rdfs:label xml:lang="en">lessThan</rdfs:label>
        <rdfs:comment xml:lang="en">swrlb:lessThan — checks if first arg is strictly less than second. Used for minimum constraints (violation when value below limit).</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;greaterThanOrEqual">
        <rdf:type rdf:resource="&dgm;Builtin"/>
        <rdfs:label xml:lang="en">greaterThanOrEqual</rdfs:label>
        <rdfs:comment xml:lang="en">swrlb:greaterThanOrEqual — checks if first arg is greater than or equal to second.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;lessThanOrEqual">
        <rdf:type rdf:resource="&dgm;Builtin"/>
        <rdfs:label xml:lang="en">lessThanOrEqual</rdfs:label>
        <rdfs:comment xml:lang="en">swrlb:lessThanOrEqual — checks if first arg is less than or equal to second.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;equal">
        <rdf:type rdf:resource="&dgm;Builtin"/>
        <rdfs:label xml:lang="en">equal</rdfs:label>
        <rdfs:comment xml:lang="en">swrlb:equal — checks if two arguments are equal.</rdfs:comment>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;notEqual">
        <rdf:type rdf:resource="&dgm;Builtin"/>
        <rdfs:label xml:lang="en">notEqual</rdfs:label>
        <rdfs:comment xml:lang="en">swrlb:notEqual — checks if two arguments are not equal. Used for equality constraints (violation when value differs).</rdfs:comment>
    </owl:NamedIndividual>

    <!-- ************************************************************
         METAGRAPH INSTANCES — from Neo4j database
         5 Rules, 20 Atoms, 5 Variables, 5 Literals, 2 Builtins,
         5 DesignRuleSessions across projects: UrbanBlock, TestA, Test Project
         ************************************************************ -->

    <!-- === Rules === -->

    <owl:NamedIndividual rdf:about="&dgm;R_BUILDING_MAX_HEIGHT_75_V">
        <rdf:type rdf:resource="&dgm;Rule"/>
        <rdfs:label xml:lang="en">R_BUILDING_MAX_HEIGHT_75_V</rdfs:label>
        <dgm:ruleId>R_BUILDING_MAX_HEIGHT_75_V</dgm:ruleId>
        <dgm:ruleKind>violation</dgm:ruleKind>
        <dgm:ruleText>Building(?b)^hasHeightM(?b,?h)^swrlb:greaterThan(?h,75)-&gt;violatesMaxHeight(?b,true)</dgm:ruleText>
        <dgm:hasBody rdf:resource="&dgm;R_BUILDING_MAX_HEIGHT_75_V_A1"/>
        <dgm:hasBody rdf:resource="&dgm;R_BUILDING_MAX_HEIGHT_75_V_A2"/>
        <dgm:hasBody rdf:resource="&dgm;R_BUILDING_MAX_HEIGHT_75_V_A3"/>
        <dgm:hasHead rdf:resource="&dgm;R_BUILDING_MAX_HEIGHT_75_V_H1"/>
        <dg:graph>Metagraph</dg:graph>
        <dg:project>UrbanBlock</dg:project>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;R_BUILDING_MAX_HEIGHT_80_V">
        <rdf:type rdf:resource="&dgm;Rule"/>
        <rdfs:label xml:lang="en">R_BUILDING_MAX_HEIGHT_80_V</rdfs:label>
        <dgm:ruleId>R_BUILDING_MAX_HEIGHT_80_V</dgm:ruleId>
        <dgm:ruleKind>violation</dgm:ruleKind>
        <dgm:ruleText>Building(?b)^hasHeightM(?b,?h)^swrlb:greaterThan(?h,80)-&gt;violatesMaxHeight(?b,true)</dgm:ruleText>
        <dg:graph>Metagraph</dg:graph>
        <dg:project>TestA</dg:project>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;R_LIVINGUNIT_MIN_WINDOW_2_V">
        <rdf:type rdf:resource="&dgm;Rule"/>
        <rdfs:label xml:lang="en">R_LIVINGUNIT_MIN_WINDOW_2_V</rdfs:label>
        <dgm:ruleId>R_LIVINGUNIT_MIN_WINDOW_2_V</dgm:ruleId>
        <dgm:ruleKind>violation</dgm:ruleKind>
        <dgm:ruleText>LivingUnit(?u)^hasWindowCount(?u,?w)^swrlb:lessThan(?w,2)-&gt;violatesMinWindowCount(?u,true)</dgm:ruleText>
        <dg:graph>Metagraph</dg:graph>
        <dg:project>TestA</dg:project>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="&dgm;R_STREET_MIN_WIDTH_18_V">
