        <dgm:ruleId>R_UNIT_MIN_WINDOW_2_V</dgm:ruleId>
        <dgm:ruleKind>violation</dgm:ruleKind>
        <dgm:ruleText>Unit(?u)^hasWindowCount(?u,?w)^swrlb:lessThan(?w,2)-&gt;violatesMinWindowCount(?u,true)</dgm:ruleText>
        <dg:graph>Metagraph</dg:graph>
        <dg:project>Test Project</dg:project>
    </owl:NamedIndividual>

